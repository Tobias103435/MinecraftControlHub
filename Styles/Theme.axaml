<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Palette notes:
        Base surfaces step from near-black (app background) up through the
        sidebar/topbar to elevated panel surfaces, so depth reads through
        value alone rather than borders. Accent is a violet-blue rather than
        a literal brand color, used sparingly for the active nav indicator,
        selected version pill, and future primary actions.
    -->

    <!-- Surface colors -->
    <Color x:Key="ColorAppBackground">#15161A</Color>
    <Color x:Key="ColorSidebarBackground">#1B1D23</Color>
    <Color x:Key="ColorPanelBackground">#22252B</Color>
    <Color x:Key="ColorPanelElevated">#2A2E36</Color>
    <Color x:Key="ColorBorder">#33363F</Color>

    <!-- Accent / status colors -->
    <Color x:Key="ColorAccent">#6C5DD3</Color>
    <Color x:Key="ColorAccentHover">#8172E0</Color>
    <Color x:Key="ColorOnline">#57C785</Color>
    <Color x:Key="ColorOffline">#7A7F8A</Color>
    <Color x:Key="ColorDanger">#E5534B</Color>

    <!-- Text colors -->
    <Color x:Key="ColorTextPrimary">#E8E9ED</Color>
    <Color x:Key="ColorTextSecondary">#9098A3</Color>
    <Color x:Key="ColorTextMuted">#5C6270</Color>

    <!-- Info banner colors -->
    <Color x:Key="ColorInfoBg">#0E2233</Color>
    <Color x:Key="ColorInfoText">#60AAEE</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="BrushAppBackground" Color="{StaticResource ColorAppBackground}"/>
    <SolidColorBrush x:Key="BrushSidebarBackground" Color="{StaticResource ColorSidebarBackground}"/>
    <SolidColorBrush x:Key="BrushPanelBackground" Color="{StaticResource ColorPanelBackground}"/>
    <SolidColorBrush x:Key="BrushPanelElevated" Color="{StaticResource ColorPanelElevated}"/>
    <SolidColorBrush x:Key="BrushBorder" Color="{StaticResource ColorBorder}"/>

    <SolidColorBrush x:Key="BrushAccent" Color="{StaticResource ColorAccent}"/>
    <SolidColorBrush x:Key="BrushAccentHover" Color="{StaticResource ColorAccentHover}"/>
    <SolidColorBrush x:Key="BrushOnline" Color="{StaticResource ColorOnline}"/>
    <SolidColorBrush x:Key="BrushOffline" Color="{StaticResource ColorOffline}"/>
    <SolidColorBrush x:Key="BrushDanger" Color="{StaticResource ColorDanger}"/>

    <SolidColorBrush x:Key="BrushTextPrimary" Color="{StaticResource ColorTextPrimary}"/>
    <SolidColorBrush x:Key="BrushTextSecondary" Color="{StaticResource ColorTextSecondary}"/>
    <SolidColorBrush x:Key="BrushTextMuted" Color="{StaticResource ColorTextMuted}"/>

    <SolidColorBrush x:Key="BrushInfoBg" Color="{StaticResource ColorInfoBg}"/>
    <SolidColorBrush x:Key="BrushInfoText" Color="{StaticResource ColorInfoText}"/>

    <!-- Typography -->
    <FontFamily x:Key="FontDisplay">Segoe UI Semibold</FontFamily>
    <FontFamily x:Key="FontBody">Segoe UI</FontFamily>

</ResourceDictionary>
