<UserControl x:Class="MinecraftControlHub.UI.Components.TopBar"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="48">

    <Border Height="48"
            Background="{DynamicResource BrushSidebarBackground}"
            BorderBrush="{DynamicResource BrushBorder}"
            BorderThickness="0,0,0,1">

        <Grid ColumnDefinitions="*,Auto">

            <!-- Update available banner (hidden until update check returns true) -->
            <Border x:Name="UpdateBanner"
                    Grid.Column="0"
                    IsVisible="False"
                    Background="#1A4CAF7D"
                    BorderBrush="#4CAF7D"
                    BorderThickness="0,0,0,2"
                    Padding="14,0"
                    VerticalAlignment="Stretch"
                    Cursor="Hand"
                    PointerReleased="UpdateBanner_Click">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="10">
                    <!-- Green dot indicator -->
                    <Ellipse Width="8" Height="8" Fill="#4CAF7D" VerticalAlignment="Center"/>
                    <TextBlock x:Name="UpdateBannerText"
                               Text="An update is available — click to update"
                               FontFamily="{DynamicResource FontBody}"
                               FontSize="12.5" FontWeight="SemiBold"
                               Foreground="#4CAF7D"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="0,0,16,0">

                <!-- Bell button — badge sits OUTSIDE the ControlTemplate so code-behind can reach it -->
                <Grid Width="36" Height="36">

                    <Button x:Name="BellButton"
                            Click="BellButton_Click"
                            ToolTip.Tip="Notifications"
                            Width="36" Height="36"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Padding="0">
                        <Button.Styles>
                            <Style Selector="Button:pointerover /template/ Border#Bg">
                                <Setter Property="Background" Value="{DynamicResource BrushPanelElevated}"/>
                            </Style>
                        </Button.Styles>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bg"
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="6"
                                        Width="36" Height="36">
                                    <ContentPresenter Content="{TemplateBinding Content}"
                                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <Canvas Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False">
                            <!-- Bell body -->
                            <Path Data="M 3 7 C 3 4 6 2 9 2 C 12 2 15 4 15 7 L 15 11 L 16 11 L 16 12 L 2 12 L 2 11 L 3 11 Z" Fill="{Binding $parent[Button].Foreground}"/>
                            <!-- Bell top loop -->
                            <Path Data="M 6 2 C 6 0.5 12 0.5 12 2" Stroke="{Binding $parent[Button].Foreground}" StrokeThickness="1.6" StrokeLineCap="Round"/>
                            <!-- Bell clapper -->
                            <Ellipse Canvas.Left="7" Canvas.Top="13" Width="4" Height="3" Fill="{Binding $parent[Button].Foreground}"/>
                        </Canvas>
                    </Button>

                    <!-- Badge — named here at UserControl level, accessible from code-behind -->
                    <Border x:Name="BadgeBorder"
                            IsVisible="False"
                            Background="{DynamicResource BrushDanger}"
                            CornerRadius="8"
                            MinWidth="16" Height="16"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,1,1,0"
                            Padding="3,0"
                            IsHitTestVisible="False">
                        <TextBlock x:Name="BadgeText"
                                   FontFamily="{DynamicResource FontBody}"
                                   FontSize="9" FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                </Grid>
            </StackPanel>

            <!-- Notification flyout popup -->
            <Popup x:Name="NotificationPopup"
                   Grid.Column="1"
                   Placement="Bottom"
                   PlacementTarget="{Binding #BellButton}"
                   IsLightDismissEnabled="True">
                <Border Background="{DynamicResource BrushPanelBackground}"
                        BorderBrush="{DynamicResource BrushBorder}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Width="360"
                        MaxHeight="480"
                        Margin="0,4,16,0"
                        BoxShadow="0 4 16 0 #59000000">

                    <Grid RowDefinitions="Auto,*">

                        <!-- Popup header -->
                        <Border Grid.Row="0"
                                BorderBrush="{DynamicResource BrushBorder}"
                                BorderThickness="0,0,0,1"
                                Padding="16,12">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0"
                                           Text="Notifications"
                                           FontFamily="{DynamicResource FontDisplay}"
                                           FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource BrushTextPrimary}"
                                           VerticalAlignment="Center"/>
                                <Button Grid.Column="1"
                                        x:Name="MarkAllReadButton"
                                        Content="Mark all read"
                                        Click="MarkAllRead_Click"
                                        Theme="{StaticResource SecondaryButtonStyle}"
                                        Padding="10,4" FontSize="11"/>
                            </Grid>
                        </Border>

                        <!-- Notifications list -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel>

                                <!-- Empty state -->
                                <TextBlock x:Name="EmptyNotifText"
                                           Text="No notifications yet."
                                           FontFamily="{DynamicResource FontBody}"
                                           FontSize="13"
                                           Foreground="{DynamicResource BrushTextMuted}"
                                           HorizontalAlignment="Center"
                                           Margin="0,24"/>

                                <!-- Notification items -->
                                <ItemsControl x:Name="NotificationList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{DynamicResource BrushBorder}"
                                                    BorderThickness="0,0,0,1"
                                                    Padding="16,12"
                                                    Cursor="Hand"
                                                    PointerReleased="NotifRow_Click"
                                                    Tag="{Binding}"
                                                    Classes.unread="{Binding !IsRead}">
                                                <Border.Styles>
                                                    <Style Selector="Border.unread">
                                                        <Setter Property="Background" Value="{DynamicResource BrushPanelElevated}"/>
                                                    </Style>
                                                    <Style Selector="Border:pointerover">
                                                        <Setter Property="Background" Value="{DynamicResource BrushPanelElevated}"/>
                                                    </Style>
                                                </Border.Styles>

                                                <Grid ColumnDefinitions="Auto,*">

                                                    <!-- Sender avatar -->
                                                    <Border Grid.Column="0"
                                                            Width="36" Height="36" CornerRadius="18"
                                                            Background="{DynamicResource BrushAccent}"
                                                            Margin="0,0,12,0">
                                                        <TextBlock Text="{Binding SenderInitial}"
                                                                   FontFamily="{DynamicResource FontDisplay}"
                                                                   FontSize="15" Foreground="White"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>

                                                    <StackPanel Grid.Column="1">
                                                        <!-- Header row -->
                                                        <Grid Margin="0,0,0,6" ColumnDefinitions="*,Auto">
                                                            <TextBlock Grid.Column="0"
                                                                       FontFamily="{DynamicResource FontBody}"
                                                                       FontSize="12"
                                                                       Foreground="{DynamicResource BrushTextPrimary}"
                                                                       TextWrapping="Wrap">
                                                                <Run Text="{Binding SenderUsername, Mode=OneWay}" FontWeight="SemiBold"/>
                                                                <Run Text=" shared an IP with you" Foreground="{DynamicResource BrushTextSecondary}"/>
                                                            </TextBlock>
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding TimeLabel}"
                                                                       FontFamily="{DynamicResource FontBody}"
                                                                       FontSize="10"
                                                                       Foreground="{DynamicResource BrushTextMuted}"
                                                                       VerticalAlignment="Top"
                                                                       Margin="8,1,0,0"/>
                                                        </Grid>

                                                        <!-- IP / Port info block -->
                                                        <Border Background="{DynamicResource BrushAppBackground}"
                                                                CornerRadius="5" Padding="10,8"
                                                                Margin="0,0,0,8">
                                                            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto">

                                                                <TextBlock Grid.Row="0" Grid.Column="0"
                                                                           Text="IP:"
                                                                           FontFamily="{DynamicResource FontBody}"
                                                                           FontSize="11"
                                                                           Foreground="{DynamicResource BrushTextMuted}"
                                                                           Margin="0,0,8,3"/>
                                                                <TextBlock Grid.Row="0" Grid.Column="1"
                                                                           Text="{Binding Tunnel.Ip}"
                                                                           FontFamily="Consolas, Courier New, monospace"
                                                                           FontSize="12"
                                                                           Foreground="#4CAF7D"
                                                                           Margin="0,0,0,3"/>

                                                                <TextBlock Grid.Row="1" Grid.Column="0"
                                                                           Text="Port:"
                                                                           FontFamily="{DynamicResource FontBody}"
                                                                           FontSize="11"
                                                                           Foreground="{DynamicResource BrushTextMuted}"
                                                                           Margin="0,0,8,0"/>
                                                                <TextBlock Grid.Row="1" Grid.Column="1"
                                                                           Text="{Binding Tunnel.Port}"
                                                                           FontFamily="Consolas, Courier New, monospace"
                                                                           FontSize="12"
                                                                           Foreground="#4CAF7D"/>
                                                            </Grid>
                                                        </Border>

                                                        <!-- Copy buttons -->
                                                        <StackPanel Orientation="Horizontal">
                                                            <Button Content="Copy IP"
                                                                    Tag="{Binding Tunnel.Ip}"
                                                                    Click="CopyIp_Click"
                                                                    Theme="{StaticResource SecondaryButtonStyle}"
                                                                    Padding="10,4" FontSize="10"
                                                                    Margin="0,0,6,0"/>
                                                            <Button Content="Copy Port"
                                                                    Tag="{Binding Tunnel.Port}"
                                                                    Click="CopyPort_Click"
                                                                    Theme="{StaticResource SecondaryButtonStyle}"
                                                                    Padding="10,4" FontSize="10"
                                                                    Margin="0,0,6,0"/>
                                                            <Button Content="Copy IP:PORT"
                                                                    Tag="{Binding Tunnel.IpPort}"
                                                                    Click="CopyIpPort_Click"
                                                                    Theme="{StaticResource SecondaryButtonStyle}"
                                                                    Padding="10,4" FontSize="10"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Popup>
        </Grid>
    </Border>
</UserControl>
