<UserControl x:Class="MinecraftControlHub.UI.Components.TopBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="48">

    <Border Height="48"
            Background="{DynamicResource BrushSidebarBackground}"
            BorderBrush="{DynamicResource BrushBorder}"
            BorderThickness="0,0,0,1">

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Right side: notification bell -->
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="0,0,16,0">

                <!-- Bell button — badge sits OUTSIDE the ControlTemplate so code-behind can reach it -->
                <Grid Width="36" Height="36">

                    <Button x:Name="BellButton"
                            Click="BellButton_Click"
                            ToolTip="Notifications"
                            Width="36" Height="36"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Padding="0">
                        <TextBlock Text="🔔"
                                   FontSize="16"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False"/>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bg"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="6"
                                                    Width="36" Height="36">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bg" Property="Background"
                                                            Value="{DynamicResource BrushPanelElevated}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Badge — named here at UserControl level, accessible from code-behind -->
                    <Border x:Name="BadgeBorder"
                            Visibility="Collapsed"
                            Background="{DynamicResource BrushDanger}"
                            CornerRadius="8"
                            MinWidth="16" Height="16"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,1,1,0"
                            Padding="3,0"
                            IsHitTestVisible="False">
                        <TextBlock x:Name="BadgeText"
                                   FontFamily="{DynamicResource FontBody}"
                                   FontSize="9" FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                </Grid>
            </StackPanel>

            <!-- Notification flyout popup -->
            <Popup x:Name="NotificationPopup"
                   Grid.Column="1"
                   Placement="Bottom"
                   PlacementTarget="{Binding ElementName=BellButton}"
                   StaysOpen="False"
                   AllowsTransparency="True"
                   PopupAnimation="Fade">
                <Border Background="{DynamicResource BrushPanelBackground}"
                        BorderBrush="{DynamicResource BrushBorder}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Width="360"
                        MaxHeight="480"
                        Margin="0,4,16,0">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.35" Color="#000000"/>
                    </Border.Effect>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Popup header -->
                        <Border Grid.Row="0"
                                BorderBrush="{DynamicResource BrushBorder}"
                                BorderThickness="0,0,0,1"
                                Padding="16,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="Notifications"
                                           FontFamily="{DynamicResource FontDisplay}"
                                           FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource BrushTextPrimary}"
                                           VerticalAlignment="Center"/>
                                <Button Grid.Column="1"
                                        x:Name="MarkAllReadButton"
                                        Content="Mark all read"
                                        Click="MarkAllRead_Click"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Padding="10,4" FontSize="11"/>
                            </Grid>
                        </Border>

                        <!-- Notifications list -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel>

                                <!-- Empty state -->
                                <TextBlock x:Name="EmptyNotifText"
                                           Text="No notifications yet."
                                           FontFamily="{DynamicResource FontBody}"
                                           FontSize="13"
                                           Foreground="{DynamicResource BrushTextMuted}"
                                           HorizontalAlignment="Center"
                                           Margin="0,24"/>

                                <!-- Notification items -->
                                <ItemsControl x:Name="NotificationList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{DynamicResource BrushBorder}"
                                                    BorderThickness="0,0,0,1"
                                                    Padding="16,12"
                                                    Cursor="Hand"
                                                    MouseLeftButtonUp="NotifRow_Click"
                                                    Tag="{Binding}">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsRead}" Value="False">
                                                                <Setter Property="Background" Value="{DynamicResource BrushPanelElevated}"/>
                                                            </DataTrigger>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="{DynamicResource BrushPanelElevated}"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Sender avatar -->
                                                    <Border Grid.Column="0"
                                                            Width="36" Height="36" CornerRadius="18"
                                                            Background="{DynamicResource BrushAccent}"
                                                            Margin="0,0,12,0">
                                                        <TextBlock Text="{Binding SenderInitial}"
                                                                   FontFamily="{DynamicResource FontDisplay}"
                                                                   FontSize="15" Foreground="White"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>

                                                    <StackPanel Grid.Column="1">
                                                        <!-- Header row -->
                                                        <Grid Margin="0,0,0,6">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0"
                                                                       FontFamily="{DynamicResource FontBody}"
                                                                       FontSize="12"
                                                                       Foreground="{DynamicResource BrushTextPrimary}"
                                                                       TextWrapping="Wrap">
                                                                <Run Text="{Binding SenderUsername, Mode=OneWay}" FontWeight="SemiBold"/>
                                                                <Run Text=" shared an IP with you" Foreground="{DynamicResource BrushTextSecondary}"/>
                                                            </TextBlock>
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding TimeLabel}"
                                                                       FontFamily="{DynamicResource FontBody}"
                                                                       FontSize="10"
                                                                       Foreground="{DynamicResource BrushTextMuted}"
                                                                       VerticalAlignment="Top"
                                                                       Margin="8,1,0,0"/>
                                                        </Grid>

                                                        <!-- IP / Port info block -->
                                                        <Border Background="{DynamicResource BrushAppBackground}"
                                                                CornerRadius="5" Padding="10,8"
                                                                Margin="0,0,0,8">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <RowDefinition Height="Auto"/>
                                                                </Grid.RowDefinitions>

                                                                <TextBlock Grid.Row="0" Grid.Column="0"
                                                                           Text="IP:"
                                                                           FontFamily="{DynamicResource FontBody}"
                                                                           FontSize="11"
                                                                           Foreground="{DynamicResource BrushTextMuted}"
                                                                           Margin="0,0,8,3"/>
                                                                <TextBlock Grid.Row="0" Grid.Column="1"
                                                                           Text="{Binding Tunnel.Ip}"
                                                                           FontFamily="Consolas, Courier New, monospace"
                                                                           FontSize="12"
                                                                           Foreground="#4CAF7D"
                                                                           Margin="0,0,0,3"/>

                                                                <TextBlock Grid.Row="1" Grid.Column="0"
                                                                           Text="Port:"
                                                                           FontFamily="{DynamicResource FontBody}"
                                                                           FontSize="11"
                                                                           Foreground="{DynamicResource BrushTextMuted}"
                                                                           Margin="0,0,8,0"/>
                                                                <TextBlock Grid.Row="1" Grid.Column="1"
                                                                           Text="{Binding Tunnel.Port}"
                                                                           FontFamily="Consolas, Courier New, monospace"
                                                                           FontSize="12"
                                                                           Foreground="#4CAF7D"/>
                                                            </Grid>
                                                        </Border>

                                                        <!-- Copy buttons -->
                                                        <StackPanel Orientation="Horizontal">
                                                            <Button Content="Copy IP"
                                                                    Tag="{Binding Tunnel.Ip}"
                                                                    Click="CopyIp_Click"
                                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                                    Padding="10,4" FontSize="10"
                                                                    Margin="0,0,6,0"/>
                                                            <Button Content="Copy Port"
                                                                    Tag="{Binding Tunnel.Port}"
                                                                    Click="CopyPort_Click"
                                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                                    Padding="10,4" FontSize="10"
                                                                    Margin="0,0,6,0"/>
                                                            <Button Content="Copy IP:PORT"
                                                                    Tag="{Binding Tunnel.IpPort}"
                                                                    Click="CopyIpPort_Click"
                                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                                    Padding="10,4" FontSize="10"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Popup>
        </Grid>
    </Border>
</UserControl>
