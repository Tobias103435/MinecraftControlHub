<UserControl x:Class="MinecraftControlHub.UI.Components.Sidebar"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:MinecraftControlHub.UI.Converters"
             mc:Ignorable="d" d:DesignWidth="230" d:DesignHeight="700">
    <UserControl.Resources>
        <converters:BoolToOpacityConverter x:Key="BoolToOpacityConverter"/>
    </UserControl.Resources>

    <Border Background="{DynamicResource BrushSidebarBackground}">
        <DockPanel LastChildFill="True">

            <!-- Brand -->
            <Border DockPanel.Dock="Top" Height="72">
                <StackPanel Orientation="Horizontal" Margin="20,0" VerticalAlignment="Center">
                    <Border Width="28" Height="28" CornerRadius="8" Background="{DynamicResource BrushAccent}">
                        <TextBlock Text="N" FontFamily="{StaticResource FontDisplay}" FontSize="15"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="exora" Margin="10,0,0,0"
                               FontFamily="{StaticResource FontDisplay}" FontSize="15"
                               Foreground="{DynamicResource BrushTextPrimary}" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- ── Bottom: NOT logged in ── -->
            <Border DockPanel.Dock="Bottom"
                    Background="{DynamicResource BrushPanelBackground}"
                    BorderBrush="{DynamicResource BrushBorder}"
                    BorderThickness="0,1,0,0"
                    Padding="14,12"
                    IsVisible="{Binding !$parent[UserControl].IsNexoraLoggedIn}">
                <StackPanel>
                    <TextBlock Text="Log in to use social features"
                               FontFamily="{StaticResource FontBody}" FontSize="11"
                               Foreground="{DynamicResource BrushTextMuted}"
                               Margin="0,0,0,8" TextWrapping="Wrap"/>
                    <Button Content="Log in"
                            Theme="{StaticResource PrimaryButtonStyle}"
                            Padding="0,7"
                            HorizontalAlignment="Stretch"
                            Click="SidebarLogin_Click"/>
                </StackPanel>
            </Border>

            <!-- ── Bottom: logged in ── -->
            <Border DockPanel.Dock="Bottom"
                    Background="{DynamicResource BrushPanelBackground}"
                    BorderBrush="{DynamicResource BrushBorder}"
                    BorderThickness="0,1,0,0"
                    Padding="14,10"
                    IsVisible="{Binding $parent[UserControl].IsNexoraLoggedIn}">
                <Grid ColumnDefinitions="Auto,*">
                    <Border Grid.Column="0" Width="30" Height="30" CornerRadius="15"
                            Background="{DynamicResource BrushAccent}" Margin="0,0,10,0">
                        <TextBlock x:Name="SidebarAvatarInitial" Text="?"
                                   FontFamily="{StaticResource FontDisplay}" FontSize="13"
                                   Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock x:Name="SidebarUsername" Text="Nexora"
                                   FontFamily="{StaticResource FontBody}" FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource BrushTextPrimary}"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="Logged in"
                                   FontFamily="{StaticResource FontBody}" FontSize="11"
                                   Foreground="{DynamicResource BrushTextMuted}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Nav items -->
            <StackPanel Margin="0,8,0,0" ToggleButton.IsCheckedChanged="NavItem_Checked">

                <RadioButton x:Name="NavHome" GroupName="MainNav" Tag="Home"
                             Theme="{StaticResource NavItemStyle}" IsChecked="True">
                    <StackPanel Orientation="Horizontal">
                        <Canvas Width="18" Height="18">
                            <Polygon Points="9,1 17,7.5 17,17 1,17 1,7.5"
                                     Fill="{Binding $parent[RadioButton].Foreground}"/>
                        </Canvas>
                        <TextBlock Text="Home" Margin="14,0,0,0" VerticalAlignment="Center" FontSize="13.5"/>
                    </StackPanel>
                </RadioButton>

                <RadioButton x:Name="NavAccount" GroupName="MainNav" Tag="Account"
                             Theme="{StaticResource NavItemStyle}">
                    <StackPanel Orientation="Horizontal">
                        <Canvas Width="18" Height="18">
                            <Ellipse Canvas.Left="2" Canvas.Top="2" Width="14" Height="14" StrokeThickness="2.2"
                                     Stroke="{Binding $parent[RadioButton].Foreground}"/>
                            <Ellipse Canvas.Left="7" Canvas.Top="7" Width="4" Height="4"
                                     Fill="{Binding $parent[RadioButton].Foreground}"/>
                        </Canvas>
                        <TextBlock Text="Account" Margin="14,0,0,0" VerticalAlignment="Center" FontSize="13.5"/>
                    </StackPanel>
                </RadioButton>

                <RadioButton x:Name="NavServers" GroupName="MainNav" Tag="Servers"
                             Theme="{StaticResource NavItemStyle}">
                    <Grid>
                        <StackPanel Orientation="Horizontal">
                            <Canvas Width="18" Height="18">
                                <Rectangle Canvas.Left="1" Canvas.Top="1" Width="16" Height="3.5" RadiusX="1.5" RadiusY="1.5"
                                           Fill="{Binding $parent[RadioButton].Foreground}"/>
                                <Rectangle Canvas.Left="1" Canvas.Top="7.25" Width="16" Height="3.5" RadiusX="1.5" RadiusY="1.5"
                                           Fill="{Binding $parent[RadioButton].Foreground}"/>
                                <Rectangle Canvas.Left="1" Canvas.Top="13.5" Width="16" Height="3.5" RadiusX="1.5" RadiusY="1.5"
                                           Fill="{Binding $parent[RadioButton].Foreground}"/>
                            </Canvas>
                            <TextBlock Text="Servers" Margin="14,0,0,0" VerticalAlignment="Center" FontSize="13.5"/>
                        </StackPanel>
                        <!-- Server event notification dot -->
                        <Border x:Name="ServerNotifBadge"
                                Width="8" Height="8" CornerRadius="4"
                                Background="{DynamicResource BrushDanger}"
                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                Margin="0,2,2,0"
                                IsVisible="False"
                                ToolTip.Tip="{Binding #ServerNotifBadge.Tag}"/>
                    </Grid>
                </RadioButton>

                <RadioButton x:Name="NavMods" GroupName="MainNav" Tag="Mods"
                             Theme="{StaticResource NavItemStyle}">
                    <StackPanel Orientation="Horizontal">
                        <Canvas Width="18" Height="18">
                            <Rectangle Canvas.Left="1" Canvas.Top="1" Width="7" Height="7" RadiusX="2" RadiusY="2"
                                       Fill="{Binding $parent[RadioButton].Foreground}"/>
                            <Rectangle Canvas.Left="10" Canvas.Top="1" Width="7" Height="7" RadiusX="2" RadiusY="2"
                                       Fill="{Binding $parent[RadioButton].Foreground}"/>
                            <Rectangle Canvas.Left="1" Canvas.Top="10" Width="7" Height="7" RadiusX="2" RadiusY="2"
                                       Fill="{Binding $parent[RadioButton].Foreground}"/>
                            <Rectangle Canvas.Left="10" Canvas.Top="10" Width="7" Height="7" RadiusX="2" RadiusY="2"
                                       Fill="{Binding $parent[RadioButton].Foreground}"/>
                        </Canvas>
                        <TextBlock Text="Mods" Margin="14,0,0,0" VerticalAlignment="Center" FontSize="13.5"/>
                    </StackPanel>
                </RadioButton>

                <!-- Social — altijd klikbaar, overlay in FriendsPage als niet ingelogd -->
                <RadioButton x:Name="NavFriends" GroupName="MainNav" Tag="Friends"
                             Theme="{StaticResource NavItemStyle}">
                    <StackPanel Orientation="Horizontal">
                        <Canvas Width="18" Height="18">
                            <Ellipse Canvas.Left="1" Canvas.Top="4" Width="10" Height="10" Opacity="0.55"
                                     Fill="{Binding $parent[RadioButton].Foreground}"/>
                            <Ellipse Canvas.Left="7" Canvas.Top="4" Width="10" Height="10" Opacity="0.9"
                                     Fill="{Binding $parent[RadioButton].Foreground}"/>
                        </Canvas>
                        <TextBlock Text="Social" Margin="14,0,0,0" VerticalAlignment="Center" FontSize="13.5"/>
                    </StackPanel>
                </RadioButton>

                <RadioButton x:Name="NavTunnel" GroupName="MainNav" Tag="Tunnel"
                             Theme="{StaticResource NavItemStyle}">
                    <StackPanel Orientation="Horizontal">
                        <Canvas Width="18" Height="18">
                            <Ellipse Canvas.Left="1" Canvas.Top="7" Width="5" Height="5" StrokeThickness="1.6"
                                     Stroke="{Binding $parent[RadioButton].Foreground}"/>
                            <Line StartPoint="6.5,9.5" EndPoint="12.5,9.5" StrokeThickness="1.6"
                                  Stroke="{Binding $parent[RadioButton].Foreground}"/>
                            <Ellipse Canvas.Left="12" Canvas.Top="7" Width="5" Height="5" StrokeThickness="1.6"
                                     Stroke="{Binding $parent[RadioButton].Foreground}"/>
                        </Canvas>
                        <TextBlock Text="Tunnel" Margin="14,0,0,0" VerticalAlignment="Center" FontSize="13.5"/>
                    </StackPanel>
                </RadioButton>

                <RadioButton x:Name="NavAi" GroupName="MainNav" Tag="Ai"
                             Theme="{StaticResource NavItemStyle}">
                    <StackPanel Orientation="Horizontal">
                        <Canvas Width="18" Height="18">
                            <Polygon Points="9,0 11,7 18,9 11,11 9,18 7,11 0,9 7,7"
                                     Fill="{Binding $parent[RadioButton].Foreground}"/>
                        </Canvas>
                        <TextBlock Text="AI" Margin="14,0,0,0" VerticalAlignment="Center" FontSize="13.5"/>
                    </StackPanel>
                </RadioButton>

                <RadioButton x:Name="NavSettings" GroupName="MainNav" Tag="Settings"
                             Theme="{StaticResource NavItemStyle}">
                    <StackPanel Orientation="Horizontal">
                        <Canvas Width="18" Height="18">
                            <Ellipse Canvas.Left="2" Canvas.Top="2" Width="14" Height="14" StrokeThickness="2.2"
                                     Stroke="{Binding $parent[RadioButton].Foreground}"/>
                            <Ellipse Canvas.Left="7" Canvas.Top="7" Width="4" Height="4"
                                     Fill="{Binding $parent[RadioButton].Foreground}"/>
                        </Canvas>
                        <TextBlock Text="Settings" Margin="14,0,0,0" VerticalAlignment="Center" FontSize="13.5"/>
                    </StackPanel>
                </RadioButton>

                <!-- Discord link -->
                <Button x:Name="DiscordButton"
                        Click="DiscordButton_Click"
                        Theme="{StaticResource DiscordButtonStyle}"
                        HorizontalAlignment="Stretch">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Canvas Width="20" Height="20">
                            <!-- Discord icon -->
                            <Path Data="M 3.889 5.556 C 2.222 8.889 2.222 13.333 3.889 16.667 L 5 16.111 C 5 16.111 5.556 14.444 6.667 13.333 C 5 12.222 4.444 10.556 5 8.889 C 6.111 7.778 7.778 7.222 9.444 7.222 C 10.556 7.222 11.667 7.5 12.778 8.056 C 13.889 7.5 15 7.222 16.111 7.222 C 17.778 7.222 19.444 7.778 20.556 8.889 C 21.111 10.556 20.556 12.222 18.889 13.333 C 20 14.444 20.556 16.111 20.556 16.111 L 21.667 16.667 C 23.333 13.333 23.333 8.889 21.667 5.556 C 17.778 3.333 13.333 3.333 9.444 3.333 C 5.556 3.333 3.889 5.556 3.889 5.556 Z M 8.333 10.556 C 9.259 10.556 10 11.299 10 12.222 C 10 13.146 9.259 13.889 8.333 13.889 C 7.407 13.889 6.667 13.146 6.667 12.222 C 6.667 11.299 7.407 10.556 8.333 10.556 Z M 17.222 10.556 C 18.148 10.556 18.889 11.299 18.889 12.222 C 18.889 13.146 18.148 13.889 17.222 13.889 C 16.296 13.889 15.556 13.146 15.556 12.222 C 15.556 11.299 16.296 10.556 17.222 10.556 Z"
                                  Fill="White" Stretch="Uniform"/>
                        </Canvas>
                        <TextBlock Text="Join Discord" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

            </StackPanel>
        </DockPanel>
    </Border>
</UserControl>
