<Window x:Class="MinecraftControlHub.UI.Windows.ServerPreviewWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="Server Preview"
        Width="1100"
        Height="720"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BrushAppBackground}">
    <Window.Resources>
        <ControlTheme x:Key="FriendCheckboxStyle" TargetType="CheckBox">
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="FontFamily" Value="{StaticResource FontBody}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{StaticResource BrushPanelElevated}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <DockPanel>
                                <Border x:Name="CheckBoxMarker"
                                        Width="20"
                                        Height="20"
                                        CornerRadius="5"
                                        Background="Transparent"
                                        BorderBrush="{StaticResource BrushTextSecondary}"
                                        BorderThickness="1"
                                        VerticalAlignment="Center"
                                        Margin="0,0,12,0"
                                        DockPanel.Dock="Left">
                                <Path x:Name="FriendCheckMark"
                                      Data="M 4 10 L 8 14 L 16 6"
                                      Stroke="White"
                                      StrokeThickness="2"
                                      StrokeLineCap="Round"
                                      StrokeJoin="Round"
                                      Opacity="0"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Width="12"
                                      Height="12"/>
                            </Border>
                                <StackPanel>
                                    <ContentPresenter/>
                                    <TextBlock x:Name="DescriptionText"
                                               Text="Can join your server when invited."
                                               FontSize="12"
                                               Foreground="{StaticResource BrushTextSecondary}"
                                               Margin="0,4,0,0"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </DockPanel>
                        </Border>
                        <!-- Triggers removed -->
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </ControlTheme>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{DynamicResource BrushSidebarBackground}">
            <DockPanel LastChildFill="True">

                <!-- Brand / Server name -->
                <Border DockPanel.Dock="Top" Height="72" Padding="20,0">
                    <StackPanel VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Border Width="28" Height="28" CornerRadius="8" Background="{DynamicResource BrushAccent}">
                                <TextBlock Text="S" FontFamily="{StaticResource FontDisplay}" FontSize="15"
                                           Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="{Binding Name}"
                                       Margin="10,0,0,0"
                                       FontFamily="{StaticResource FontDisplay}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource BrushTextPrimary}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       MaxWidth="150"/>
                        </StackPanel>
                        <TextBlock FontFamily="{StaticResource FontBody}"
                                   FontSize="11"
                                   Foreground="{DynamicResource BrushTextMuted}">
                            <Run Text="{Binding Type, Mode=OneWay}"/> · <Run Text="{Binding MinecraftVersion, Mode=OneWay}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Separator -->
                <Border DockPanel.Dock="Top" Height="1"
                        Background="{DynamicResource BrushBorder}"
                        Margin="16,0"/>

                <!-- Nav items -->
                <StackPanel Margin="0,8,0,0">
                    <RadioButton GroupName="ServerNav" Tag="Terminal"
                                 Theme="{StaticResource NavItemStyle}"
                                 IsChecked="True"
                                 Checked="NavRadio_Checked">
                        <TextBlock Text="Terminal" FontSize="13.5"/>
                    </RadioButton>

                    <RadioButton GroupName="ServerNav" Tag="Friends"
                                 Theme="{StaticResource NavItemStyle}"
                                 Checked="NavRadio_Checked">
                        <TextBlock Text="Friends" FontSize="13.5"/>
                    </RadioButton>

                    <RadioButton GroupName="ServerNav" Tag="Settings"
                                 Theme="{StaticResource NavItemStyle}"
                                 Checked="NavRadio_Checked">
                        <TextBlock Text="Settings" FontSize="13.5"/>
                    </RadioButton>

                    <RadioButton GroupName="ServerNav" Tag="Plugins"
                                 Theme="{StaticResource NavItemStyle}"
                                 Checked="NavRadio_Checked">
                        <TextBlock Text="Plugins/Mods" FontSize="13.5"/>
                    </RadioButton>

                    <RadioButton GroupName="ServerNav" Tag="Advanced"
                                 Theme="{StaticResource NavItemStyle}"
                                 Checked="NavRadio_Checked">
                        <TextBlock Text="Advanced" FontSize="13.5"/>
                    </RadioButton>

                    <RadioButton GroupName="ServerNav" Tag="Health"
                                 Theme="{StaticResource NavItemStyle}"
                                 Checked="NavRadio_Checked">
                        <TextBlock Text="Health" FontSize="13.5"/>
                    </RadioButton>
                </StackPanel>

                <!-- Spacer -->
                <Border/>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="24">
            <Border x:Name="TerminalSection"
                    Background="{StaticResource BrushPanelBackground}"
                    BorderBrush="{StaticResource BrushBorder}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="24"
                    IsVisible="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Terminal"
                                   FontFamily="{StaticResource FontDisplay}"
                                   FontSize="20"
                                   Foreground="{StaticResource BrushTextPrimary}"
                                   VerticalAlignment="Center"
                                   Grid.Column="0"/>
                        <Button Content="Clear"
                                Theme="{StaticResource SecondaryButtonStyle}"
                                Width="110"
                                Margin="0,0,12,0"
                                Grid.Column="1"
                                Click="ClearTerminal_Click"/>
                        <Button x:Name="TerminalStartStopButton"
                                Content="Start"
                                Theme="{StaticResource PrimaryButtonStyle}"
                                Width="110"
                                Grid.Column="2"
                                Click="TerminalStartStop_Click"/>
                    </Grid>
                    <Border Grid.Row="1"
                            Background="#FF101217"
                            BorderBrush="#FF2D2D30"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12"
                            Margin="0,0,0,12"
                            VerticalAlignment="Stretch"
                            HorizontalAlignment="Stretch">
                        <TextBox x:Name="TerminalOutputTextBox"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 TextWrapping="NoWrap"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{DynamicResource BrushTextPrimary}"
                                 FontFamily="Consolas">
                        </TextBox>
                    </Border>

                    <Grid Grid.Row="2" Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="130"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TerminalInputTextBox"
                                 Grid.Column="0"
                                 HorizontalAlignment="Stretch"
                                 VerticalAlignment="Center"
                                 Margin="0,0,12,0"
                                 Padding="12"
                                 FontSize="14"
                                 Background="{StaticResource BrushAppBackground}"
                                 BorderBrush="{StaticResource BrushBorder}"
                                 BorderThickness="1"
                                 Foreground="{StaticResource BrushTextPrimary}"
                                 KeyDown="TerminalInputTextBox_KeyDown"
                                 Text=""/>
                        <Button Grid.Column="1"
                                Content="Send"
                                Theme="{StaticResource PrimaryButtonStyle}"
                                Width="120"
                                Margin="0,0,12,0"
                                Click="SendTerminalCommand_Click"/>
                    </Grid>
                </Grid>
            </Border>

                    <!-- Health Section -->
                    <Border x:Name="HealthSection"
                            Background="{StaticResource BrushPanelBackground}"
                            BorderBrush="{StaticResource BrushBorder}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="20"
                            IsVisible="False"
                            Grid.Column="1"
                            Grid.Row="0">
                        <StackPanel>

                            <!-- Header -->
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Server Health"
                                               FontFamily="{StaticResource FontDisplay}"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource BrushTextPrimary}"/>
                                    <TextBlock x:Name="ServerOverallAdviceText"
                                               Text="No data"
                                               FontSize="11"
                                               Foreground="{DynamicResource BrushTextMuted}"
                                               TextWrapping="Wrap"
                                               MaxWidth="400"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                                <Button x:Name="RefreshServerHealthBtn"
                                        Grid.Column="1"
                                        Content="⟳ Refresh"
                                        Theme="{StaticResource SecondaryButtonStyle}"
                                        Padding="14,8"
                                        VerticalAlignment="Center"
                                        Click="RefreshServerHealth_Click"/>
                            </Grid>

                            <!-- Overall Score Card -->
                            <Border Background="{DynamicResource BrushPanelElevated}"
                                    BorderBrush="{DynamicResource BrushBorder}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="16"
                                    Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Score Number -->
                                    <Border Grid.Column="0"
                                            Width="64" Height="64"
                                            CornerRadius="32"
                                            Background="{DynamicResource BrushAccent}"
                                            VerticalAlignment="Center"
                                            Margin="0,0,16,0">
                                        <TextBlock x:Name="ServerOverallScoreText"
                                                   Text="0"
                                                   FontSize="24"
                                                   FontWeight="Bold"
                                                   Foreground="White"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <!-- Status Label -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Overall Score" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                                        <TextBlock x:Name="ServerOverallStatusText"
                                                   Text="Unknown"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource BrushTextPrimary}"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Metrics Grid: 2x2 -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- RAM Card -->
                                <Border Grid.Column="0" Grid.Row="0"
                                        Background="{DynamicResource BrushPanelElevated}"
                                        BorderBrush="{DynamicResource BrushBorder}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="14">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <Ellipse Width="8" Height="8" Fill="{DynamicResource BrushAccent}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="RAM Usage" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource BrushTextPrimary}"/>
                                        </StackPanel>
                                        <TextBlock x:Name="ServerRamText" Text="0% of 2048MB" FontSize="11" Foreground="{DynamicResource BrushTextMuted}" Margin="0,0,0,6"/>
                                        <ProgressBar x:Name="ServerRamProgress" Height="6" Value="0" Maximum="100" Margin="0,0,0,8"/>
                                        <!-- Sparkline -->
                                        <Border Background="{DynamicResource BrushPanelBackground}" CornerRadius="6" Padding="4" Height="40">
                                            <Canvas x:Name="ServerRamSparklineCanvas" Width="360" Height="32" HorizontalAlignment="Stretch" VerticalAlignment="Center">
                                                <Polyline x:Name="ServerRamSparkline" Stroke="{DynamicResource BrushAccent}" StrokeThickness="1.5" Fill="Transparent"/>
                                            </Canvas>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- Java Card -->
                                <Border Grid.Column="2" Grid.Row="0"
                                        Background="{DynamicResource BrushPanelElevated}"
                                        BorderBrush="{DynamicResource BrushBorder}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="14">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <Ellipse Width="8" Height="8" Fill="{DynamicResource BrushOnline}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Java" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource BrushTextPrimary}"/>
                                        </StackPanel>
                                        <TextBlock x:Name="ServerJavaText"
                                                   Text="Unknown"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource BrushTextMuted}"
                                                   TextWrapping="Wrap"
                                                   MaxWidth="220"/>
                                    </StackPanel>
                                </Border>

                                <!-- Mods Card -->
                                <Border Grid.Column="0" Grid.Row="2"
                                        Background="{DynamicResource BrushPanelElevated}"
                                        BorderBrush="{DynamicResource BrushBorder}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="14">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <Ellipse Width="8" Height="8" Fill="{DynamicResource BrushAccent}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Mods" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource BrushTextPrimary}"/>
                                        </StackPanel>
                                        <TextBlock x:Name="ServerModsText"
                                                   Text="Not scanned"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource BrushTextMuted}"
                                                   TextWrapping="Wrap"
                                                   MaxWidth="220"/>
                                    </StackPanel>
                                </Border>

                                <!-- Stability Card -->
                                <Border Grid.Column="2" Grid.Row="2"
                                        Background="{DynamicResource BrushPanelElevated}"
                                        BorderBrush="{DynamicResource BrushBorder}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="14">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <Ellipse Width="8" Height="8" Fill="{DynamicResource BrushOnline}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Stability" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource BrushTextPrimary}"/>
                                        </StackPanel>
                                        <TextBlock x:Name="ServerStabilityText"
                                                   Text="No recent crashes"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource BrushTextMuted}"
                                                   TextWrapping="Wrap"
                                                   MaxWidth="220"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                        </StackPanel>
                    </Border>

            <Border x:Name="FriendsSection"
                    Background="{StaticResource BrushPanelBackground}"
                    BorderBrush="{StaticResource BrushBorder}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="24"
                    IsVisible="False">
                <StackPanel>
                    <TextBlock Text="Friends &amp; Whitelist"
                               FontFamily="{StaticResource FontDisplay}"
                               FontSize="20"
                               Foreground="{StaticResource BrushTextPrimary}"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="Manage who can join your server. Selected friends with linked Minecraft accounts will be added to the whitelist."
                               FontFamily="{StaticResource FontBody}"
                               FontSize="13"
                               Foreground="{StaticResource BrushTextSecondary}"
                               Margin="0,0,0,20"
                               TextWrapping="Wrap"/>

                    <!-- Whitelist toggle -->
                    <Border Background="{StaticResource BrushPanelElevated}"
                            BorderBrush="{StaticResource BrushBorder}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="16"
                            Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Enable Whitelist"
                                           FontFamily="{StaticResource FontBody}"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource BrushTextPrimary}"/>
                                <TextBlock Text="Only whitelisted players can join this server."
                                           FontFamily="{StaticResource FontBody}"
                                           FontSize="12"
                                           Foreground="{StaticResource BrushTextSecondary}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1"
                                      x:Name="WhitelistToggleCheckBox"
                                      IsChecked="{Binding WhiteListEnabled}"
                                      VerticalAlignment="Center"
                                      Checked="WhitelistToggle_Changed"
                                      Unchecked="WhitelistToggle_Changed"/>
                        </Grid>
                    </Border>

                    <!-- Friends list header -->
                    <Border Background="{StaticResource BrushPanelElevated}"
                            BorderBrush="{StaticResource BrushBorder}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Header row -->
                            <Border Grid.Row="0"
                                    BorderBrush="{StaticResource BrushBorder}"
                                    BorderThickness="0,0,0,1"
                                    Padding="16,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="Trusted Friends"
                                               FontFamily="{StaticResource FontDisplay}"
                                               FontSize="14"
                                               Foreground="{StaticResource BrushTextPrimary}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1"
                                               x:Name="FriendsSelectedCountText"
                                               FontFamily="{StaticResource FontBody}"
                                               FontSize="11"
                                               Foreground="{StaticResource BrushTextMuted}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <!-- Loading -->
                            <TextBlock Grid.Row="1"
                                       x:Name="FriendsLoadingText"
                                       Text="Loading friends…"
                                       FontFamily="{StaticResource FontBody}"
                                       FontSize="13"
                                       Foreground="{StaticResource BrushTextMuted}"
                                       HorizontalAlignment="Center"
                                       Margin="0,20"/>

                            <!-- Empty -->
                            <TextBlock Grid.Row="1"
                                       x:Name="FriendsEmptyText"
                                       Text="Not logged in to Nexora, or no friends found.&#x0a;Add friends from the Social page first."
                                       FontFamily="{StaticResource FontBody}"
                                       FontSize="12"
                                       Foreground="{StaticResource BrushTextMuted}"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       Margin="20"
                                       IsVisible="False"/>

                            <!-- Friends list -->
                            <ItemsControl Grid.Row="2"
                                          x:Name="ServerFriendsList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{StaticResource BrushBorder}"
                                                BorderThickness="0,0,0,1"
                                                Padding="16,12"
                                                Cursor="Hand">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Avatar -->
                                                <Border Grid.Column="0"
                                                        Width="38" Height="38" CornerRadius="19"
                                                        Background="{StaticResource BrushAccent}"
                                                        Margin="0,0,14,0">
                                                    <TextBlock Text="{Binding Initial}"
                                                               FontFamily="{StaticResource FontDisplay}"
                                                               FontSize="16" Foreground="White"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>

                                                <!-- Name + MC username -->
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding WebsiteUsername}"
                                                               FontFamily="{StaticResource FontBody}"
                                                               FontSize="13" FontWeight="SemiBold"
                                                               Foreground="{StaticResource BrushTextPrimary}"/>
                                                    <TextBlock FontFamily="{StaticResource FontBody}"
                                                               FontSize="11"
                                                               Foreground="{StaticResource BrushTextSecondary}"
                                                               Margin="0,2,0,0"
                                                               IsVisible="{Binding MinecraftUsername, Converter={StaticResource NullToVisibilityConverter}}">
                                                        <Run Text="MC: "/><Run Text="{Binding MinecraftUsername, Mode=OneWay}"/>
                                                    </TextBlock>
                                                </StackPanel>

                                                <!-- Whitelist checkbox -->
                                                <CheckBox Grid.Column="2"
                                                          IsChecked="{Binding IsSelected}"
                                                          VerticalAlignment="Center"
                                                          Checked="FriendWhitelist_Changed"
                                                          Unchecked="FriendWhitelist_Changed"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>

                    <!-- Save whitelist button -->
                    <Button x:Name="SaveWhitelistBtn"
                            Content="Save Whitelist"
                            Theme="{StaticResource PrimaryButtonStyle}"
                            Padding="20,10"
                            Margin="0,16,0,0"
                            HorizontalAlignment="Left"
                            Click="SaveWhitelist_Click"/>

                    <!-- Status text -->
                    <TextBlock x:Name="WhitelistStatusText"
                               FontFamily="{StaticResource FontBody}"
                               FontSize="12"
                               Foreground="{StaticResource BrushTextSecondary}"
                               TextWrapping="Wrap"
                               Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <Border x:Name="SettingsSection"
                    Background="{StaticResource BrushPanelBackground}"
                    BorderBrush="{StaticResource BrushBorder}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="0"
                    IsVisible="False">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
                <StackPanel>
                    <TextBlock Text="Settings"
                               FontFamily="{StaticResource FontDisplay}"
                               FontSize="20"
                               Foreground="{StaticResource BrushTextPrimary}"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="Configure this server's identity, gameplay rules, and network settings."
                               FontFamily="{StaticResource FontBody}"
                               FontSize="13"
                               Foreground="{StaticResource BrushTextSecondary}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,20"/>

                    <!-- Server Identity Card -->
                    <Border Background="{StaticResource BrushPanelElevated}"
                            BorderBrush="{StaticResource BrushBorder}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="20"
                            Margin="0,0,0,20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Server Name -->
                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock Text="Server name"
                                           FontFamily="{StaticResource FontBody}" FontSize="12"
                                           Foreground="{StaticResource BrushTextSecondary}" Margin="0,0,0,4"/>
                                <TextBox x:Name="ServerNameBox"
                                         Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="10" FontSize="13"
                                         Background="{StaticResource BrushAppBackground}"
                                         BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                                         Foreground="{StaticResource BrushTextPrimary}"/>
                            </StackPanel>

                            <!-- Server Type -->
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Server type"
                                           FontFamily="{StaticResource FontBody}" FontSize="12"
                                           Foreground="{StaticResource BrushTextSecondary}" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding Type, Mode=OneWay}"
                                         IsReadOnly="True"
                                         Padding="10" FontSize="13"
                                         Background="{StaticResource BrushAppBackground}"
                                         BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                                         Foreground="{StaticResource BrushTextMuted}"/>
                            </StackPanel>

                            <!-- Minecraft Version -->
                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,12,12,0">
                                <TextBlock Text="Minecraft version"
                                           FontFamily="{StaticResource FontBody}" FontSize="12"
                                           Foreground="{StaticResource BrushTextSecondary}" Margin="0,0,0,4"/>
                                <TextBox x:Name="ServerVersionBox"
                                         Text="{Binding MinecraftVersion, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                         Padding="10" FontSize="13"
                                         Background="{StaticResource BrushAppBackground}"
                                         BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                                         Foreground="{StaticResource BrushTextPrimary}"/>
                            </StackPanel>

                            <!-- MOTD -->
                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,12,0,0">
                                <TextBlock Text="MOTD"
                                           FontFamily="{StaticResource FontBody}" FontSize="12"
                                           Foreground="{StaticResource BrushTextSecondary}" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding Motd, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="10" FontSize="13"
                                         Background="{StaticResource BrushAppBackground}"
                                         BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                                         Foreground="{StaticResource BrushTextPrimary}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Margin="0,20,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,16,0">
                            <TextBlock Text="Server port"
                                       FontFamily="{StaticResource FontBody}"
                                       FontSize="12"
                                       Foreground="{StaticResource BrushTextSecondary}"
                                       Margin="0,0,0,4"/>
                            <TextBox Text="{Binding Port, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="10"
                                     Background="{StaticResource BrushAppBackground}"
                                     BorderBrush="{StaticResource BrushBorder}"
                                     BorderThickness="1"
                                     Foreground="{StaticResource BrushTextPrimary}"
                                     FontSize="13"/>

                            <TextBlock Text="Max players"
                                       FontFamily="{StaticResource FontBody}"
                                       FontSize="12"
                                       Foreground="{StaticResource BrushTextSecondary}"
                                       Margin="0,16,0,4"/>
                            <TextBox Text="{Binding MaxPlayers, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="10"
                                     Background="{StaticResource BrushAppBackground}"
                                     BorderBrush="{StaticResource BrushBorder}"
                                     BorderThickness="1"
                                     Foreground="{StaticResource BrushTextPrimary}"
                                     FontSize="13"/>

                            <TextBlock Text="Min JVM memory (MB)"
                                       FontFamily="{StaticResource FontBody}"
                                       FontSize="12"
                                       Foreground="{StaticResource BrushTextSecondary}"
                                       Margin="0,16,0,4"/>
                            <TextBox Text="{Binding MinMemoryMB, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="10"
                                     Background="{StaticResource BrushAppBackground}"
                                     BorderBrush="{StaticResource BrushBorder}"
                                     BorderThickness="1"
                                     Foreground="{StaticResource BrushTextPrimary}"
                                     FontSize="13"/>

                            <TextBlock Text="Max JVM memory (MB)"
                                       FontFamily="{StaticResource FontBody}"
                                       FontSize="12"
                                       Foreground="{StaticResource BrushTextSecondary}"
                                       Margin="0,16,0,4"/>
                            <TextBox Text="{Binding MaxMemoryMB, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="10"
                                     Background="{StaticResource BrushAppBackground}"
                                     BorderBrush="{StaticResource BrushBorder}"
                                     BorderThickness="1"
                                     Foreground="{StaticResource BrushTextPrimary}"
                                     FontSize="13"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Game mode"
                                       FontFamily="{StaticResource FontBody}"
                                       FontSize="12"
                                       Foreground="{StaticResource BrushTextSecondary}"
                                       Margin="0,0,0,4"/>
                            <ComboBox SelectedItem="{Binding Gamemode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      Padding="10"
                                      Background="{StaticResource BrushAppBackground}"
                                      BorderBrush="{StaticResource BrushBorder}"
                                      BorderThickness="1"
                                      Foreground="{StaticResource BrushTextPrimary}"
                                      FontSize="13">
                                <sys:String>survival</sys:String>
                                <sys:String>creative</sys:String>
                                <sys:String>adventure</sys:String>
                                <sys:String>spectator</sys:String>
                            </ComboBox>

                            <TextBlock Text="Difficulty"
                                       FontFamily="{StaticResource FontBody}"
                                       FontSize="12"
                                       Foreground="{StaticResource BrushTextSecondary}"
                                       Margin="0,16,0,4"/>
                            <ComboBox SelectedItem="{Binding Difficulty, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      Padding="10"
                                      Background="{StaticResource BrushAppBackground}"
                                      BorderBrush="{StaticResource BrushBorder}"
                                      BorderThickness="1"
                                      Foreground="{StaticResource BrushTextPrimary}"
                                      FontSize="13">
                                <sys:String>peaceful</sys:String>
                                <sys:String>easy</sys:String>
                                <sys:String>normal</sys:String>
                                <sys:String>hard</sys:String>
                            </ComboBox>

                            <CheckBox Content="Online mode"
                                      Theme="{StaticResource CardCheckBoxStyle}"
                                      IsChecked="{Binding AllowOnlineMode, Mode=TwoWay}"
                                      Margin="0,16,0,0"/>
                            <CheckBox Content="Allow cheats"
                                      Theme="{StaticResource CardCheckBoxStyle}"
                                      IsChecked="{Binding AllowCheats, Mode=TwoWay}"
                                      Margin="0,10,0,0"/>
                            <CheckBox Content="Enable whitelist"
                                      Theme="{StaticResource CardCheckBoxStyle}"
                                      IsChecked="{Binding WhiteListEnabled, Mode=TwoWay}"
                                      Margin="0,10,0,0"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,20,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,16,0">
                            <TextBlock Text="View distance"
                                       FontFamily="{StaticResource FontBody}"
                                       FontSize="12"
                                       Foreground="{StaticResource BrushTextSecondary}"
                                       Margin="0,0,0,4"/>
                            <Slider Value="{Binding ViewDistance, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Minimum="2"
                                    Maximum="32"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="True"
                                    TickPlacement="BottomRight"
                                    SmallChange="1"
                                    LargeChange="5"/>
                            <TextBlock Text="Chunks loaded around each player (2-32)."
                                       FontFamily="{StaticResource FontBody}"
                                       FontSize="11"
                                       Foreground="{StaticResource BrushTextMuted}"
                                       Margin="0,4,0,0"/>

                            <TextBlock Text="Simulation distance"
                                       FontFamily="{StaticResource FontBody}"
                                       FontSize="12"
                                       Foreground="{StaticResource BrushTextSecondary}"
                                       Margin="0,16,0,4"/>
                            <Slider Value="{Binding SimulationDistance, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Minimum="2"
                                    Maximum="16"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="True"
                                    TickPlacement="BottomRight"
                                    SmallChange="1"
                                    LargeChange="3"/>
                            <TextBlock Text="Distance for entity/tick updates (2-16)."
                                       FontFamily="{StaticResource FontBody}"
                                       FontSize="11"
                                       Foreground="{StaticResource BrushTextMuted}"
                                       Margin="0,4,0,0"/>

                            <TextBlock Text="Spawn protection radius"
                                       FontFamily="{StaticResource FontBody}"
                                       FontSize="12"
                                       Foreground="{StaticResource BrushTextSecondary}"
                                       Margin="0,16,0,4"/>
                            <TextBox Text="{Binding SpawnProtection, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="10"
                                     Background="{StaticResource BrushAppBackground}"
                                     BorderBrush="{StaticResource BrushBorder}"
                                     BorderThickness="1"
                                     Foreground="{StaticResource BrushTextPrimary}"
                                     FontSize="13"/>
                            <TextBlock Text="Blocks around spawn protected from non-ops (0-100, 0 = disabled)."
                                       FontFamily="{StaticResource FontBody}"
                                       FontSize="11"
                                       Foreground="{StaticResource BrushTextMuted}"
                                       Margin="0,4,0,0"/>

                            <TextBlock Text="Network compression threshold"
                                       FontFamily="{StaticResource FontBody}"
                                       FontSize="12"
                                       Foreground="{StaticResource BrushTextSecondary}"
                                       Margin="0,16,0,4"/>
                            <TextBox Text="{Binding NetworkCompressionThreshold, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="10"
                                     Background="{StaticResource BrushAppBackground}"
                                     BorderBrush="{StaticResource BrushBorder}"
                                     BorderThickness="1"
                                     Foreground="{StaticResource BrushTextPrimary}"
                                     FontSize="13"/>
                            <TextBlock Text="Packet size threshold for compression (-1 to 256, -1 = disabled)."
                                       FontFamily="{StaticResource FontBody}"
                                       FontSize="11"
                                       Foreground="{StaticResource BrushTextMuted}"
                                       Margin="0,4,0,0"/>

                            <TextBlock Text="Player idle timeout (minutes)"
                                       FontFamily="{StaticResource FontBody}"
                                       FontSize="12"
                                       Foreground="{StaticResource BrushTextSecondary}"
                                       Margin="0,16,0,4"/>
                            <TextBox Text="{Binding PlayerIdleTimeout, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="10"
                                     Background="{StaticResource BrushAppBackground}"
                                     BorderBrush="{StaticResource BrushBorder}"
                                     BorderThickness="1"
                                     Foreground="{StaticResource BrushTextPrimary}"
                                     FontSize="13"/>
                            <TextBlock Text="Auto-kick idle players after this many minutes (0 = disabled)."
                                       FontFamily="{StaticResource FontBody}"
                                       FontSize="11"
                                       Foreground="{StaticResource BrushTextMuted}"
                                       Margin="0,4,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Op permission level"
                                       FontFamily="{StaticResource FontBody}"
                                       FontSize="12"
                                       Foreground="{StaticResource BrushTextSecondary}"
                                       Margin="0,0,0,4"/>
                            <ComboBox SelectedItem="{Binding OpPermissionLevel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      Padding="10"
                                      Background="{StaticResource BrushAppBackground}"
                                      BorderBrush="{StaticResource BrushBorder}"
                                      BorderThickness="1"
                                      Foreground="{StaticResource BrushTextPrimary}"
                                      FontSize="13">
                                <sys:Int32>1</sys:Int32>
                                <sys:Int32>2</sys:Int32>
                                <sys:Int32>3</sys:Int32>
                                <sys:Int32>4</sys:Int32>
                            </ComboBox>
                            <TextBlock Text="Permission level for opped players (1-4)."
                                       FontFamily="{StaticResource FontBody}"
                                       FontSize="11"
                                       Foreground="{StaticResource BrushTextMuted}"
                                       Margin="0,4,0,0"/>

                            <CheckBox Content="PvP enabled"
                                      Theme="{StaticResource CardCheckBoxStyle}"
                                      IsChecked="{Binding PvpEnabled, Mode=TwoWay}"
                                      Margin="0,16,0,0"/>
                            <CheckBox Content="Allow Nether"
                                      Theme="{StaticResource CardCheckBoxStyle}"
                                      IsChecked="{Binding AllowNether, Mode=TwoWay}"
                                      Margin="0,10,0,0"/>
                            <CheckBox Content="Allow flight"
                                      Theme="{StaticResource CardCheckBoxStyle}"
                                      IsChecked="{Binding AllowFlight, Mode=TwoWay}"
                                      Margin="0,10,0,0"/>
                            <CheckBox Content="Hardcore mode"
                                      Theme="{StaticResource CardCheckBoxStyle}"
                                      IsChecked="{Binding HardcoreMode, Mode=TwoWay}"
                                      Margin="0,10,0,0"/>
                            <CheckBox Content="Force gamemode"
                                      Theme="{StaticResource CardCheckBoxStyle}"
                                      IsChecked="{Binding ForceGamemode, Mode=TwoWay}"
                                      Margin="0,10,0,0"/>
                            <CheckBox Content="Enable command blocks"
                                      Theme="{StaticResource CardCheckBoxStyle}"
                                      IsChecked="{Binding EnableCommandBlocks, Mode=TwoWay}"
                                      Margin="0,10,0,0"/>
                            <CheckBox Content="Spawn animals"
                                      Theme="{StaticResource CardCheckBoxStyle}"
                                      IsChecked="{Binding SpawnAnimals, Mode=TwoWay}"
                                      Margin="0,10,0,0"/>
                            <CheckBox Content="Spawn monsters"
                                      Theme="{StaticResource CardCheckBoxStyle}"
                                      IsChecked="{Binding SpawnMonsters, Mode=TwoWay}"
                                      Margin="0,10,0,0"/>
                            <CheckBox Content="Spawn NPCs"
                                      Theme="{StaticResource CardCheckBoxStyle}"
                                      IsChecked="{Binding SpawnNpcs, Mode=TwoWay}"
                                      Margin="0,10,0,0"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Margin="0,20,0,0">
                        <TextBlock Text="Operator players"
                                   FontFamily="{StaticResource FontBody}"
                                   FontSize="12"
                                   Foreground="{StaticResource BrushTextSecondary}"
                                   Margin="0,0,0,4"/>
                        <TextBox Text="{Binding OpPlayers, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="10"
                                 Background="{StaticResource BrushAppBackground}"
                                 BorderBrush="{StaticResource BrushBorder}"
                                 BorderThickness="1"
                                 Foreground="{StaticResource BrushTextPrimary}"
                                 FontSize="13"
                                 AcceptsReturn="True"
                                 Height="72"
                                 TextWrapping="Wrap"/>
                        <TextBlock Text="Comma-separated list of players who should be ops."
                                   FontFamily="{StaticResource FontBody}"
                                   FontSize="12"
                                   Foreground="{StaticResource BrushTextSecondary}"
                                   Margin="0,8,0,0"/>
                    </StackPanel>

                    <StackPanel Margin="0,20,0,0">
                        <TextBlock Text="Whitelisted players"
                                   FontFamily="{StaticResource FontBody}"
                                   FontSize="12"
                                   Foreground="{StaticResource BrushTextSecondary}"
                                   Margin="0,0,0,4"/>
                        <TextBox Text="{Binding WhitelistedPlayers, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="10"
                                 Background="{StaticResource BrushAppBackground}"
                                 BorderBrush="{StaticResource BrushBorder}"
                                 BorderThickness="1"
                                 Foreground="{StaticResource BrushTextPrimary}"
                                 FontSize="13"
                                 AcceptsReturn="True"
                                 Height="72"
                                 TextWrapping="Wrap"/>
                        <TextBlock Text="Comma-separated list of friends who can join while whitelist is enabled."
                                   FontFamily="{StaticResource FontBody}"
                                   FontSize="12"
                                   Foreground="{StaticResource BrushTextSecondary}"
                                   Margin="0,8,0,0"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,24,0,0">
                        <Button Content="Save settings"
                                Theme="{StaticResource PrimaryButtonStyle}"
                                Padding="16,8"
                                Margin="0,0,12,0"
                                Click="SaveServerSettings_Click"/>
                        <Button Content="Open server folder"
                                Theme="{StaticResource SecondaryButtonStyle}"
                                Padding="16,8"
                                Click="OpenServerFolder_Click"/>
                    </StackPanel>
                </StackPanel>
                </ScrollViewer>
            </Border>

            <Border x:Name="PluginsSection"
                    Background="{StaticResource BrushPanelBackground}"
                    BorderBrush="{StaticResource BrushBorder}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="24"
                    IsVisible="False">
                <StackPanel>
                    <TextBlock Text="Plugins / Mods"
                               FontFamily="{StaticResource FontDisplay}"
                               FontSize="20"
                               Foreground="{StaticResource BrushTextPrimary}"
                               Margin="0,0,0,12"/>
                    <TextBlock Text="Drop plugin or mod .jar files here or install them from local files. This will copy them into the server and validate compatibility for modded server types."
                               FontFamily="{StaticResource FontBody}"
                               FontSize="13"
                               Foreground="{StaticResource BrushTextSecondary}"
                               TextWrapping="Wrap"/>

                    <StackPanel Orientation="Horizontal" Margin="0,20,0,16">
                        <Button Content="Install local files..."
                                ToolTip.Tip="Select plugin or mod jars from your computer and install them into this server."
                                Theme="{StaticResource PrimaryButtonStyle}"
                                Padding="14,8"
                                Margin="0,0,10,0"
                                Click="BrowsePlugins_Click"/>
                        <Button Content="Browse Plugins &amp; Mods..."
                                ToolTip.Tip="Search and install plugins, mods, and datapacks from Modrinth directly into this server."
                                Theme="{StaticResource PrimaryButtonStyle}"
                                Padding="14,8"
                                Margin="0,0,10,0"
                                Click="BrowseServerPlugins_Click"/>
                        <Button Content="Check compatibility"
                                Theme="{StaticResource SecondaryButtonStyle}"
                                Padding="14,8"
                                Margin="0,0,10,0"
                                Click="CheckPluginCompatibility_Click"/>
                        <Button Content="Open folder"
                                Theme="{StaticResource SecondaryButtonStyle}"
                                Padding="14,8"
                                Click="OpenPluginFolder_Click"/>
                    </StackPanel>

                    <TextBlock x:Name="PluginFolderInfoTextBlock"
                               FontFamily="{StaticResource FontBody}"
                               FontSize="12"
                               Foreground="{StaticResource BrushTextMuted}"
                               Margin="0,0,0,12"/>

                    <TextBlock x:Name="PluginStatusTextBlock"
                               FontFamily="{StaticResource FontBody}"
                               FontSize="12"
                               Foreground="{StaticResource BrushTextSecondary}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,12"/>

                    <ItemsControl x:Name="PluginIssuesItemsControl"
                                  Margin="0,0,0,12"
                                  IsVisible="False">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource BrushPanelElevated}"
                                        BorderBrush="{StaticResource BrushBorder}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="10,8"
                                        Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding TypeLabel}"
                                                       FontFamily="{StaticResource FontBody}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource BrushTextPrimary}"/>
                                            <TextBlock Text="{Binding Description}"
                                                       FontFamily="{StaticResource FontBody}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource BrushTextSecondary}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,6,0,0"/>
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Content="Fix"
                                                Theme="{StaticResource PrimaryButtonStyle}"
                                                Padding="10,5"
                                                Margin="10,0,0,0"
                                                Click="FixPluginDependencyIssue_Click"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Button x:Name="PluginFixAllButton"
                            Content="Fix all"
                            Theme="{StaticResource SecondaryButtonStyle}"
                            Padding="12,6"
                            Width="120"
                            HorizontalAlignment="Left"
                            Margin="0,0,0,12"
                            IsVisible="False"
                            Click="FixAllPluginDependencyIssues_Click"/>

                    <Border x:Name="PluginDropZone"
                            DragDrop.AllowDrop="True"
                            DragDrop.DragOver="PluginDropZone_DragOver"
                            DragDrop.Drop="PluginDropZone_Drop"
                            BorderBrush="{StaticResource BrushBorder}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12"
                            Background="{StaticResource BrushPanelBackground}"
                            MinHeight="140">
                        <StackPanel>
                            <Border Background="{StaticResource BrushPanelBackground}"
                                    BorderBrush="{StaticResource BrushBorder}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="0,8"
                                    Margin="0,0,0,8"
                                    x:Name="PluginEmptyHintBorder">
                                <TextBlock FontFamily="{StaticResource FontBody}"
                                           FontSize="12"
                                           Foreground="{StaticResource BrushTextMuted}"
                                           HorizontalAlignment="Center"
                                           Text="⬇ Drop plugin or mod .jar files here to install them"/>
                            </Border>
                            <TextBlock x:Name="PluginHintTextBlock"
                                       FontFamily="{StaticResource FontBody}"
                                       FontSize="11"
                                       Foreground="{StaticResource BrushTextMuted}"
                                       HorizontalAlignment="Right"
                                       Margin="0,0,4,6"
                                       Text="⬇ Drop another .jar to add more plugins or mods"
                                       IsVisible="False"/>
                            <ItemsControl x:Name="PluginFilesItemsControl">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource BrushPanelElevated}"
                                                BorderBrush="{StaticResource BrushBorder}"
                                                BorderThickness="1"
                                                CornerRadius="6"
                                                Padding="10,8"
                                                Margin="0,0,0,4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding FileName}"
                                                           FontFamily="{StaticResource FontBody}"
                                                           FontSize="13"
                                                           Foreground="{StaticResource BrushTextPrimary}"
                                                           VerticalAlignment="Center"/>
                                                <Button Grid.Column="1"
                                                        Content="Remove"
                                                        Theme="{StaticResource DangerButtonStyle}"
                                                        Padding="10,4"
                                                        Margin="8,0,0,0"
                                                        Click="RemovePluginFile_Click"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border x:Name="AdvancedSection"
                    Background="{StaticResource BrushPanelBackground}"
                    BorderBrush="{StaticResource BrushBorder}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="24"
                    IsVisible="False">
                <StackPanel>
                    <TextBlock Text="Advanced"
                               FontFamily="{StaticResource FontDisplay}"
                               FontSize="20"
                               Foreground="{StaticResource BrushTextPrimary}"
                               Margin="0,0,0,12"/>
                    <WrapPanel Margin="0,0,0,16">
                        <Button Content="Open Server Folder"
                                Theme="{StaticResource PrimaryButtonStyle}"
                                Margin="0,0,8,8"
                                Click="OpenServerFolder_Click"/>
                        <Button Content="Terminal"
                                Theme="{StaticResource SecondaryButtonStyle}"
                                Margin="0,0,0,8"
                                Click="AdvancedTerminal_Click"/>
                        <Button Content="Logs"
                                Theme="{StaticResource SecondaryButtonStyle}"
                                Margin="0,0,0,8"
                                Click="AdvancedLogs_Click"/>
                    </WrapPanel>
                    <TextBlock Text="Advanced server settings let you pin a specific Java runtime, choose the preferred jar to launch, and refresh the server start scripts without recreating the whole directory."
                               FontFamily="{StaticResource FontBody}"
                               FontSize="13"
                               Foreground="{StaticResource BrushTextSecondary}"
                               TextWrapping="Wrap"/>
                    <StackPanel Margin="0,20,0,0">
                        <TextBlock Text="Custom Java executable"
                                   FontFamily="{StaticResource FontBody}"
                                   FontSize="12"
                                   Foreground="{StaticResource BrushTextPrimary}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBox Text="{Binding JavaPath, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="10"
                                     MinWidth="260"
                                     HorizontalAlignment="Stretch"
                                     Background="{StaticResource BrushPanelElevated}"
                                     BorderBrush="{StaticResource BrushBorder}"
                                     BorderThickness="1"
                                     Foreground="{StaticResource BrushTextPrimary}"
                                     FontSize="13"/>
                            <Button Content="Browse"
                                    Theme="{StaticResource SecondaryButtonStyle}"
                                    Margin="10,0,0,0"
                                    Padding="16,8"
                                    Click="BrowseJavaPath_Click"/>
                        </StackPanel>

                        <TextBlock Text="Preferred server jar"
                                   FontFamily="{StaticResource FontBody}"
                                   FontSize="12"
                                   Foreground="{StaticResource BrushTextPrimary}"
                                   Margin="0,12,0,0"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBox Text="{Binding JarFileName, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="10"
                                     MinWidth="260"
                                     HorizontalAlignment="Stretch"
                                     Background="{StaticResource BrushPanelElevated}"
                                     BorderBrush="{StaticResource BrushBorder}"
                                     BorderThickness="1"
                                     Foreground="{StaticResource BrushTextPrimary}"
                                     FontSize="13"/>
                            <Button Content="Detect"
                                    Theme="{StaticResource SecondaryButtonStyle}"
                                    Margin="10,0,0,0"
                                    Padding="16,8"
                                    Click="DetectJarFile_Click"/>
                        </StackPanel>

                        <TextBlock Text="Custom JVM arguments"
                                   FontFamily="{StaticResource FontBody}"
                                   FontSize="12"
                                   Foreground="{StaticResource BrushTextPrimary}"
                                   Margin="0,16,0,0"/>
                        <TextBox Text="{Binding CustomJvmArgs, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="10"
                                 MinWidth="260"
                                 HorizontalAlignment="Stretch"
                                 Background="{StaticResource BrushPanelElevated}"
                                 BorderBrush="{StaticResource BrushBorder}"
                                 BorderThickness="1"
                                 Foreground="{StaticResource BrushTextPrimary}"
                                 FontSize="13"
                                 AcceptsReturn="True"
                                 Height="80"
                                 TextWrapping="Wrap"/>
                        <TextBlock Text="Optional extra Java flags such as -XX:+UseG1GC or -XX:MaxGCPauseMillis=50."
                                   FontFamily="{StaticResource FontBody}"
                                   FontSize="12"
                                   Foreground="{StaticResource BrushTextSecondary}"
                                   Margin="0,8,0,0"
                                   TextWrapping="Wrap"/>

                        <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                            <Button Content="Save advanced settings"
                                    Theme="{StaticResource PrimaryButtonStyle}"
                                    Padding="16,8"
                                    Margin="0,0,12,0"
                                    Click="SaveAdvancedSettings_Click"/>                            <Button Content="Regenerate start scripts"
                                    Theme="{StaticResource SecondaryButtonStyle}"
                                    Padding="16,8"
                                    Click="RegenerateStartScripts_Click"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border x:Name="LogsSection"
                    Background="{StaticResource BrushPanelBackground}"
                    BorderBrush="{StaticResource BrushBorder}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="24"
                    IsVisible="False">
                <StackPanel>
                    <TextBlock Text="Logs"
                               FontFamily="{StaticResource FontDisplay}"
                               FontSize="20"
                               Foreground="{StaticResource BrushTextPrimary}"
                               Margin="0,0,0,12"/>
                    <TextBox x:Name="LogsTextBox"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             Height="360"
                             Padding="12"
                             Background="{StaticResource BrushAppBackground}"
                             BorderBrush="{StaticResource BrushBorder}"
                             BorderThickness="1"
                             Foreground="{StaticResource BrushTextPrimary}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
