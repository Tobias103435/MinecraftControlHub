<Window x:Class="MinecraftControlHub.UI.Windows.ShareInstanceWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Share Instance"
        Width="480" Height="640"
        MinWidth="420" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BrushAppBackground}"
        ShowInTaskbar="False">

    <Grid Margin="28,24,28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Share Instance"
                       FontFamily="{DynamicResource FontDisplay}" FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource BrushTextPrimary}"
                       Margin="0,0,0,4"/>
            <TextBlock x:Name="SubtitleText"
                       FontFamily="{DynamicResource FontBody}" FontSize="12"
                       Foreground="{DynamicResource BrushTextSecondary}"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <!-- ── Instance info card ── -->
        <Border Grid.Row="1"
                Background="{DynamicResource BrushPanelBackground}"
                BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"
                CornerRadius="8" Padding="16,12" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="Instance"
                           FontFamily="{DynamicResource FontBody}" FontSize="11"
                           Foreground="{DynamicResource BrushTextMuted}"
                           Margin="0,0,12,0" VerticalAlignment="Center"/>
                <TextBlock Grid.Row="0" Grid.Column="1"
                           x:Name="InstanceNameText"
                           FontFamily="{DynamicResource FontBody}" FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource BrushTextPrimary}"/>
                <TextBlock Grid.Row="1" Grid.Column="0"
                           Text="Version"
                           FontFamily="{DynamicResource FontBody}" FontSize="11"
                           Foreground="{DynamicResource BrushTextMuted}"
                           Margin="0,4,12,0" VerticalAlignment="Center"/>
                <TextBlock Grid.Row="1" Grid.Column="1"
                           x:Name="InstanceVersionText"
                           FontFamily="{DynamicResource FontBody}" FontSize="12"
                           Foreground="{DynamicResource BrushTextSecondary}"
                           Margin="0,4,0,0"/>
            </Grid>
        </Border>

        <!-- ── Status / error message ── -->
        <Border Grid.Row="2"
                Background="{DynamicResource BrushPanelElevated}"
                CornerRadius="6" Padding="12,8" Margin="0,0,0,10"
                IsVisible="{Binding HasStatusMessage, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock x:Name="StatusMessageText"
                       FontFamily="{DynamicResource FontBody}" FontSize="12"
                       Foreground="{DynamicResource BrushTextSecondary}"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- ── Tab bar ── -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,12">
            <Button x:Name="TabFriendsBtn"
                    Content="Share with Friends"
                    Padding="14,7" Margin="0,0,8,0"
                    Theme="{StaticResource SecondaryButtonStyle}"
                    Click="TabFriends_Click"/>
            <Button x:Name="TabCodeBtn"
                    Content="Share Code"
                    Padding="14,7"
                    Theme="{StaticResource SecondaryButtonStyle}"
                    Click="TabCode_Click"/>
        </StackPanel>

        <!-- ── Friends tab ── -->
        <Border Grid.Row="4"
                x:Name="FriendsTabPanel"
                Background="{DynamicResource BrushPanelBackground}"
                BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"
                CornerRadius="8" Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- List header -->
                <Border Grid.Row="0"
                        BorderBrush="{DynamicResource BrushBorder}" BorderThickness="0,0,0,1"
                        Padding="14,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="Friends"
                                   FontFamily="{DynamicResource FontDisplay}" FontSize="13"
                                   Foreground="{DynamicResource BrushTextPrimary}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1"
                                   x:Name="SelectedCountText"
                                   FontFamily="{DynamicResource FontBody}" FontSize="11"
                                   Foreground="{DynamicResource BrushTextMuted}"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Loading -->
                <TextBlock Grid.Row="1"
                           x:Name="LoadingText"
                           Text="Loading friends…"
                           FontFamily="{DynamicResource FontBody}" FontSize="13"
                           Foreground="{DynamicResource BrushTextMuted}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Margin="0,20"/>

                <!-- Empty -->
                <TextBlock Grid.Row="1"
                           x:Name="EmptyText"
                           Text="No friends found. Add friends from the Social page first."
                           FontFamily="{DynamicResource FontBody}" FontSize="12"
                           Foreground="{DynamicResource BrushTextMuted}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           TextAlignment="Center" TextWrapping="Wrap"
                           Margin="20" IsVisible="False"/>

                <!-- Friends list -->
                <ScrollViewer Grid.Row="1"
                              x:Name="FriendsScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              IsVisible="False">
                    <ItemsControl x:Name="FriendsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource BrushBorder}"
                                        BorderThickness="0,0,0,1"
                                        Padding="14,10"
                                        Cursor="Hand">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Avatar -->
                                        <Border Grid.Column="0"
                                                Width="36" Height="36" CornerRadius="18"
                                                Background="{DynamicResource BrushAccent}"
                                                Margin="0,0,12,0">
                                            <TextBlock Text="{Binding Initial}"
                                                       FontFamily="{DynamicResource FontDisplay}"
                                                       FontSize="15" Foreground="White"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- Name -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding WebsiteUsername}"
                                                       FontFamily="{DynamicResource FontBody}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource BrushTextPrimary}"/>
                                            <TextBlock Text="{Binding MinecraftUsername}"
                                                       FontFamily="{DynamicResource FontBody}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource BrushTextMuted}"/>
                                        </StackPanel>

                                        <!-- Checkbox -->
                                        <CheckBox Grid.Column="2"
                                                  x:Name="FriendCheckBox"
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                  VerticalAlignment="Center"
                                                  Checked="FriendCheckBox_Changed"
                                                  Unchecked="FriendCheckBox_Changed"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ── Code tab ── -->
        <StackPanel Grid.Row="4"
                    x:Name="CodeTabPanel"
                    IsVisible="False"
                    Margin="0,0,0,12">

            <!-- Generate code -->
            <Border Background="{DynamicResource BrushPanelBackground}"
                    BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"
                    CornerRadius="8" Padding="16,14" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Generate a share code"
                               FontFamily="{DynamicResource FontDisplay}" FontSize="14"
                               Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,6"/>
                    <TextBlock Text="Anyone with this code can import this instance directly — no Nexora account needed. Codes expire after 7 days."
                               FontFamily="{DynamicResource FontBody}" FontSize="12"
                               Foreground="{DynamicResource BrushTextSecondary}"
                               TextWrapping="Wrap" Margin="0,0,0,14"/>
                    <Button x:Name="GenerateCodeBtn"
                            Content="Generate code"
                            Theme="{StaticResource SecondaryButtonStyle}"
                            Padding="16,8" HorizontalAlignment="Left"
                            Click="GenerateCode_Click"/>

                    <!-- Code display -->
                    <Border x:Name="CodeDisplayBorder"
                            Background="{DynamicResource BrushAppBackground}"
                            BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"
                            CornerRadius="8" Padding="16,12" Margin="0,14,0,0"
                            IsVisible="False">
                        <Grid>
                            <TextBlock x:Name="ShareCodeText"
                                       FontFamily="Consolas" FontSize="22"
                                       Foreground="{DynamicResource BrushAccent}"
                                       VerticalAlignment="Center"
                                       TextWrapping="Wrap"/>
                            <Button Content="Copy"
                                    Theme="{StaticResource SecondaryButtonStyle}"
                                    Padding="12,6" HorizontalAlignment="Right"
                                    Click="CopyCode_Click"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Import from code -->
            <Border Background="{DynamicResource BrushPanelBackground}"
                    BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"
                    CornerRadius="8" Padding="16,14">
                <StackPanel>
                    <TextBlock Text="Import using a code"
                               FontFamily="{DynamicResource FontDisplay}" FontSize="14"
                               Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,6"/>
                    <TextBlock Text="Paste a share code from someone else to import their instance."
                               FontFamily="{DynamicResource FontBody}" FontSize="12"
                               Foreground="{DynamicResource BrushTextSecondary}"
                               TextWrapping="Wrap" Margin="0,0,0,12"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBox x:Name="ImportCodeBox"
                                 Width="200" Padding="10,8"
                                 FontFamily="{DynamicResource FontBody}" FontSize="13"
                                 Background="{DynamicResource BrushPanelElevated}"
                                 Foreground="{DynamicResource BrushTextPrimary}"
                                 BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"/>
                        <Button Content="Import"
                                Theme="{StaticResource PrimaryButtonStyle}"
                                Padding="16,8" Margin="8,0,0,0"
                                Click="ImportFromCode_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- ── Selected friends summary (friends tab only) ── -->
        <Border Grid.Row="5"
                x:Name="SelectedSummaryBorder"
                Background="{DynamicResource BrushPanelBackground}"
                BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"
                CornerRadius="8" Padding="12,10" Margin="0,0,0,16"
                IsVisible="{Binding HasSelection, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock x:Name="SelectedSummaryText"
                       FontFamily="{DynamicResource FontBody}" FontSize="12"
                       Foreground="{DynamicResource BrushTextSecondary}"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- ── Action buttons ── -->
        <Grid Grid.Row="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       x:Name="SendStatusText"
                       FontFamily="{DynamicResource FontBody}" FontSize="12"
                       Foreground="{DynamicResource BrushTextSecondary}"
                       VerticalAlignment="Center" TextWrapping="Wrap"/>

            <Button Grid.Column="1"
                    Content="Cancel"
                    Click="Cancel_Click"
                    Theme="{StaticResource SecondaryButtonStyle}"
                    Padding="18,9" FontSize="13"/>

            <Button Grid.Column="3"
                    x:Name="ShareButton"
                    Content="Share with selected"
                    Click="Share_Click"
                    Theme="{StaticResource PrimaryButtonStyle}"
                    Padding="18,9" FontSize="13"
                    IsEnabled="False"/>
        </Grid>
    </Grid>
</Window>
