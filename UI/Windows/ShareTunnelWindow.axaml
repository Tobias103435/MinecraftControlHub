<Window x:Class="MinecraftControlHub.UI.Windows.ShareTunnelWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Share Tunnel"
        Width="480" Height="600"
        MinWidth="420" MinHeight="480"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BrushAppBackground}"
        ShowInTaskbar="False">

    <Grid Margin="28,24,28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Share Tunnel"
                       FontFamily="{StaticResource FontDisplay}" FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource BrushTextPrimary}"
                       Margin="0,0,0,4"/>
            <TextBlock Text="Select one or more friends to share your tunnel address with."
                       FontFamily="{StaticResource FontBody}" FontSize="12"
                       Foreground="{DynamicResource BrushTextSecondary}"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <!-- ── Tunnel info card ── -->
        <Border Grid.Row="1"
                Background="{DynamicResource BrushPanelBackground}"
                BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"
                CornerRadius="8" Padding="16,12" Margin="0,0,0,16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="Address"
                           FontFamily="{StaticResource FontBody}" FontSize="11"
                           Foreground="{DynamicResource BrushTextMuted}"
                           Margin="0,0,12,0" VerticalAlignment="Center"/>
                <TextBlock Grid.Row="0" Grid.Column="1"
                           x:Name="TunnelAddressText"
                           FontFamily="Consolas, Courier New, monospace"
                           FontSize="14" FontWeight="Bold"
                           Foreground="#4CAF7D"/>

                <TextBlock Grid.Row="1" Grid.Column="0"
                           Text="Server"
                           FontFamily="{StaticResource FontBody}" FontSize="11"
                           Foreground="{DynamicResource BrushTextMuted}"
                           Margin="0,4,12,0" VerticalAlignment="Center"
                           IsVisible="{Binding HasServerName, Converter={StaticResource BoolToVisibilityConverter}}"/>
                <TextBlock Grid.Row="1" Grid.Column="1"
                           x:Name="ServerNameText"
                           FontFamily="{StaticResource FontBody}" FontSize="12"
                           Foreground="{DynamicResource BrushTextSecondary}"
                           Margin="0,4,0,0"
                           IsVisible="{Binding HasServerName, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </Grid>
        </Border>

        <!-- ── Status / error message ── -->
        <Border Grid.Row="2"
                Background="{DynamicResource BrushPanelElevated}"
                CornerRadius="6" Padding="12,8" Margin="0,0,0,10"
                IsVisible="{Binding HasStatusMessage, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock x:Name="StatusMessageText"
                       FontFamily="{StaticResource FontBody}" FontSize="12"
                       Foreground="{DynamicResource BrushTextSecondary}"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- ── Friends list ── -->
        <Border Grid.Row="3"
                Background="{DynamicResource BrushPanelBackground}"
                BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"
                CornerRadius="8" Margin="0,0,0,16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- List header -->
                <Border Grid.Row="0"
                        BorderBrush="{DynamicResource BrushBorder}" BorderThickness="0,0,0,1"
                        Padding="14,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="Friends"
                                   FontFamily="{StaticResource FontDisplay}" FontSize="13"
                                   Foreground="{DynamicResource BrushTextPrimary}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1"
                                   x:Name="SelectedCountText"
                                   FontFamily="{StaticResource FontBody}" FontSize="11"
                                   Foreground="{DynamicResource BrushTextMuted}"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Loading indicator -->
                <TextBlock Grid.Row="1"
                           x:Name="LoadingText"
                           Text="Loading friends…"
                           FontFamily="{StaticResource FontBody}" FontSize="13"
                           Foreground="{DynamicResource BrushTextMuted}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Margin="0,20"/>

                <!-- Empty state -->
                <TextBlock Grid.Row="1"
                           x:Name="EmptyText"
                           Text="No friends found. Add friends from the Social page first."
                           FontFamily="{StaticResource FontBody}" FontSize="12"
                           Foreground="{DynamicResource BrushTextMuted}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           TextAlignment="Center" TextWrapping="Wrap"
                           Margin="20" IsVisible="False"/>

                <!-- Friends scrollable list -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              IsVisible="False" x:Name="FriendsScrollViewer">
                    <ItemsControl x:Name="FriendsList" Margin="0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- Each friend row is a CheckBox styled as a full-width card row -->
                                <Border x:Name="RowBorder"
                                        BorderBrush="{DynamicResource BrushBorder}"
                                        BorderThickness="0,0,0,1"
                                        Padding="14,10"
                                        Cursor="Hand">
                                    <!-- Triggers removed - handled in code-behind -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Avatar circle -->
                                        <Border Grid.Column="0"
                                                Width="36" Height="36" CornerRadius="18"
                                                Background="{DynamicResource BrushAccent}"
                                                Margin="0,0,12,0">
                                            <TextBlock Text="{Binding Initial}"
                                                       FontFamily="{StaticResource FontDisplay}"
                                                       FontSize="15" Foreground="White"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- Username + Minecraft name -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding WebsiteUsername}"
                                                       FontFamily="{StaticResource FontBody}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource BrushTextPrimary}"/>
                                            <TextBlock Text="{Binding MinecraftUsername}"
                                                       FontFamily="{StaticResource FontBody}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource BrushTextMuted}"
                                                       IsVisible="{Binding MinecraftUsername,
                                                                    Converter={StaticResource NullToVisibilityConverter}}"/>
                                        </StackPanel>

                                        <!-- Checkbox -->
                                        <CheckBox Grid.Column="2"
                                                  x:Name="FriendCheckBox"
                                                  IsChecked="{Binding IsSelected}"
                                                  VerticalAlignment="Center"
                                                  IsCheckedChanged="FriendCheckBox_Changed"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ── Selected friends summary ── -->
        <Border Grid.Row="4"
                Background="{DynamicResource BrushPanelBackground}"
                BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"
                CornerRadius="8" Padding="12,10" Margin="0,0,0,16"
                IsVisible="{Binding HasSelection, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock x:Name="SelectedSummaryText"
                       FontFamily="{StaticResource FontBody}" FontSize="12"
                       Foreground="{DynamicResource BrushTextSecondary}"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- ── Action buttons ── -->
        <Grid Grid.Row="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       x:Name="SendStatusText"
                       FontFamily="{StaticResource FontBody}" FontSize="12"
                       Foreground="{DynamicResource BrushTextSecondary}"
                       VerticalAlignment="Center" TextWrapping="Wrap"/>

            <Button Grid.Column="1"
                    Content="Cancel"
                    Click="Cancel_Click"
                    Theme="{StaticResource SecondaryButtonStyle}"
                    Padding="18,9" FontSize="13"/>

            <Button Grid.Column="3"
                    x:Name="ShareButton"
                    Content="Share with selected friends"
                    Click="Share_Click"
                    Theme="{StaticResource PrimaryButtonStyle}"
                    Padding="18,9" FontSize="13"
                    IsEnabled="False"/>
        </Grid>
    </Grid>
</Window>
