<Window x:Class="MinecraftControlHub.UI.Windows.ServerPluginBrowserWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="Browse Plugins &amp; Mods"
        Width="960"
        Height="720"
        MinWidth="700"
        MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BrushAppBackground}">

    <Window.Resources>
        <!-- Tab button style (Plugins / Mods / Datapacks) -->
        <ControlTheme x:Key="TabButtonStyle" TargetType="Button">
            <Setter Property="FontFamily" Value="{StaticResource FontBody}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource BrushTextSecondary}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <!-- Triggers removed - handled in code-behind -->
                </ControlTemplate>
            </Setter>
        </ControlTheme>

        <ControlTheme x:Key="ActiveTabButtonStyle" TargetType="Button" BasedOn="{StaticResource TabButtonStyle}">
            <Setter Property="Foreground" Value="{StaticResource BrushAccent}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushAccent}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </ControlTheme>

        <!-- Result card style -->
        <ControlTheme x:Key="ResultCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BrushPanelBackground}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </ControlTheme>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- header + tabs -->
            <RowDefinition Height="Auto"/>
            <!-- search bar -->
            <RowDefinition Height="*"/>
            <!-- results -->
            <RowDefinition Height="Auto"/>
            <!-- pagination / status -->
        </Grid.RowDefinitions>

        <!-- ══════ HEADER ══════ -->
        <Border Grid.Row="0"
                Background="{StaticResource BrushPanelBackground}"
                BorderBrush="{StaticResource BrushBorder}"
                BorderThickness="0,0,0,1"
                Padding="24,16">
            <Grid>
                <StackPanel>
                    <TextBlock x:Name="WindowTitleTextBlock"
                               Text="Browse Plugins &amp; Mods"
                               FontFamily="{StaticResource FontDisplay}"
                               FontSize="20"
                               Foreground="{StaticResource BrushTextPrimary}"/>
                    <TextBlock x:Name="ServerSubtitleTextBlock"
                               Text="Powered by Modrinth"
                               FontFamily="{StaticResource FontBody}"
                               FontSize="12"
                               Foreground="{StaticResource BrushTextMuted}"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Tab row -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <Button x:Name="TabPlugins"
                            Content="Plugins"
                            Theme="{StaticResource ActiveTabButtonStyle}"
                            Tag="plugin"
                            Click="Tab_Click"/>
                    <Button x:Name="TabMods"
                            Content="Mods"
                            Theme="{StaticResource TabButtonStyle}"
                            Tag="mod"
                            Click="Tab_Click"/>
                    <Button x:Name="TabDatapacks"
                            Content="Datapacks"
                            Theme="{StaticResource TabButtonStyle}"
                            Tag="datapack"
                            Click="Tab_Click"/>
                </StackPanel>

                <!-- Sort -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="Sort:"
                               FontFamily="{StaticResource FontBody}"
                               FontSize="13"
                               Foreground="{StaticResource BrushTextSecondary}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <ComboBox x:Name="SortComboBox"
                              Width="160"
                              Padding="10,6"
                              FontSize="13"
                              Background="{StaticResource BrushAppBackground}"
                              BorderBrush="{StaticResource BrushBorder}"
                              BorderThickness="1"
                              Foreground="{StaticResource BrushTextPrimary}"
                              SelectionChanged="SortComboBox_SelectionChanged"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════ SEARCH BAR ══════ -->
        <Border Grid.Row="1"
                Padding="24,14"
                BorderBrush="{StaticResource BrushBorder}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="SearchBox"
                         Grid.Column="0"
                         Padding="12,8"
                         FontSize="14"
                         Background="{StaticResource BrushPanelBackground}"
                         BorderBrush="{StaticResource BrushBorder}"
                         BorderThickness="1"
                         Foreground="{StaticResource BrushTextPrimary}"
                         VerticalContentAlignment="Center"
                         KeyDown="SearchBox_KeyDown"/>

                <Button Grid.Column="1"
                        Content="Search"
                        Theme="{StaticResource PrimaryButtonStyle}"
                        Padding="20,8"
                        Margin="10,0,0,0"
                        Click="SearchButton_Click"/>

                <Button Grid.Column="2"
                        Content="Re-check Dependencies"
                        Theme="{StaticResource SecondaryButtonStyle}"
                        Padding="14,8"
                        Margin="10,0,0,0"
                        Click="RecheckDependencies_Click"/>

                <TextBlock x:Name="VersionBadge"
                           Grid.Column="3"
                           VerticalAlignment="Center"
                           Margin="14,0,0,0"
                           FontFamily="{StaticResource FontBody}"
                           FontSize="12"
                           Foreground="{StaticResource BrushTextMuted}"/>
            </Grid>
        </Border>

        <!-- ══════ RESULTS ══════ -->
        <Grid Grid.Row="2">
            <!-- Loading spinner -->
            <Border x:Name="LoadingOverlay"
                    IsVisible="False"
                    Background="{StaticResource BrushAppBackground}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Searching Modrinth…"
                               FontFamily="{StaticResource FontBody}"
                               FontSize="15"
                               Foreground="{StaticResource BrushTextSecondary}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Empty state -->
            <Border x:Name="EmptyState"
                    IsVisible="False">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock x:Name="EmptyStateText"
                               Text="No results found. Try a different search term."
                               FontFamily="{StaticResource FontBody}"
                               FontSize="14"
                               Foreground="{StaticResource BrushTextMuted}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Results list -->
            <ScrollViewer x:Name="ResultsScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          Padding="24,16">
                <ItemsControl x:Name="ResultsItemsControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Theme="{StaticResource ResultCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="56"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Icon -->
                                    <Border Grid.Column="0"
                                            Width="48"
                                            Height="48"
                                            CornerRadius="8"
                                            Background="{StaticResource BrushPanelElevated}"
                                            VerticalAlignment="Top"
                                            Margin="0,0,12,0">
                                        <Image Width="48" Height="48"
                                               Stretch="UniformToFill"
                                               RenderOptions.BitmapInterpolationMode="HighQuality"
                                               Source="{Binding IconUrl}"/>
                                    </Border>

                                    <!-- Info -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}"
                                                   FontFamily="{StaticResource FontDisplay}"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource BrushTextPrimary}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Author, StringFormat='by {0}'}"
                                                   FontFamily="{StaticResource FontBody}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource BrushAccent}"
                                                   Margin="0,2,0,4"/>
                                        <TextBlock Text="{Binding Description}"
                                                   FontFamily="{StaticResource FontBody}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource BrushTextSecondary}"
                                                   TextWrapping="Wrap"
                                                   MaxHeight="36"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                            <TextBlock Text="⬇"
                                                       FontSize="11"
                                                       Foreground="{StaticResource BrushTextMuted}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding Downloads, StringFormat='{}{0:N0}'}"
                                                       FontFamily="{StaticResource FontBody}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource BrushTextMuted}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Install button -->
                                    <StackPanel Grid.Column="2"
                                                VerticalAlignment="Center"
                                                Margin="16,0,0,0">
                                        <Button Content="Install"
                                                Theme="{StaticResource PrimaryButtonStyle}"
                                                Padding="18,7"
                                                Tag="{Binding}"
                                                Click="InstallContent_Click"/>
                                        <TextBlock x:Name="InstalledBadge"
                                                   Text="✓ Installed"
                                                   FontFamily="{StaticResource FontBody}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource BrushAccent}"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,4,0,0"
                                                   IsVisible="False"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- ══════ PAGINATION + STATUS ══════ -->
        <Border Grid.Row="3"
                Background="{StaticResource BrushPanelBackground}"
                BorderBrush="{StaticResource BrushBorder}"
                BorderThickness="0,1,0,0"
                Padding="24,12">
            <Grid>
                <TextBlock x:Name="StatusTextBlock"
                           FontFamily="{StaticResource FontBody}"
                           FontSize="12"
                           Foreground="{StaticResource BrushTextMuted}"
                           VerticalAlignment="Center"/>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button x:Name="PrevPageButton"
                            Content="← Prev"
                            Theme="{StaticResource SecondaryButtonStyle}"
                            Padding="14,6"
                            Margin="0,0,8,0"
                            IsEnabled="False"
                            Click="PrevPage_Click"/>
                    <TextBlock x:Name="PageLabel"
                               FontFamily="{StaticResource FontBody}"
                               FontSize="13"
                               Foreground="{StaticResource BrushTextPrimary}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <Button x:Name="NextPageButton"
                            Content="Next →"
                            Theme="{StaticResource SecondaryButtonStyle}"
                            Padding="14,6"
                            IsEnabled="False"
                            Click="NextPage_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
