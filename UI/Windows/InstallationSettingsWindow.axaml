<Window x:Class="MinecraftControlHub.UI.Windows.InstallationSettingsWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewmodels="clr-namespace:MinecraftControlHub.UI.ViewModels"
        xmlns:models="clr-namespace:MinecraftControlHub.Core.Models"
        Title="{Binding DetailInstallation.Name, StringFormat='{}{0} — Settings'}"
        Width="960" Height="720"
        MinWidth="680" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BrushAppBackground}"
        d:DataContext="{d:DesignInstance viewmodels:HomePageViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Main body: sidebar (left) + content (right) -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="185"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ===================== Left nav sidebar ===================== -->
            <Border Grid.Column="0"
                    Background="{DynamicResource BrushSidebarBackground}"
                    BorderBrush="{DynamicResource BrushBorder}"
                    BorderThickness="0,0,1,0">
                <StackPanel Margin="0,16,0,0" RadioButton.Checked="DetailNav_Checked">

                    <TextBlock Text="Settings"
                               FontFamily="{DynamicResource FontDisplay}"
                               FontSize="11"
                               Foreground="{DynamicResource BrushTextMuted}"
                               Margin="26,0,0,10"/>

                    <!-- General -->
                    <RadioButton x:Name="DetailNavHome" GroupName="DetailNav" Tag="Home"
                                 Theme="{StaticResource NavItemStyle}" IsChecked="True">
                        <StackPanel Orientation="Horizontal">
                            <Canvas Width="16" Height="16" VerticalAlignment="Center">
                                <Polygon Points="8,1 15,7 15,15 1,15 1,7"
                                         Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                                <Rectangle Canvas.Left="5.5" Canvas.Top="9" Width="5" Height="6"
                                           Fill="{DynamicResource BrushSidebarBackground}"/>
                            </Canvas>
                            <TextBlock Text="General" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="13"/>
                        </StackPanel>
                    </RadioButton>

                    <!-- Content (resourcepacks / shaderpacks / worlds) -->
                    <RadioButton x:Name="DetailNavContent" GroupName="DetailNav" Tag="Content"
                                 Theme="{StaticResource NavItemStyle}">
                        <StackPanel Orientation="Horizontal">
                            <Canvas Width="16" Height="16" VerticalAlignment="Center">
                                <!-- Layers icon -->
                                <Rectangle Canvas.Left="1" Canvas.Top="1" Width="14" Height="4" RadiusX="2" RadiusY="2"
                                           Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                                <Rectangle Canvas.Left="1" Canvas.Top="6" Width="14" Height="4" RadiusX="2" RadiusY="2"
                                           Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                                <Rectangle Canvas.Left="1" Canvas.Top="11" Width="14" Height="4" RadiusX="2" RadiusY="2"
                                           Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                            </Canvas>
                            <TextBlock Text="Content" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="13"/>
                        </StackPanel>
                    </RadioButton>

                    <!-- Advanced -->
                    <RadioButton x:Name="DetailNavAdvanced" GroupName="DetailNav" Tag="Advanced"
                                 Theme="{StaticResource NavItemStyle}">
                        <StackPanel Orientation="Horizontal">
                            <Canvas Width="16" Height="16" VerticalAlignment="Center">
                                <Ellipse Canvas.Left="2" Canvas.Top="2" Width="12" Height="12" StrokeThickness="2"
                                         Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                                <Ellipse Canvas.Left="6" Canvas.Top="6" Width="4" Height="4"
                                         Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                            </Canvas>
                            <TextBlock Text="Advanced" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="13"/>
                        </StackPanel>
                    </RadioButton>

                    <!-- Server Sync -->
                    <RadioButton x:Name="DetailNavServerSync" GroupName="DetailNav" Tag="ServerSync"
                                 Theme="{StaticResource NavItemStyle}">
                        <StackPanel Orientation="Horizontal">
                            <Canvas Width="16" Height="16" VerticalAlignment="Center">
                                <!-- Up arrow -->
                                <Polyline Points="8,2 12,7 8,7 8,14 8,7 4,7"
                                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                          StrokeThickness="2" StrokeJoin="Round" StrokeLineCap="Round"/>
                                <!-- Down arrow -->
                                <Line StartPoint="8,14" EndPoint="8,7"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                      StrokeThickness="2"/>
                            </Canvas>
                            <TextBlock Text="Server Sync" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="13"/>
                        </StackPanel>
                    </RadioButton>

                    <!-- Screenshots -->
                    <RadioButton x:Name="DetailNavScreenshots" GroupName="DetailNav" Tag="Screenshots"
                                 Theme="{StaticResource NavItemStyle}">
                        <StackPanel Orientation="Horizontal">
                            <Canvas Width="16" Height="16" VerticalAlignment="Center">
                                <!-- Camera body -->
                                <Rectangle Canvas.Left="1" Canvas.Top="4" Width="14" Height="10"
                                           RadiusX="2" RadiusY="2"
                                           Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                           StrokeThickness="1.6"
                                           Fill="Transparent"/>
                                <!-- Lens circle -->
                                <Ellipse Canvas.Left="5" Canvas.Top="6" Width="6" Height="6"
                                         Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                         StrokeThickness="1.4"
                                         Fill="Transparent"/>
                                <!-- Viewfinder bump -->
                                <Rectangle Canvas.Left="5" Canvas.Top="2" Width="4" Height="3"
                                           RadiusX="1" RadiusY="1"
                                           Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                            </Canvas>
                            <TextBlock Text="Screenshots" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="13"/>
                        </StackPanel>
                    </RadioButton>

                    <!-- Health -->
                    <RadioButton x:Name="DetailNavHealth" GroupName="DetailNav" Tag="Health"
                                 Theme="{StaticResource NavItemStyle}">
                        <StackPanel Orientation="Horizontal">
                            <Canvas Width="16" Height="16" VerticalAlignment="Center">
                                <!-- Heart -->
                                <Path Canvas.Left="1" Canvas.Top="2" Data="M 2,4 C 2,2.5 3,1 4.5,1 C 5.5,1 6.5,2 7,3 C 7.5,2 8.5,1 9.5,1 C 11,1 12,2.5 12,4 C 12,6.5 7,11 7,11 C 7,11 2,6.5 2,4 Z"
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                            </Canvas>
                            <TextBlock Text="Health" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="13"/>
                        </StackPanel>
                    </RadioButton>

                </StackPanel>
            </Border>

            <!-- ===================== Content area ===================== -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="28,20,28,20">

                    <!-- ===== General section ===== -->
                    <StackPanel IsVisible="{Binding IsHomeSection, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="General"
                                   FontFamily="{DynamicResource FontDisplay}"
                                   FontSize="16"
                                   Foreground="{DynamicResource BrushTextPrimary}"
                                   Margin="0,0,0,18"/>

                        <TextBlock Text="Name"
                                   FontFamily="{DynamicResource FontBody}" FontSize="12"
                                   Foreground="{DynamicResource BrushTextSecondary}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding DetailName, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="10" Background="{DynamicResource BrushPanelElevated}"
                                 BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"
                                 Foreground="{DynamicResource BrushTextPrimary}" FontSize="13" Margin="0,0,0,16"/>

                        <TextBlock Text="Minecraft version"
                                   FontFamily="{DynamicResource FontBody}" FontSize="12"
                                   Foreground="{DynamicResource BrushTextSecondary}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding DetailMinecraftVersion, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="10" Background="{DynamicResource BrushPanelElevated}"
                                 BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"
                                 Foreground="{DynamicResource BrushTextPrimary}" FontSize="13" Margin="0,0,0,16"/>

                        <TextBlock Text="Loader"
                                   FontFamily="{DynamicResource FontBody}" FontSize="12"
                                   Foreground="{DynamicResource BrushTextSecondary}" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding Loaders}" SelectedItem="{Binding DetailLoader}"
                                  HorizontalAlignment="Left" MinWidth="200" Margin="0,0,0,16"/>

                        <TextBlock Text="Pinned loader build"
                                   FontFamily="{DynamicResource FontBody}" FontSize="12"
                                   Foreground="{DynamicResource BrushTextSecondary}" Margin="0,0,0,2"/>
                        <TextBlock Text="Leave blank to always use the newest compatible build."
                                   FontFamily="{DynamicResource FontBody}" FontSize="11"
                                   Foreground="{DynamicResource BrushTextMuted}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding DetailLoaderVersion, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="10" Background="{DynamicResource BrushPanelElevated}"
                                 BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"
                                 Foreground="{DynamicResource BrushTextPrimary}" FontSize="13" Margin="0,0,0,4"/>
                    </StackPanel>

                    <!-- ===== Content section (Mods / ResourcePacks / ShaderPacks) ===== -->
                    <StackPanel IsVisible="{Binding IsContentSection, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="Content"
                                   FontFamily="{DynamicResource FontDisplay}" FontSize="16"
                                   Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,6"/>
                        <TextBlock Text="Manage mods, resource packs, and shader packs for this installation."
                                   FontFamily="{DynamicResource FontBody}" FontSize="12"
                                   Foreground="{DynamicResource BrushTextSecondary}" Margin="0,0,0,16"/>

                        <!-- Sub-nav tabs -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16"
                                    RadioButton.Checked="ContentSubNav_Checked">
                            <RadioButton x:Name="SubNavMods"
                                         GroupName="ContentSubNav" Tag="Mods"
                                         IsChecked="True"
                                         Content="Mods"
                                         Theme="{StaticResource ContentTabStyle}"
                                         Padding="14,10" Margin="0,0,2,0"/>
                            <RadioButton x:Name="SubNavResourcePacks"
                                         GroupName="ContentSubNav" Tag="ResourcePacks"
                                         Content="Resource Packs"
                                         Theme="{StaticResource ContentTabStyle}"
                                         Padding="14,10" Margin="0,0,2,0"/>
                            <RadioButton x:Name="SubNavShaderPacks"
                                         GroupName="ContentSubNav" Tag="ShaderPacks"
                                         Content="Shader Packs"
                                         Theme="{StaticResource ContentTabStyle}"
                                         Padding="14,10" Margin="0,0,2,0"/>
                            <RadioButton x:Name="SubNavMaps"
                                         GroupName="ContentSubNav" Tag="Maps"
                                         Content="Maps"
                                         Theme="{StaticResource ContentTabStyle}"
                                         Padding="14,10"/>
                        </StackPanel>

                        <!-- ─ Mods panel ─ -->
                        <StackPanel x:Name="ModsContentPanel">
                            <!-- Action buttons row -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Button Content="Browse Mods"
                                        Theme="{StaticResource PrimaryButtonStyle}"
                                        Padding="14,8" Margin="0,0,10,0"
                                        Click="BrowseMods_Click"/>
                                <Button Content="Check for updates"
                                        Theme="{StaticResource SecondaryButtonStyle}"
                                        Padding="14,8" Margin="0,0,10,0"
                                        IsEnabled="{Binding IsCheckingModUpdates, Converter={StaticResource InverseBoolConverter}}"
                                        Click="CheckModUpdates_Click"/>
                                <Button Content="Check dependencies"
                                        Theme="{StaticResource SecondaryButtonStyle}"
                                        Padding="14,8" Margin="0,0,10,0"
                                        IsEnabled="{Binding IsCheckingDependencies, Converter={StaticResource InverseBoolConverter}}"
                                        Click="CheckDependencies_Click"/>
                                <Button Content="Open folder"
                                        Theme="{StaticResource SecondaryButtonStyle}"
                                        Padding="14,8"
                                        Click="OpenModsFolder_Click"/>
                            </StackPanel>

                            <!-- Update status -->
                            <TextBlock Text="{Binding DetailUpdateStatus}"
                                       FontFamily="{DynamicResource FontBody}" FontSize="12"
                                       Foreground="{DynamicResource BrushTextSecondary}"
                                       TextWrapping="Wrap" Margin="0,0,0,8"
                                       IsVisible="{Binding HasDetailUpdateStatus, Converter={StaticResource BoolToVisibilityConverter}}"/>

                            <!-- Dependency issues -->
                            <TextBlock Text="{Binding DetailDependencyStatus}"
                                       FontFamily="{DynamicResource FontBody}" FontSize="12"
                                       Foreground="{DynamicResource BrushTextSecondary}"
                                       TextWrapping="Wrap" Margin="0,0,0,8"
                                       IsVisible="{Binding HasDetailDependencyStatus, Converter={StaticResource BoolToVisibilityConverter}}"/>

                            <ItemsControl ItemsSource="{Binding DetailDependencyIssues}"
                                          Margin="0,0,0,12"
                                          IsVisible="{Binding HasDetailDependencyIssues, Converter={StaticResource BoolToVisibilityConverter}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource BrushPanelElevated}"
                                                BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"
                                                CornerRadius="6" Padding="10,8" Margin="0,0,0,4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Description}"
                                                           FontFamily="{DynamicResource FontBody}" FontSize="12"
                                                           Foreground="{DynamicResource BrushTextPrimary}"
                                                           TextWrapping="Wrap" VerticalAlignment="Center"/>
                                                <Button Grid.Column="1" Content="Fix"
                                                        Theme="{StaticResource PrimaryButtonStyle}"
                                                        Padding="12,5" Margin="10,0,4,0"
                                                        Click="FixDependencyIssue_Click"/>
                                                <Button Grid.Column="2" Content="Fix all"
                                                        Theme="{StaticResource SecondaryButtonStyle}"
                                                        Padding="12,5"
                                                        IsVisible="{Binding HasDetailDependencyIssues, Converter={StaticResource BoolToVisibilityConverter}}"
                                                        Click="FixAllDependencyIssues_Click"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Border Height="1" Background="{DynamicResource BrushBorder}" Margin="0,0,0,12"
                                    IsVisible="{Binding HasDetailDependencyIssues, Converter={StaticResource BoolToVisibilityConverter}}"/>

                            <!-- Installed mods list — drag & drop enabled -->
                            <Border DragDrop.AllowDrop="True"
                                    DragDrop.DragOver="ModsDropZone_DragOver"
                                    DragDrop.Drop="ModsDropZone_Drop"
                                    BorderBrush="{DynamicResource BrushBorder}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="10"
                                    Background="{DynamicResource BrushPanelBackground}"
                                    Margin="0,0,0,4">
                                <StackPanel>
                                    <!-- Drop hint: always visible when no mods, subtler bar when mods exist -->
                                    <Border Background="{DynamicResource BrushPanelBackground}"
                                            BorderBrush="{DynamicResource BrushBorder}"
                                            BorderThickness="1" CornerRadius="6"
                                            Padding="0,8" Margin="0,0,0,8"
                                            IsVisible="{Binding HasDetailMods, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                        <TextBlock FontFamily="{DynamicResource FontBody}" FontSize="12"
                                                   Foreground="{DynamicResource BrushTextMuted}"
                                                   HorizontalAlignment="Center"
                                                   Text="⬇  Sleep .jar mod bestanden hiernaartoe om ze te installeren"/>
                                    </Border>
                                    <!-- Subtle drop hint when mods ARE installed -->
                                    <TextBlock FontFamily="{DynamicResource FontBody}" FontSize="11"
                                               Foreground="{DynamicResource BrushTextMuted}"
                                               HorizontalAlignment="Right" Margin="0,0,4,6"
                                               Text="⬇ Sleep hier een .jar om nog een mod toe te voegen"
                                               IsVisible="{Binding HasDetailMods, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                    <ItemsControl ItemsSource="{Binding DetailModRows}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <!-- Each installed mod row -->
                                                <Border Background="{DynamicResource BrushPanelElevated}"
                                                        BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"
                                                        CornerRadius="8" Padding="12,10" Margin="0,0,0,6"
                                                        Opacity="{Binding IsEnabled, Converter={StaticResource BoolToOpacityConverter}}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <!-- Toggle button -->
                                                            <ColumnDefinition Width="Auto"/>
                                                            <!-- Mod info -->
                                                            <ColumnDefinition Width="*"/>
                                                            <!-- Version -->
                                                            <ColumnDefinition Width="Auto"/>
                                                            <!-- Update -->
                                                            <ColumnDefinition Width="Auto"/>
                                                            <!-- Uninstall -->
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <!-- Enable/Disable toggle -->
                                                        <ToggleButton Grid.Column="0"
                                                                      IsChecked="{Binding IsEnabled, Mode=OneWay}"
                                                                      ToolTip.Tip="{Binding IsEnabled, Converter={StaticResource BoolToEnableTooltipConverter}}"
                                                                      Theme="{StaticResource ModToggleStyle}"
                                                                      Margin="0,0,12,0"
                                                                      Click="ModToggle_Click"/>

                                                        <!-- Name + version info -->
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock FontFamily="{DynamicResource FontBody}" FontSize="13"
                                                                       Foreground="{DynamicResource BrushTextPrimary}"
                                                                       Cursor="Hand" PointerPressed="ModLink_Click">
                                                                <Run Text="{Binding Mod.Name, Mode=OneWay}"/>
                                                            </TextBlock>
                                                            <TextBlock FontFamily="{DynamicResource FontBody}" FontSize="11"
                                                                       Foreground="{DynamicResource BrushTextSecondary}" Margin="0,2,0,0">
                                                                <Run Text="{Binding Mod.Version, Mode=OneWay}"/>
                                                                <Run Text=" · "/>
                                                                <Run Text="{Binding LoaderLabel, Mode=OneWay}"/>
                                                            </TextBlock>
                                                            <TextBlock Text="{Binding StatusText}"
                                                                       IsVisible="{Binding HasStatusText, Converter={StaticResource BoolToVisibilityConverter}}"
                                                                       FontFamily="{DynamicResource FontBody}" FontSize="11"
                                                                       Foreground="{DynamicResource BrushTextSecondary}" Margin="0,2,0,0"/>
                                                        </StackPanel>

                                                        <!-- Change version button -->
                                                        <Button Grid.Column="2"
                                                                Content="Version"
                                                                Theme="{StaticResource SecondaryButtonStyle}"
                                                                Padding="10,5" Margin="8,0,0,0" VerticalAlignment="Center"
                                                                Click="ChangeVersion_Click"/>

                                                        <!-- Update button -->
                                                        <Button Grid.Column="3"
                                                                Content="{Binding UpdateLabel}"
                                                                Theme="{StaticResource PrimaryButtonStyle}"
                                                                Padding="12,5" Margin="4,0,0,0" VerticalAlignment="Center"
                                                                IsVisible="{Binding UpdateAvailable, Converter={StaticResource BoolToVisibilityConverter}}"
                                                                Click="UpdateModRow_Click"/>

                                                        <!-- Uninstall button -->
                                                        <Button Grid.Column="4"
                                                                Content="Uninstall"
                                                                DataContext="{Binding Mod}"
                                                                Theme="{StaticResource DangerButtonStyle}"
                                                                Padding="12,5" Margin="4,0,0,0" VerticalAlignment="Center"
                                                                Click="UninstallMod_Click"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- ─ Resource Packs panel ─ -->
                        <StackPanel x:Name="ResourcePacksPanel" IsVisible="False">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Button Content="Browse Resource Packs"
                                        Theme="{StaticResource PrimaryButtonStyle}"
                                        Padding="14,8"
                                        Click="BrowseResourcePacks_Click"/>
                            </StackPanel>
                            <Border x:Name="ResourcePacksDropZone"
                                    DragDrop.AllowDrop="True"
                                    DragDrop.DragOver="ContentPanel_DragOver"
                                    DragDrop.Drop="ContentPanel_Drop"
                                    Background="{DynamicResource BrushPanelBackground}"
                                    BorderBrush="{DynamicResource BrushBorder}"
                                    BorderThickness="1" CornerRadius="8" Padding="12"
                                    MinHeight="80">
                                <StackPanel DataContext="{Binding ElementName=ResourcePacksPanel, Path=DataContext}">
                                    <Border Background="{DynamicResource BrushPanelBackground}"
                                            BorderBrush="{DynamicResource BrushBorder}"
                                            BorderThickness="1" CornerRadius="6"
                                            Padding="0,8" Margin="0,0,0,8"
                                            IsVisible="{Binding HasItems, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                        <TextBlock Text="⬇  Sleep .zip resource pack bestanden hiernaartoe"
                                                   FontFamily="{DynamicResource FontBody}" FontSize="12"
                                                   Foreground="{DynamicResource BrushTextMuted}"
                                                   HorizontalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="⬇ Sleep hier een .zip om nog een resource pack toe te voegen"
                                               FontFamily="{DynamicResource FontBody}" FontSize="11"
                                               Foreground="{DynamicResource BrushTextMuted}"
                                               HorizontalAlignment="Right" Margin="0,0,4,6"
                                               IsVisible="{Binding HasItems, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    <TextBlock Text="Loading…"
                                               FontFamily="{DynamicResource FontBody}" FontSize="12"
                                               Foreground="{DynamicResource BrushTextMuted}"
                                               HorizontalAlignment="Center"
                                               IsVisible="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    <ItemsControl ItemsSource="{Binding InstalledItems}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type models:ContentItem}">
                                                <Border Background="{DynamicResource BrushPanelElevated}"
                                                        BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"
                                                        CornerRadius="6" Padding="10,8" Margin="0,0,0,4">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Name}"
                                                                       FontFamily="{DynamicResource FontBody}" FontSize="13"
                                                                       Foreground="{DynamicResource BrushTextPrimary}"/>
                                                            <TextBlock Text="{Binding FileSizeLabel}"
                                                                       FontFamily="{DynamicResource FontBody}" FontSize="11"
                                                                       Foreground="{DynamicResource BrushTextMuted}" Margin="0,2,0,0"/>
                                                        </StackPanel>
                                                        <!-- Enable/Disable toggle -->
                                                        <ToggleButton Grid.Column="1"
                                                                      IsChecked="{Binding IsEnabled, Mode=OneWay}"
                                                                      Content="{Binding IsEnabled, Converter={StaticResource BoolToEnabledLabelConverter}}"
                                                                      Theme="{StaticResource SecondaryToggleButtonStyle}"
                                                                      Padding="10,4" Margin="8,0,0,0" VerticalAlignment="Center"
                                                                      Click="ToggleContentItem_Click"/>
                                                        <!-- Version picker -->
                                                        <Button Grid.Column="2"
                                                                Content="Version"
                                                                Theme="{StaticResource SecondaryButtonStyle}"
                                                                Padding="10,4" Margin="4,0,0,0" VerticalAlignment="Center"
                                                                Click="ContentVersionPicker_Click"/>
                                                        <Button Grid.Column="3" Content="Delete"
                                                                Theme="{StaticResource DangerButtonStyle}"
                                                                Padding="10,4" Margin="4,0,0,0" VerticalAlignment="Center"
                                                                Click="DeleteContentItem_Click"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Text="{Binding Status}"
                                               FontFamily="{DynamicResource FontBody}" FontSize="12"
                                               Foreground="{DynamicResource BrushTextSecondary}" Margin="0,4,0,0"
                                               IsVisible="{Binding HasStatus, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- ─ Shader Packs panel ─ -->
                        <StackPanel x:Name="ShaderPacksPanel" IsVisible="False">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Button Content="Browse Shader Packs"
                                        Theme="{StaticResource PrimaryButtonStyle}"
                                        Padding="14,8"
                                        Click="BrowseShaderPacks_Click"/>
                            </StackPanel>
                            <Border DragDrop.AllowDrop="True"
                                    DragDrop.DragOver="ContentPanel_DragOver"
                                    DragDrop.Drop="ContentPanel_Drop"
                                    Background="{DynamicResource BrushPanelBackground}"
                                    BorderBrush="{DynamicResource BrushBorder}"
                                    BorderThickness="1" CornerRadius="8" Padding="12"
                                    MinHeight="80">
                                <StackPanel DataContext="{Binding ElementName=ShaderPacksPanel, Path=DataContext}">
                                    <Border Background="{DynamicResource BrushPanelBackground}"
                                            BorderBrush="{DynamicResource BrushBorder}"
                                            BorderThickness="1" CornerRadius="6"
                                            Padding="0,8" Margin="0,0,0,8"
                                            IsVisible="{Binding HasItems, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                        <TextBlock Text="⬇  Sleep .zip shader pack bestanden hiernaartoe"
                                                   FontFamily="{DynamicResource FontBody}" FontSize="12"
                                                   Foreground="{DynamicResource BrushTextMuted}"
                                                   HorizontalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="⬇ Sleep hier een .zip om nog een shader pack toe te voegen"
                                               FontFamily="{DynamicResource FontBody}" FontSize="11"
                                               Foreground="{DynamicResource BrushTextMuted}"
                                               HorizontalAlignment="Right" Margin="0,0,4,6"
                                               IsVisible="{Binding HasItems, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    <TextBlock Text="Loading…"
                                               FontFamily="{DynamicResource FontBody}" FontSize="12"
                                               Foreground="{DynamicResource BrushTextMuted}"
                                               HorizontalAlignment="Center"
                                               IsVisible="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    <ItemsControl ItemsSource="{Binding InstalledItems}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type models:ContentItem}">
                                                <Border Background="{DynamicResource BrushPanelElevated}"
                                                        BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"
                                                        CornerRadius="6" Padding="10,8" Margin="0,0,0,4">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Name}"
                                                                       FontFamily="{DynamicResource FontBody}" FontSize="13"
                                                                       Foreground="{DynamicResource BrushTextPrimary}"/>
                                                            <TextBlock Text="{Binding FileSizeLabel}"
                                                                       FontFamily="{DynamicResource FontBody}" FontSize="11"
                                                                       Foreground="{DynamicResource BrushTextMuted}" Margin="0,2,0,0"/>
                                                        </StackPanel>
                                                        <!-- Enable/Disable toggle -->
                                                        <ToggleButton Grid.Column="1"
                                                                      IsChecked="{Binding IsEnabled, Mode=OneWay}"
                                                                      Content="{Binding IsEnabled, Converter={StaticResource BoolToEnabledLabelConverter}}"
                                                                      Theme="{StaticResource SecondaryToggleButtonStyle}"
                                                                      Padding="10,4" Margin="8,0,0,0" VerticalAlignment="Center"
                                                                      Click="ToggleContentItem_Click"/>
                                                        <!-- Version picker -->
                                                        <Button Grid.Column="2"
                                                                Content="Version"
                                                                Theme="{StaticResource SecondaryButtonStyle}"
                                                                Padding="10,4" Margin="4,0,0,0" VerticalAlignment="Center"
                                                                Click="ContentVersionPicker_Click"/>
                                                        <Button Grid.Column="3" Content="Delete"
                                                                Theme="{StaticResource DangerButtonStyle}"
                                                                Padding="10,4" Margin="4,0,0,0" VerticalAlignment="Center"
                                                                Click="DeleteContentItem_Click"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Text="{Binding Status}"
                                               FontFamily="{DynamicResource FontBody}" FontSize="12"
                                               Foreground="{DynamicResource BrushTextSecondary}" Margin="0,4,0,0"
                                               IsVisible="{Binding HasStatus, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- ─ Maps panel ─ -->
                        <StackPanel x:Name="MapsPanel" IsVisible="False">
                            <!-- Drop zone: always visible, doubles as hint when empty -->
                            <Border x:Name="MapsDropZone"
                                    DragDrop.AllowDrop="True"
                                    DragDrop.DragOver="ContentPanel_DragOver"
                                    DragDrop.Drop="MapsPanel_Drop"
                                    Background="{DynamicResource BrushPanelBackground}"
                                    BorderBrush="{DynamicResource BrushAccent}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="0"
                                    Margin="0,0,0,12"
                                    MinHeight="110">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                            Margin="0,20,0,20">
                                    <!-- Drop icon (arrow down) -->
                                    <Border Width="44" Height="44" CornerRadius="22"
                                            Background="{DynamicResource BrushPanelElevated}"
                                            HorizontalAlignment="Center" Margin="0,0,0,10">
                                        <TextBlock Text="⬇" FontSize="18"
                                                   Foreground="{DynamicResource BrushAccent}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Drop world save .zip files here"
                                               FontFamily="{DynamicResource FontDisplay}" FontSize="13"
                                               Foreground="{DynamicResource BrushTextPrimary}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Drag them straight from File Explorer — no button needed"
                                               FontFamily="{DynamicResource FontBody}" FontSize="11"
                                               Foreground="{DynamicResource BrushTextMuted}"
                                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            <!-- Installed maps list -->
                            <ItemsControl x:Name="MapsListControl">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource BrushPanelElevated}"
                                                BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"
                                                CornerRadius="8" Padding="14,10" Margin="0,0,0,6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontFamily="{DynamicResource FontBody}" FontSize="13"
                                                               Foreground="{DynamicResource BrushTextPrimary}"
                                                               FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding FileSizeLabel}"
                                                               FontFamily="{DynamicResource FontBody}" FontSize="11"
                                                               Foreground="{DynamicResource BrushTextMuted}" Margin="0,2,0,0"/>
                                                </StackPanel>
                                                <Button Grid.Column="1" Content="Delete"
                                                        Theme="{StaticResource DangerButtonStyle}"
                                                        Padding="12,5" VerticalAlignment="Center"
                                                        Tag="{Binding}"
                                                        Click="DeleteMapItem_Click"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                    </StackPanel>

                    <!-- ===== Advanced section ===== -->
                    <StackPanel IsVisible="{Binding IsAdvancedSection, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="Advanced"
                                   FontFamily="{DynamicResource FontDisplay}" FontSize="16"
                                   Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,4"/>
                        <TextBlock Text="Launch arguments and performance settings."
                                   FontFamily="{DynamicResource FontBody}" FontSize="12"
                                   Foreground="{DynamicResource BrushTextSecondary}" Margin="0,0,0,20"/>

                        <!-- RAM -->
                        <Border Background="{DynamicResource BrushPanelBackground}"
                                BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"
                                CornerRadius="10" Padding="20" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Memory"
                                           FontFamily="{DynamicResource FontDisplay}" FontSize="13"
                                           Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,12"/>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                        <TextBlock Text="Max RAM (MB)"
                                                   FontFamily="{DynamicResource FontBody}" FontSize="12"
                                                   Foreground="{DynamicResource BrushTextSecondary}" Margin="0,0,0,4"/>
                                        <TextBox Text="{Binding DetailMaxMemoryMB, UpdateSourceTrigger=PropertyChanged}"
                                                 Padding="10" Background="{DynamicResource BrushPanelElevated}"
                                                 BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"
                                                 Foreground="{DynamicResource BrushTextPrimary}" FontSize="13"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                        <TextBlock Text="Min RAM (MB)"
                                                   FontFamily="{DynamicResource FontBody}" FontSize="12"
                                                   Foreground="{DynamicResource BrushTextSecondary}" Margin="0,0,0,4"/>
                                        <TextBox Text="{Binding DetailMinMemoryMB, UpdateSourceTrigger=PropertyChanged}"
                                                 Padding="10" Background="{DynamicResource BrushPanelElevated}"
                                                 BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"
                                                 Foreground="{DynamicResource BrushTextPrimary}" FontSize="13"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Render distance (chunks) for RAM calculator -->
                                <StackPanel Margin="0,0,0,8">
                                    <TextBlock Text="Render distance (chunks)"
                                               FontFamily="{DynamicResource FontBody}" FontSize="12"
                                               Foreground="{DynamicResource BrushTextSecondary}" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding DetailRenderDistance, UpdateSourceTrigger=PropertyChanged}"
                                             Width="160"
                                             Padding="10" Background="{DynamicResource BrushPanelElevated}"
                                             BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"
                                             Foreground="{DynamicResource BrushTextPrimary}" FontSize="13"/>
                                </StackPanel>

                                <Button Content="Calculate recommended RAM"
                                        Theme="{StaticResource SecondaryButtonStyle}"
                                        Padding="14,8" HorizontalAlignment="Left"
                                        Click="CalculateRam_Click"/>
                                <TextBlock Text="{Binding DetailRamRecommendation}"
                                           FontFamily="{DynamicResource FontBody}" FontSize="12"
                                           Foreground="{DynamicResource BrushTextSecondary}"
                                           TextWrapping="Wrap" Margin="0,8,0,0"
                                           IsVisible="{Binding HasDetailRamRecommendation, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </StackPanel>
                        </Border>

                        <!-- Java path -->
                        <Border Background="{DynamicResource BrushPanelBackground}"
                                BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"
                                CornerRadius="10" Padding="20" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Java executable"
                                           FontFamily="{DynamicResource FontDisplay}" FontSize="13"
                                           Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,4"/>
                                <TextBlock Text="Leave blank to auto-detect the bundled JRE."
                                           FontFamily="{DynamicResource FontBody}" FontSize="11"
                                           Foreground="{DynamicResource BrushTextMuted}" Margin="0,0,0,8"/>
                                <TextBox Text="{Binding DetailJavaPath, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="10" Background="{DynamicResource BrushPanelElevated}"
                                         BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"
                                         Foreground="{DynamicResource BrushTextPrimary}" FontSize="13"/>
                                <!-- Java health + auto-download -->
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <TextBlock Text="{Binding DetailJavaHealth}"
                                               FontFamily="{DynamicResource FontBody}" FontSize="11"
                                               Foreground="{DynamicResource BrushTextMuted}"
                                               VerticalAlignment="Center"
                                               IsVisible="{Binding DetailJavaHealth, Converter={StaticResource NullToVisibilityConverter}}"/>
                                    <Button Content="⬇ Download Java automatically"
                                            Theme="{StaticResource SecondaryButtonStyle}"
                                            Padding="10,4" Margin="10,0,0,0" FontSize="11"
                                            IsVisible="{Binding DetailJavaOk, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                            Click="DownloadJava_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- JVM args -->
                        <Border Background="{DynamicResource BrushPanelBackground}"
                                BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"
                                CornerRadius="10" Padding="20" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Extra JVM arguments"
                                           FontFamily="{DynamicResource FontDisplay}" FontSize="13"
                                           Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,4"/>
                                <TextBlock Text="Space-separated flags appended after the memory args on every launch."
                                           FontFamily="{DynamicResource FontBody}" FontSize="11"
                                           Foreground="{DynamicResource BrushTextMuted}" Margin="0,0,0,8"/>
                                <TextBox Text="{Binding DetailCustomJvmArgs, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="10" Background="{DynamicResource BrushPanelElevated}"
                                         BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"
                                         Foreground="{DynamicResource BrushTextPrimary}" FontSize="13"/>
                            </StackPanel>
                        </Border>

                        <!-- Version pinning -->
                        <Border Background="{DynamicResource BrushPanelBackground}"
                                BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"
                                CornerRadius="10" Padding="16" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Mod update pinning"
                                           FontFamily="{DynamicResource FontDisplay}" FontSize="13"
                                           Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,6"/>
                                <CheckBox Content="Pin to Minecraft version (only accept mod updates that target the exact same MC version)"
                                          IsChecked="{Binding DetailPinMinecraftVersion, Mode=TwoWay}"
                                          FontFamily="{DynamicResource FontBody}" FontSize="12"
                                          Foreground="{DynamicResource BrushTextPrimary}"/>
                                <TextBlock Text="Prevents accidentally pulling in a mod version built for a newer patch (e.g. 1.20.4 into a 1.20.1 pack)."
                                           FontFamily="{DynamicResource FontBody}" FontSize="11"
                                           Foreground="{DynamicResource BrushTextMuted}" Margin="0,6,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <!-- Export section -->
                        <TextBlock Text="Export"
                                   FontFamily="{DynamicResource FontDisplay}" FontSize="13"
                                   Foreground="{DynamicResource BrushTextPrimary}" Margin="0,4,0,4"/>
                        <TextBlock Text="Export this installation to use it in Prism Launcher. Both formats open directly in Prism."
                                   FontFamily="{DynamicResource FontBody}" FontSize="12"
                                   Foreground="{DynamicResource BrushTextSecondary}" TextWrapping="Wrap" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Background="{DynamicResource BrushPanelBackground}"
                                    BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"
                                    CornerRadius="10" Padding="16" Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="Modrinth pack (.mrpack)"
                                               FontFamily="{DynamicResource FontDisplay}" FontSize="12"
                                               Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,4"/>
                                    <TextBlock Text="Standard Modrinth format — best compatibility."
                                               FontFamily="{DynamicResource FontBody}" FontSize="11"
                                               Foreground="{DynamicResource BrushTextMuted}" Margin="0,0,0,10"
                                               TextWrapping="Wrap"/>
                                    <Button Content="Export .mrpack…"
                                            Theme="{StaticResource SecondaryButtonStyle}"
                                            Padding="14,8" HorizontalAlignment="Left"
                                            IsEnabled="{Binding IsExportingDetail, Converter={StaticResource InverseBoolConverter}}"
                                            Click="ExportInstallationDetail_Click"/>
                                    <TextBlock Text="{Binding DetailExportStatus}"
                                               FontFamily="{DynamicResource FontBody}" FontSize="11"
                                               Foreground="{DynamicResource BrushTextSecondary}"
                                               TextWrapping="Wrap" Margin="0,6,0,0"
                                               IsVisible="{Binding HasDetailExportStatus, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Background="{DynamicResource BrushPanelBackground}"
                                    BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"
                                    CornerRadius="10" Padding="16" Margin="8,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="Prism Launcher (.zip)"
                                               FontFamily="{DynamicResource FontDisplay}" FontSize="12"
                                               Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,4"/>
                                    <TextBlock Text="Prism-compatible instance zip."
                                               FontFamily="{DynamicResource FontBody}" FontSize="11"
                                               Foreground="{DynamicResource BrushTextMuted}" Margin="0,0,0,10"
                                               TextWrapping="Wrap"/>
                                    <Button Content="Export Prism zip…"
                                            Theme="{StaticResource SecondaryButtonStyle}"
                                            Padding="14,8" HorizontalAlignment="Left"
                                            IsEnabled="{Binding IsExportingPrismDetail, Converter={StaticResource InverseBoolConverter}}"
                                            Click="ExportInstallationDetailPrism_Click"/>
                                    <TextBlock Text="{Binding DetailPrismExportStatus}"
                                               FontFamily="{DynamicResource FontBody}" FontSize="11"
                                               Foreground="{DynamicResource BrushTextSecondary}"
                                               TextWrapping="Wrap" Margin="0,6,0,0"
                                               IsVisible="{Binding HasDetailPrismExportStatus, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>


                    <!-- ===== Server Sync section ===== -->
                    <StackPanel IsVisible="{Binding IsServerSyncSection, Converter={StaticResource BoolToVisibilityConverter}}">

                        <!-- Header row -->
                        <Grid Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="Server Sync"
                                           FontFamily="{DynamicResource FontDisplay}" FontSize="16"
                                           Foreground="{DynamicResource BrushTextPrimary}"/>
                                <TextBlock Text="Select which servers to sync mods from into this instance. Checked servers will copy their mods to this installation."
                                           FontFamily="{DynamicResource FontBody}" FontSize="12"
                                           Foreground="{DynamicResource BrushTextSecondary}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Button x:Name="MakeServerButton"
                                    Content="&#x2795; Make Server"
                                    Theme="{StaticResource PrimaryButtonStyle}"
                                    Padding="16,8"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Click="MakeServer_Click"/>
                        </Grid>

                        <!-- Server cards -->
                        <ItemsControl x:Name="ServerSyncItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Theme="{StaticResource CardCheckBoxStyle}"
                                              IsChecked="{Binding SyncEnabled, Mode=TwoWay}"
                                              IsEnabled="{Binding IsCompatible}"
                                              Opacity="{Binding RowOpacity}"
                                              Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Server info -->
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Border Width="36" Height="36" CornerRadius="8"
                                                        Background="{DynamicResource BrushAccent}" Margin="0,0,12,0">
                                                    <TextBlock Text="{Binding Initial}"
                                                               FontFamily="{DynamicResource FontDisplay}"
                                                               FontSize="15" FontWeight="Bold" Foreground="White"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontFamily="{DynamicResource FontBody}"
                                                               FontSize="14" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource BrushTextPrimary}"/>
                                                    <TextBlock Text="{Binding VersionLabel}"
                                                               FontFamily="{DynamicResource FontBody}" FontSize="12"
                                                               Foreground="{DynamicResource BrushTextSecondary}"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Compatible badge -->
                                            <Border Grid.Column="1" CornerRadius="20" Padding="10,4" Margin="12,0,16,0"
                                                    VerticalAlignment="Center"
                                                    Background="{Binding BadgeBackground}"
                                                    BorderBrush="{Binding BadgeBorder}" BorderThickness="1">
                                                <TextBlock Text="{Binding BadgeText}"
                                                           FontFamily="{DynamicResource FontBody}" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{Binding BadgeForeground}"/>
                                            </Border>

                                            <!-- Sync now button -->
                                            <Button Grid.Column="2"
                                                    Content="Sync now"
                                                    Theme="{StaticResource SecondaryButtonStyle}"
                                                    Padding="12,5" IsEnabled="{Binding IsCompatible}"
                                                    VerticalAlignment="Center" Tag="{Binding}"
                                                    Click="ServerSyncInstance_Click"/>
                                        </Grid>
                                    </CheckBox>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Empty state -->
                        <Border x:Name="ServerSyncEmptyState" Padding="24" IsVisible="False">
                            <TextBlock Text="No servers found. Create a server first in the Servers tab."
                                       FontFamily="{DynamicResource FontBody}" FontSize="13"
                                       Foreground="{DynamicResource BrushTextMuted}" HorizontalAlignment="Center"/>
                        </Border>

                        <!-- Bottom actions -->
                        <StackPanel Orientation="Horizontal" Margin="0,16,0,4">
                            <Button x:Name="ServerSyncAllButton"
                                    Content="Sync Checked"
                                    Theme="{StaticResource PrimaryButtonStyle}"
                                    Padding="16,8"
                                    Click="ServerSyncAll_Click"/>
                            <Button Content="&#x21BB; Refresh"
                                    Theme="{StaticResource SecondaryButtonStyle}"
                                    Padding="12,8" Margin="10,0,0,0"
                                    Click="RefreshServerSync_Click"/>
                        </StackPanel>

                        <TextBlock x:Name="ServerSyncStatusTextBlock"
                                   FontFamily="{DynamicResource FontBody}" FontSize="12"
                                   Foreground="{DynamicResource BrushTextSecondary}"
                                   TextWrapping="Wrap" Margin="0,10,0,0"/>

                    </StackPanel>

                    <!-- ===== Screenshots section ===== -->
                    <StackPanel IsVisible="{Binding IsScreenshotsSection, Converter={StaticResource BoolToVisibilityConverter}}">

                        <!-- Header -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Screenshots"
                                           FontFamily="{DynamicResource FontDisplay}"
                                           FontSize="16"
                                           Foreground="{DynamicResource BrushTextPrimary}"/>
                                <TextBlock x:Name="ScreenshotCountText"
                                           FontFamily="{DynamicResource FontBody}"
                                           FontSize="12"
                                           Foreground="{DynamicResource BrushTextMuted}"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="Open folder"
                                        Theme="{StaticResource SecondaryButtonStyle}"
                                        Padding="12,7" Margin="0,0,8,0"
                                        Click="OpenScreenshotsFolder_Click"/>
                                <Button Content="&#x21BB; Refresh"
                                        Theme="{StaticResource SecondaryButtonStyle}"
                                        Padding="12,7"
                                        Click="RefreshScreenshots_Click"/>
                            </StackPanel>
                        </Grid>

                        <!-- Empty state -->
                        <Border x:Name="ScreenshotsEmptyState"
                                Background="{DynamicResource BrushPanelBackground}"
                                BorderBrush="{DynamicResource BrushBorder}"
                                BorderThickness="1" CornerRadius="10"
                                Padding="40,32" IsVisible="False">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="📷"
                                           FontSize="36"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,12"/>
                                <TextBlock Text="No screenshots yet"
                                           FontFamily="{DynamicResource FontDisplay}"
                                           FontSize="15"
                                           Foreground="{DynamicResource BrushTextPrimary}"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,6"/>
                                <TextBlock Text="Press F2 in-game to take a screenshot. They appear here automatically."
                                           FontFamily="{DynamicResource FontBody}"
                                           FontSize="12"
                                           Foreground="{DynamicResource BrushTextMuted}"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           MaxWidth="280"/>
                            </StackPanel>
                        </Border>

                        <!-- Screenshot grid -->
                        <WrapPanel x:Name="ScreenshotsPanel"
                                   Orientation="Horizontal"
                                   IsVisible="False">
                        </WrapPanel>

                    </StackPanel>

                    <!-- Health Section -->
                    <StackPanel x:Name="HealthSection" IsVisible="{Binding IsHealthSection, Converter={StaticResource BoolToVisibilityConverter}}">
                        <!-- Header with refresh button -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20" VerticalAlignment="Center">
                            <TextBlock Text="Installation Health Check" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{DynamicResource BrushTextPrimary}" />
                            <Button x:Name="RefreshHealthBtn" Content="⟳ Refresh" Theme="{StaticResource SecondaryButtonStyle}" Padding="12,8" Margin="12,0,0,0" Click="RefreshHealth_Click" IsEnabled="{Binding IsLoadingHealth, Converter={StaticResource InverseBoolConverter}}"/>
                            <ProgressBar x:Name="HealthLoadingBar" Width="100" Height="4" Background="Transparent" Foreground="{DynamicResource BrushAccent}" IsIndeterminate="True" IsVisible="{Binding IsLoadingHealth, Converter={StaticResource BoolToVisibilityConverter}}" Margin="12,0,0,0"/>
                        </StackPanel>

                        <!-- Overall Score Card -->
                        <Border Background="{DynamicResource BrushPanelBackground}" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1" CornerRadius="10" Padding="20" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Overall Score" FontSize="12" Foreground="{DynamicResource BrushTextMuted}" Margin="0,0,0,8"/>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock x:Name="OverallScoreText" Text="{Binding DetailHealthCheck.OverallScore, StringFormat={}{0:F0}}" FontSize="32" FontWeight="SemiBold" Margin="0,0,16,0" Foreground="{DynamicResource BrushTextPrimary}"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock x:Name="OverallStatusText" Text="{Binding DetailHealthCheck.OverallStatus}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,4" Foreground="{DynamicResource BrushTextPrimary}"/>
                                        <TextBlock Text="{Binding DetailHealthCheck.OverallAdvice}" FontSize="11" Foreground="{DynamicResource BrushTextMuted}" TextWrapping="Wrap" MaxWidth="300"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Sub-scores grid (2 columns) -->
                        <UniformGrid Columns="2" Margin="0,0,0,16">

                            <!-- Java Score -->
                            <Border Background="{DynamicResource BrushPanelBackground}" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,6,12">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <TextBlock Text="☕ Java" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{DynamicResource BrushTextPrimary}" />
                                        <TextBlock x:Name="JavaStatusIcon" Text="" FontSize="14" Margin="8,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource BrushTextPrimary}"/>
                                    </StackPanel>
                                    <ProgressBar Height="6" Background="{DynamicResource BrushPanelElevated}" Foreground="{DynamicResource BrushAccent}" Value="{Binding DetailHealthCheck.JavaScore}" Maximum="25" Margin="0,0,0,10"/>
                                    <TextBlock Text="{Binding DetailHealthCheck.JavaScore, StringFormat={}{0:F0}}" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                                    <TextBlock Text="{Binding DetailHealthCheck.JavaAdvice}" FontSize="10" Foreground="{DynamicResource BrushTextMuted}" TextWrapping="Wrap" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- RAM Score -->
                            <Border Background="{DynamicResource BrushPanelBackground}" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="6,0,0,12">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <TextBlock Text="🧠 RAM" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{DynamicResource BrushTextPrimary}"/>
                                        <TextBlock x:Name="RamStatusIcon" Text="" FontSize="14" Margin="8,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource BrushTextPrimary}"/>
                                    </StackPanel>
                                    <ProgressBar Height="6" Background="{DynamicResource BrushPanelElevated}" Foreground="{DynamicResource BrushAccent}" Value="{Binding DetailHealthCheck.RamScore}" Maximum="25" Margin="0,0,0,10"/>
                                    <TextBlock Text="{Binding DetailHealthCheck.RamScore, StringFormat={}{0:F0}}" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                                    <TextBlock Text="{Binding DetailHealthCheck.RamAdvice}" FontSize="10" Foreground="{DynamicResource BrushTextMuted}" TextWrapping="Wrap" Margin="0,8,0,0"/>

                                    <!-- Auto-tune RAM suggestion -->
                                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0" HorizontalAlignment="Left">
                                        <TextBlock x:Name="RamRecommendationText" Text="" FontSize="11" Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <Button x:Name="AutoTuneRamButton" Content="Auto-tune RAM" Theme="{StaticResource SecondaryButtonStyle}" Padding="8,6" Click="AutoTuneRam_Click"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Mods Score -->
                            <Border Background="{DynamicResource BrushPanelBackground}" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,6,0">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <TextBlock Text="📦 Mods" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{DynamicResource BrushTextPrimary}"/>
                                        <TextBlock x:Name="ModsStatusIcon" Text="" FontSize="14" Margin="8,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource BrushTextPrimary}"/>
                                    </StackPanel>
                                    <ProgressBar Height="6" Background="{DynamicResource BrushPanelElevated}" Foreground="{DynamicResource BrushAccent}" Value="{Binding DetailHealthCheck.ModsScore}" Maximum="25" Margin="0,0,0,10"/>
                                    <TextBlock Text="{Binding DetailHealthCheck.ModsScore, StringFormat={}{0:F0}}" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                                    <TextBlock Text="{Binding DetailHealthCheck.ModsAdvice}" FontSize="10" Foreground="{DynamicResource BrushTextMuted}" TextWrapping="Wrap" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Stability Score -->
                            <Border Background="{DynamicResource BrushPanelBackground}" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="6,0,0,0">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <TextBlock Text="⚡ Stability" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{DynamicResource BrushTextPrimary}"/>
                                        <TextBlock x:Name="StabilityStatusIcon" Text="" FontSize="14" Margin="8,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource BrushTextPrimary}"/>
                                    </StackPanel>
                                    <ProgressBar Height="6" Background="{DynamicResource BrushBackground}" Foreground="{DynamicResource BrushAccent}" Value="{Binding DetailHealthCheck.StabilityScore}" Maximum="25" Margin="0,0,0,10"/>
                                    <TextBlock Text="{Binding DetailHealthCheck.StabilityScore, StringFormat={}{0:F0}}" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                                    <TextBlock Text="{Binding DetailHealthCheck.StabilityAdvice}" FontSize="10" Foreground="{DynamicResource BrushTextMuted}" TextWrapping="Wrap" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                        </UniformGrid>

                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Save bar -->
        <Border Grid.Row="1"
                Background="{DynamicResource BrushSidebarBackground}"
                BorderBrush="{DynamicResource BrushBorder}"
                BorderThickness="0,1,0,0"
                Padding="28,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Text="{Binding DetailSaveStatus}"
                           VerticalAlignment="Center" Margin="0,0,14,0"
                           FontFamily="{DynamicResource FontBody}" FontSize="12"
                           Foreground="{DynamicResource BrushTextSecondary}"
                           IsVisible="{Binding HasDetailSaveStatus, Converter={StaticResource BoolToVisibilityConverter}}"/>
                <Button Content="Save"
                        Theme="{StaticResource PrimaryButtonStyle}"
                        Padding="28,10"
                        Click="SaveDetail_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
