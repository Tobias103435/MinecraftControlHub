<Window x:Class="MinecraftControlHub.UI.Windows.BrowseModsWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:pages="clr-namespace:MinecraftControlHub.UI.Pages"
        Title="Browse Mods"
        Width="960" Height="720"
        MinWidth="700" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BrushAppBackground}">
    <Grid>
        <!-- Reuse the existing ModsPage directly — it is a UserControl -->
        <pages:ModsPage x:Name="ModsPageControl"/>
    </Grid>
</Window>
