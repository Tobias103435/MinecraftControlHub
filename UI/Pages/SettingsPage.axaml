<UserControl x:Class="MinecraftControlHub.UI.Pages.SettingsPage"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:viewmodels="clr-namespace:MinecraftControlHub.UI.ViewModels"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="700">

    <Grid ColumnDefinitions="240,*">

        <!-- ═══════════════ SIDEBAR ═══════════════ -->
        <Border Grid.Column="0"
                Background="{DynamicResource BrushSidebarBackground}"
                BorderBrush="{DynamicResource BrushBorder}"
                BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Header + Search -->
                <StackPanel DockPanel.Dock="Top" Margin="16,20,16,0">
                    <TextBlock Text="Settings"
                               FontFamily="{StaticResource FontDisplay}"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource BrushTextPrimary}"
                               Margin="4,0,0,16"/>

                    <!-- Search bar -->
                    <Border Background="{DynamicResource BrushPanelBackground}"
                            BorderBrush="{DynamicResource BrushBorder}"
                            BorderThickness="1" CornerRadius="8"
                            Padding="12,8" Margin="0,0,0,20">
                        <Grid ColumnDefinitions="Auto,*">
                            <TextBlock Grid.Column="0" Text="&#x1F50D;" FontSize="13"
                                       Foreground="{DynamicResource BrushTextMuted}"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox x:Name="SearchBox" Grid.Column="1"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="{DynamicResource BrushTextPrimary}"
                                     FontFamily="{StaticResource FontBody}" FontSize="13"
                                     VerticalAlignment="Center" CaretBrush="{DynamicResource BrushTextPrimary}"
                                     TextChanged="SearchBox_TextChanged"/>
                            <TextBlock Grid.Column="1" Text="Search settings..."
                                       FontFamily="{StaticResource FontBody}" FontSize="13"
                                       Foreground="{DynamicResource BrushTextMuted}"
                                       VerticalAlignment="Center" IsHitTestVisible="False"
                                       x:Name="SearchPlaceholder"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- Ko-fi support banner — DockPanel.Dock="Bottom" moet vóór de fill-child staan -->
                <Border DockPanel.Dock="Bottom"
                        Margin="16,12,16,16"
                        Background="{DynamicResource BrushPanelBackground}"
                        BorderBrush="{DynamicResource BrushBorder}"
                        BorderThickness="1" CornerRadius="10"
                        Padding="14,12">
                    <StackPanel>
                        <TextBlock Text="☕  Support development"
                                   FontFamily="{StaticResource FontBody}" FontSize="11.5"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource BrushTextPrimary}"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="Nexora Launcher is free. If you like it, a coffee is always appreciated."
                                   FontFamily="{StaticResource FontBody}" FontSize="11"
                                   Foreground="{DynamicResource BrushTextMuted}"
                                   TextWrapping="Wrap" Margin="0,0,0,10"/>
                        <Button Content="Donate on Ko-fi"
                                Theme="{StaticResource SecondaryButtonStyle}"
                                Padding="0,7"
                                HorizontalAlignment="Stretch"
                                Click="KoFi_Click"/>
                    </StackPanel>
                </Border>

                <!-- Navigation items (fill child — must come after all Dock="Bottom" items) -->
                <StackPanel x:Name="NavPanel" Margin="8,0,8,16" ToggleButton.IsCheckedChanged="NavRadio_Checked">
                    <RadioButton x:Name="NavAccount" GroupName="SettingsNav" Content="Account"
                                 Tag="PageAccount" IsChecked="True"
                                 Theme="{StaticResource NavItemStyle}"/>
                    <RadioButton x:Name="NavJava" GroupName="SettingsNav" Content="Java &amp; Performance"
                                 Tag="PageJava"
                                 Theme="{StaticResource NavItemStyle}"/>
                    <RadioButton x:Name="NavLaunch" GroupName="SettingsNav" Content="Launch Options"
                                 Tag="PageLaunch"
                                 Theme="{StaticResource NavItemStyle}"/>
                    <RadioButton x:Name="NavMods" GroupName="SettingsNav" Content="Mod Updates"
                                 Tag="PageMods"
                                 Theme="{StaticResource NavItemStyle}"/>
                    <RadioButton x:Name="NavTunnel" GroupName="SettingsNav" Content="Network &amp; Tunnels"
                                 Tag="PageTunnel"
                                 Theme="{StaticResource NavItemStyle}"/>
                    <RadioButton x:Name="NavAi" GroupName="SettingsNav" Content="AI Terminal"
                                 Tag="PageAi"
                                 Theme="{StaticResource NavItemStyle}"/>
                    <RadioButton x:Name="NavAppearance" GroupName="SettingsNav" Content="Appearance"
                                 Tag="PageAppearance"
                                 Theme="{StaticResource NavItemStyle}"/>
                    <RadioButton x:Name="NavStorage" GroupName="SettingsNav" Content="Storage &amp; Data"
                                 Tag="PageStorage"
                                 Theme="{StaticResource NavItemStyle}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══════════════ CONTENT PAGES ═══════════════ -->
        <Grid Grid.Column="1" Background="{DynamicResource BrushAppBackground}">

            <!-- Status banner (floats at top of every page) -->
            <Border Background="{DynamicResource BrushInfoBg}"
                    BorderBrush="{DynamicResource BrushInfoText}"
                    BorderThickness="0,0,0,1"
                    Padding="24,12"
                    VerticalAlignment="Top" ZIndex="10"
                    IsVisible="{Binding HasStatus}">
                <TextBlock Text="{Binding StatusMessage}"
                           FontFamily="{StaticResource FontBody}" FontSize="13"
                           Foreground="{DynamicResource BrushInfoText}" TextWrapping="Wrap"/>
            </Border>

            <!-- ═══ PAGE: Account ═══ -->
            <ScrollViewer x:Name="PageAccount" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="40,32,40,40" MaxWidth="640">
                    <TextBlock Text="Account" FontFamily="{StaticResource FontDisplay}" FontSize="24"
                               Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,8"/>
                    <TextBlock Text="Manage your Nexora and Microsoft accounts."
                               FontFamily="{StaticResource FontBody}" FontSize="13"
                               Foreground="{DynamicResource BrushTextSecondary}" Margin="0,0,0,28"/>

                    <!-- Nexora -->
                    <Border Background="{DynamicResource BrushPanelBackground}" CornerRadius="12" Padding="24" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Nexora" FontFamily="{StaticResource FontDisplay}" FontSize="15"
                                       Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,4"/>
                            <TextBlock Text="Social features, friends, instance sharing."
                                       FontFamily="{StaticResource FontBody}" FontSize="12"
                                       Foreground="{DynamicResource BrushTextMuted}" Margin="0,0,0,16"/>

                            <StackPanel IsVisible="{Binding IsNexoraLoggedOut}">
                                <Button Content="Log in to Nexora" Theme="{StaticResource PrimaryButtonStyle}"
                                        Padding="20,10" HorizontalAlignment="Left" Click="NexoraLogin_Click"/>
                            </StackPanel>

                            <StackPanel IsVisible="{Binding IsNexoraLoggedIn}">
                                <Grid Margin="0,0,0,16" ColumnDefinitions="Auto,*">
                                    <Border Width="44" Height="44" CornerRadius="22"
                                            Background="{DynamicResource BrushAccent}" Margin="0,0,14,0">
                                        <TextBlock Text="{Binding NexoraUsernameInitial}"
                                                   FontFamily="{StaticResource FontDisplay}" FontSize="18"
                                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding NexoraUsername}"
                                                   FontFamily="{StaticResource FontBody}" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource BrushTextPrimary}"/>
                                        <TextBlock FontFamily="{StaticResource FontBody}" FontSize="12"
                                                   Foreground="{DynamicResource BrushTextSecondary}"
                                                   IsVisible="{Binding IsMinecraftLinked}">
                                            <Run Text="Minecraft: "/><Run Text="{Binding MinecraftUsername, Mode=OneWay}" FontWeight="SemiBold"/>
                                        </TextBlock>
                                        <TextBlock Text="No Minecraft account linked"
                                                   FontFamily="{StaticResource FontBody}" FontSize="12"
                                                   Foreground="{DynamicResource BrushTextMuted}"
                                                   IsVisible="{Binding !IsMinecraftLinked}"/>
                                    </StackPanel>
                                </Grid>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Unlink Minecraft" Theme="{StaticResource SecondaryButtonStyle}"
                                            Padding="14,8" Margin="0,0,8,0"
                                            IsVisible="{Binding IsMinecraftLinked}"
                                            Click="NexoraUnlink_Click"/>
                                    <Button Content="Account Settings" Theme="{StaticResource SecondaryButtonStyle}"
                                            Padding="14,8" Margin="0,0,8,0" Click="NexoraSettings_Click"/>
                                    <Button Content="Log out" Theme="{StaticResource DangerButtonStyle}"
                                            Padding="14,8" Click="NexoraLogout_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Microsoft -->
                    <Border Background="{DynamicResource BrushPanelBackground}" CornerRadius="12" Padding="24" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Microsoft" FontFamily="{StaticResource FontDisplay}" FontSize="15"
                                       Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,4"/>
                            <TextBlock Text="Required for premium/online servers. Without this you play in offline mode."
                                       FontFamily="{StaticResource FontBody}" FontSize="12"
                                       Foreground="{DynamicResource BrushTextMuted}" Margin="0,0,0,16"/>

                            <StackPanel IsVisible="{Binding IsSignedIn}">
                                <TextBlock Margin="0,0,0,12">
                                    <Run Text="Signed in as " Foreground="{DynamicResource BrushTextSecondary}" FontFamily="{StaticResource FontBody}" FontSize="13"/>
                                    <Run Text="{Binding AccountName, Mode=OneWay}" Foreground="{DynamicResource BrushTextPrimary}" FontFamily="{StaticResource FontBody}" FontSize="13" FontWeight="Bold"/>
                                </TextBlock>
                                <Button Content="Sign out" Click="SignOut_Click" Padding="14,8" HorizontalAlignment="Left"/>
                            </StackPanel>

                            <StackPanel IsVisible="{Binding IsSignedOut}">
                                <Button Content="Sign in with Microsoft" Click="SignIn_Click"
                                        Theme="{StaticResource PrimaryButtonStyle}" Padding="20,10" HorizontalAlignment="Left"
                                        IsEnabled="{Binding IsSigningIn, Converter={StaticResource InverseBoolConverter}}"/>
                                <Border Background="{DynamicResource BrushAppBackground}" CornerRadius="8" Padding="16" Margin="0,14,0,0"
                                        IsVisible="{Binding HasDeviceCode}">
                                    <StackPanel>
                                        <TextBlock Text="Enter this code:" FontFamily="{StaticResource FontBody}" FontSize="12"
                                                   Foreground="{DynamicResource BrushTextSecondary}" Margin="0,0,0,8"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding DeviceCode}" FontFamily="{StaticResource FontDisplay}" FontSize="22"
                                                       Foreground="{DynamicResource BrushTextPrimary}" VerticalAlignment="Center"/>
                                            <Button Content="Copy" Click="CopyCode_Click" Padding="12,6" Margin="14,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                            <TextBlock Text="Visit " FontFamily="{StaticResource FontBody}" FontSize="12" Foreground="{DynamicResource BrushTextSecondary}"/>
                                            <TextBlock Text="microsoft.com/link"
                                                       FontFamily="{StaticResource FontBody}" FontSize="12"
                                                       Foreground="{DynamicResource BrushAccent}"
                                                       TextDecorations="Underline" Cursor="Hand"
                                                       Tag="{Binding DeviceVerificationUri}"
                                                       PointerPressed="OpenLink_Click"/>
                                            <TextBlock Text=" and enter the code." FontFamily="{StaticResource FontBody}" FontSize="12" Foreground="{DynamicResource BrushTextSecondary}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <TextBlock Text="{Binding AccountStatus}" FontFamily="{StaticResource FontBody}" FontSize="12"
                                       Foreground="{DynamicResource BrushTextSecondary}" TextWrapping="Wrap" Margin="0,12,0,0"
                                       IsVisible="{Binding HasAccountStatus}"/>
                        </StackPanel>
                    </Border>

                    <!-- Player profile -->
                    <Border Background="{DynamicResource BrushPanelBackground}" CornerRadius="12" Padding="24">
                        <StackPanel>
                            <TextBlock Text="Offline Player Name" FontFamily="{StaticResource FontDisplay}" FontSize="15"
                                       Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,4"/>
                            <TextBlock Text="Used when not signed in with Microsoft (singleplayer / LAN)."
                                       FontFamily="{StaticResource FontBody}" FontSize="12"
                                       Foreground="{DynamicResource BrushTextMuted}" Margin="0,0,0,14"/>
                            <TextBox Text="{Binding OfflineUsername}"
                                     Theme="{StaticResource InputTextBoxStyle}" MaxWidth="280" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- ═══ PAGE: Java & Performance ═══ -->
            <ScrollViewer x:Name="PageJava" VerticalScrollBarVisibility="Auto" IsVisible="False">
                <StackPanel Margin="40,32,40,40" MaxWidth="640">
                    <TextBlock Text="Java &amp; Performance" FontFamily="{StaticResource FontDisplay}" FontSize="24"
                               Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,8"/>
                    <TextBlock Text="Memory allocation and JVM tuning for Minecraft."
                               FontFamily="{StaticResource FontBody}" FontSize="13"
                               Foreground="{DynamicResource BrushTextSecondary}" Margin="0,0,0,28"/>

                    <Border Background="{DynamicResource BrushPanelBackground}" CornerRadius="12" Padding="24">
                        <StackPanel>
                            <!-- Max RAM -->
                            <TextBlock FontFamily="{StaticResource FontBody}" FontSize="13" Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,6">
                                <Run Text="Maximum RAM: "/><Run Text="{Binding MaxRamDisplay, Mode=OneWay}" FontWeight="SemiBold" Foreground="{DynamicResource BrushAccent}"/>
                            </TextBlock>
                            <Slider Minimum="1024" Maximum="16384" TickFrequency="512"
                                    IsSnapToTickEnabled="True" Value="{Binding MaxRamMb, Mode=TwoWay}" Margin="0,0,0,24"/>

                            <!-- Min RAM -->
                            <TextBlock FontFamily="{StaticResource FontBody}" FontSize="13" Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,6">
                                <Run Text="Minimum RAM: "/><Run Text="{Binding MinRamDisplay, Mode=OneWay}" FontWeight="SemiBold" Foreground="{DynamicResource BrushAccent}"/>
                            </TextBlock>
                            <Slider Minimum="256" Maximum="4096" TickFrequency="256"
                                    IsSnapToTickEnabled="True" Value="{Binding MinRamMb, Mode=TwoWay}" Margin="0,0,0,24"/>

                            <!-- JVM args -->
                            <TextBlock Text="Custom JVM Arguments" FontFamily="{StaticResource FontBody}" FontSize="13"
                                       Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding CustomJvmArguments}"
                                     Theme="{StaticResource InputTextBoxStyle}" FontFamily="Consolas"/>
                            <TextBlock Text="Example: -XX:+UseG1GC -XX:MaxGCPauseMillis=50 -Dfml.ignoreInvalidMinecraftCertificates=true"
                                       FontFamily="{StaticResource FontBody}" FontSize="11"
                                       Foreground="{DynamicResource BrushTextMuted}" TextWrapping="Wrap" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- ═══ PAGE: Launch Options ═══ -->
            <ScrollViewer x:Name="PageLaunch" VerticalScrollBarVisibility="Auto" IsVisible="False">
                <StackPanel Margin="40,32,40,40" MaxWidth="640">
                    <TextBlock Text="Launch Options" FontFamily="{StaticResource FontDisplay}" FontSize="24"
                               Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,8"/>
                    <TextBlock Text="Control launcher behavior and game window settings."
                               FontFamily="{StaticResource FontBody}" FontSize="13"
                               Foreground="{DynamicResource BrushTextSecondary}" Margin="0,0,0,28"/>

                    <Border Background="{DynamicResource BrushPanelBackground}" CornerRadius="12" Padding="24">
                        <StackPanel>
                            <CheckBox Content="Close launcher when game starts"
                                      IsChecked="{Binding CloseLauncherOnGameStart}"
                                      Foreground="{DynamicResource BrushTextPrimary}"
                                      FontFamily="{StaticResource FontBody}" FontSize="13" Margin="0,0,0,20"/>

                            <TextBlock Text="Game Window Resolution" FontFamily="{StaticResource FontBody}" FontSize="13"
                                       Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,4"/>
                            <TextBlock Text="Set to 0 for default system resolution."
                                       FontFamily="{StaticResource FontBody}" FontSize="11"
                                       Foreground="{DynamicResource BrushTextMuted}" Margin="0,0,0,10"/>
                            <StackPanel Orientation="Horizontal">
                                <StackPanel>
                                    <TextBlock Text="Width" FontFamily="{StaticResource FontBody}" FontSize="11"
                                               Foreground="{DynamicResource BrushTextSecondary}" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding GameWindowWidth}"
                                             Theme="{StaticResource InputTextBoxStyle}" Width="100" Height="36"/>
                                </StackPanel>
                                <TextBlock Text="x" VerticalAlignment="Bottom" Margin="12,0,12,10"
                                           Foreground="{DynamicResource BrushTextMuted}" FontSize="14"/>
                                <StackPanel>
                                    <TextBlock Text="Height" FontFamily="{StaticResource FontBody}" FontSize="11"
                                               Foreground="{DynamicResource BrushTextSecondary}" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding GameWindowHeight}"
                                             Theme="{StaticResource InputTextBoxStyle}" Width="100" Height="36"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- ═══ PAGE: Mod Updates ═══ -->
            <ScrollViewer x:Name="PageMods" VerticalScrollBarVisibility="Auto" IsVisible="False">
                <StackPanel Margin="40,32,40,40" MaxWidth="640">
                    <TextBlock Text="Mod Updates" FontFamily="{StaticResource FontDisplay}" FontSize="24"
                               Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,8"/>
                    <TextBlock Text="Configure automatic mod updating behavior."
                               FontFamily="{StaticResource FontBody}" FontSize="13"
                               Foreground="{DynamicResource BrushTextSecondary}" Margin="0,0,0,28"/>

                    <Border Background="{DynamicResource BrushPanelBackground}" CornerRadius="12" Padding="24">
                        <StackPanel>
                            <CheckBox Content="Automatically update mods when checking" IsChecked="{Binding AutoUpdateMods}"
                                      Foreground="{DynamicResource BrushTextPrimary}" FontFamily="{StaticResource FontBody}" FontSize="13" Margin="0,0,0,14"/>
                            <CheckBox Content="Check for mod updates on startup" IsChecked="{Binding CheckForUpdatesOnStartup}"
                                      Foreground="{DynamicResource BrushTextPrimary}" FontFamily="{StaticResource FontBody}" FontSize="13" Margin="0,0,0,14"/>
                            <CheckBox Content="Keep a backup of replaced mod files" IsChecked="{Binding KeepModsBackup}"
                                      Foreground="{DynamicResource BrushTextPrimary}" FontFamily="{StaticResource FontBody}" FontSize="13" Margin="0,0,0,14"/>
                            <CheckBox Content="Notify when updates are available" IsChecked="{Binding NotifyOnModUpdates}"
                                      Foreground="{DynamicResource BrushTextPrimary}" FontFamily="{StaticResource FontBody}" FontSize="13" Margin="0,0,0,20"/>

                            <Button Content="Check for updates now" Theme="{StaticResource PrimaryButtonStyle}"
                                    Padding="20,10" HorizontalAlignment="Left"
                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                                    Click="CheckUpdates_Click"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- ═══ PAGE: Network & Tunnels ═══ -->
            <ScrollViewer x:Name="PageTunnel" VerticalScrollBarVisibility="Auto" IsVisible="False">
                <StackPanel Margin="40,32,40,40" MaxWidth="640">
                    <TextBlock Text="Network &amp; Tunnels" FontFamily="{StaticResource FontDisplay}" FontSize="24"
                               Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,8"/>
                    <TextBlock Text="Configure tunnel providers for exposing your server."
                               FontFamily="{StaticResource FontBody}" FontSize="13"
                               Foreground="{DynamicResource BrushTextSecondary}" Margin="0,0,0,28"/>

                    <Border Background="{DynamicResource BrushPanelBackground}" CornerRadius="12" Padding="24">
                        <StackPanel>
                            <Border Background="{DynamicResource BrushPanelElevated}" BorderBrush="{DynamicResource BrushAccent}"
                                    BorderThickness="1" CornerRadius="8" Padding="14,10" Margin="0,0,0,20">
                                <TextBlock FontFamily="{StaticResource FontBody}" FontSize="12"
                                           Foreground="{DynamicResource BrushTextSecondary}" TextWrapping="Wrap">
                                    <Run Text="API keys required for " Foreground="{DynamicResource BrushTextSecondary}"/><Run Text="ngrok" FontWeight="SemiBold" Foreground="{DynamicResource BrushAccent}"/><Run Text=" and "/><Run Text="frp" FontWeight="SemiBold" Foreground="{DynamicResource BrushAccent}"/><Run Text=". Leave exe path empty if already on system PATH."/>
                                </TextBlock>
                            </Border>

                            <!-- playit -->
                            <TextBlock Text="playit.gg" FontFamily="{StaticResource FontDisplay}" FontSize="14"
                                       Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,2"/>
                            <TextBlock Text="Free, no key needed" FontFamily="{StaticResource FontBody}" FontSize="11"
                                       Foreground="{DynamicResource BrushTextMuted}" Margin="0,0,0,8"/>
                            <Grid Margin="0,0,0,20" ColumnDefinitions="*,Auto">
                                <TextBox Grid.Column="0" Text="{Binding PlayitExePath}"
                                         Theme="{StaticResource InputTextBoxStyle}" Height="36" FontSize="13"/>
                                <Button Grid.Column="1" Content="Browse" Tag="playit" Click="BrowseExe_Click"
                                        Theme="{StaticResource SecondaryButtonStyle}" Padding="12,0" Height="36" Margin="8,0,0,0"/>
                            </Grid>

                            <!-- ngrok -->
                            <TextBlock Text="ngrok" FontFamily="{StaticResource FontDisplay}" FontSize="14"
                                       Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,2"/>
                            <TextBlock Text="Requires authtoken from ngrok.com" FontFamily="{StaticResource FontBody}" FontSize="11"
                                       Foreground="{DynamicResource BrushTextMuted}" Margin="0,0,0,8"/>
                            <Grid Margin="0,0,0,8" ColumnDefinitions="*,Auto">
                                <TextBox Grid.Column="0" Text="{Binding NgrokExePath}"
                                         Theme="{StaticResource InputTextBoxStyle}" Height="36" FontSize="13"/>
                                <Button Grid.Column="1" Content="Browse" Tag="ngrok" Click="BrowseExe_Click"
                                        Theme="{StaticResource SecondaryButtonStyle}" Padding="12,0" Height="36" Margin="8,0,0,0"/>
                            </Grid>
                            <TextBox x:Name="NgrokApiKeyBox" Theme="{StaticResource InputPasswordBoxStyle}"
                                     PasswordChar="●"
                                     Height="36" FontSize="13" Margin="0,0,0,20" TextChanged="NgrokApiKey_Changed"/>

                            <!-- bore -->
                            <TextBlock Text="bore.pub" FontFamily="{StaticResource FontDisplay}" FontSize="14"
                                       Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,2"/>
                            <TextBlock Text="Free, no signup" FontFamily="{StaticResource FontBody}" FontSize="11"
                                       Foreground="{DynamicResource BrushTextMuted}" Margin="0,0,0,8"/>
                            <Grid Margin="0,0,0,20" ColumnDefinitions="*,Auto">
                                <TextBox Grid.Column="0" Text="{Binding BoreExePath}"
                                         Theme="{StaticResource InputTextBoxStyle}" Height="36" FontSize="13"/>
                                <Button Grid.Column="1" Content="Browse" Tag="bore" Click="BrowseExe_Click"
                                        Theme="{StaticResource SecondaryButtonStyle}" Padding="12,0" Height="36" Margin="8,0,0,0"/>
                            </Grid>

                            <!-- frp -->
                            <TextBlock Text="frp (self-hosted)" FontFamily="{StaticResource FontDisplay}" FontSize="14"
                                       Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,2"/>
                            <TextBlock Text="Requires your own VPS running frps" FontFamily="{StaticResource FontBody}" FontSize="11"
                                       Foreground="{DynamicResource BrushTextMuted}" Margin="0,0,0,8"/>
                            <Grid Margin="0,0,0,8" ColumnDefinitions="*,Auto">
                                <TextBox Grid.Column="0" Text="{Binding FrpExePath}"
                                         Theme="{StaticResource InputTextBoxStyle}" Height="36" FontSize="13"/>
                                <Button Grid.Column="1" Content="Browse" Tag="frp" Click="BrowseExe_Click"
                                        Theme="{StaticResource SecondaryButtonStyle}" Padding="12,0" Height="36" Margin="8,0,0,0"/>
                            </Grid>
                            <TextBox x:Name="FrpApiKeyBox" Theme="{StaticResource InputPasswordBoxStyle}"
                                     PasswordChar="●"
                                     Height="36" FontSize="13" Margin="0,0,0,20" TextChanged="FrpApiKey_Changed"/>

                            <Button Content="Save tunnel settings" Theme="{StaticResource PrimaryButtonStyle}"
                                    Padding="20,10" HorizontalAlignment="Left" Click="SaveTunnelSettings_Click"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- ═══ PAGE: AI Terminal ═══ -->
            <ScrollViewer x:Name="PageAi" VerticalScrollBarVisibility="Auto" IsVisible="False">
                <StackPanel Margin="40,32,40,40" MaxWidth="640">
                    <TextBlock Text="AI Terminal" FontFamily="{StaticResource FontDisplay}" FontSize="24"
                               Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,8"/>
                    <TextBlock Text="Configure the AI that controls the launcher via natural language."
                               FontFamily="{StaticResource FontBody}" FontSize="13"
                               Foreground="{DynamicResource BrushTextSecondary}" Margin="0,0,0,28"/>

                    <Border Background="{DynamicResource BrushPanelBackground}" CornerRadius="12" Padding="24">
                        <StackPanel>
                            <TextBlock Text="Provider" Theme="{StaticResource InputLabelStyle}"/>
                            <ComboBox ItemsSource="{Binding AiProviders}" SelectedItem="{Binding AiProvider, Mode=TwoWay}" Margin="0,0,0,16"/>

                            <TextBlock Text="{Binding AiApiKeyLabel}" Theme="{StaticResource InputLabelStyle}"/>
                            <TextBox x:Name="AiApiKeyBox" Theme="{StaticResource InputPasswordBoxStyle}"
                                     PasswordChar="●"
                                     Margin="0,0,0,16" TextChanged="AiApiKey_Changed"/>

                            <StackPanel IsVisible="{Binding ShowEndpointField}">
                                <TextBlock Text="API Endpoint" Theme="{StaticResource InputLabelStyle}"/>
                                <TextBox Text="{Binding AiApiEndpoint}"
                                         Theme="{StaticResource InputTextBoxStyle}" Margin="0,0,0,16"/>
                            </StackPanel>

                            <TextBlock Text="Model" Theme="{StaticResource InputLabelStyle}"/>
                            <!-- Avalonia's ComboBox has no IsEditable/Text (unlike WPF) —
                                 AutoCompleteBox is the equivalent editable, filterable picker. -->
                            <AutoCompleteBox ItemsSource="{Binding AiModelOptions}"
                                             Text="{Binding AiModel, Mode=TwoWay}"
                                             FilterMode="None" Margin="0,0,0,20"/>

                            <Button Content="Save AI Settings" Theme="{StaticResource PrimaryButtonStyle}"
                                    Padding="20,10" HorizontalAlignment="Left" Click="SaveAiSettings_Click"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- ═══ PAGE: Appearance ═══ -->
            <ScrollViewer x:Name="PageAppearance" VerticalScrollBarVisibility="Auto" IsVisible="False">
                <StackPanel Margin="40,32,40,40" MaxWidth="640">
                    <TextBlock Text="Appearance" FontFamily="{StaticResource FontDisplay}" FontSize="24"
                               Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,8"/>
                    <TextBlock Text="Customize the look and feel of the launcher."
                               FontFamily="{StaticResource FontBody}" FontSize="13"
                               Foreground="{DynamicResource BrushTextSecondary}" Margin="0,0,0,28"/>

                    <Border Background="{DynamicResource BrushPanelBackground}" CornerRadius="12" Padding="24">
                        <StackPanel>
                            <TextBlock Text="Theme" FontFamily="{StaticResource FontDisplay}" FontSize="15"
                                       Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,4"/>
                            <TextBlock Text="Toggle between dark and light mode. Applied instantly."
                                       FontFamily="{StaticResource FontBody}" FontSize="12"
                                       Foreground="{DynamicResource BrushTextMuted}" Margin="0,0,0,16"/>
                            <Button x:Name="ThemeToggleButton" Padding="20,10" HorizontalAlignment="Left"
                                    Theme="{StaticResource SecondaryButtonStyle}" Click="ToggleTheme_Click"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- ═══ PAGE: Storage & Data ═══ -->
            <ScrollViewer x:Name="PageStorage" VerticalScrollBarVisibility="Auto" IsVisible="False">
                <StackPanel Margin="40,32,40,40" MaxWidth="640">
                    <TextBlock Text="Storage &amp; Data" FontFamily="{StaticResource FontDisplay}" FontSize="24"
                               Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,8"/>
                    <TextBlock Text="Manage files, logs, and reset the application."
                               FontFamily="{StaticResource FontBody}" FontSize="13"
                               Foreground="{DynamicResource BrushTextSecondary}" Margin="0,0,0,28"/>

                    <Border Background="{DynamicResource BrushPanelBackground}" CornerRadius="12" Padding="24" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Quick Access" FontFamily="{StaticResource FontDisplay}" FontSize="15"
                                       Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,4"/>
                            <TextBlock Text="Open folders and logs directly."
                                       FontFamily="{StaticResource FontBody}" FontSize="12"
                                       Foreground="{DynamicResource BrushTextMuted}" Margin="0,0,0,16"/>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Data folder" Theme="{StaticResource SecondaryButtonStyle}"
                                        Padding="16,10" Margin="0,0,10,0" Click="OpenDataFolder_Click"/>
                                <Button Content="Diagnostics log" Theme="{StaticResource SecondaryButtonStyle}"
                                        Padding="16,10" Click="OpenDiagnosticsLog_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource BrushPanelBackground}" CornerRadius="12" Padding="24"
                            BorderBrush="{DynamicResource BrushDanger}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Danger Zone" FontFamily="{StaticResource FontDisplay}" FontSize="15"
                                       Foreground="{DynamicResource BrushDanger}" Margin="0,0,0,4"/>
                            <TextBlock Text="This permanently deletes all data and restarts the app."
                                       FontFamily="{StaticResource FontBody}" FontSize="12"
                                       Foreground="{DynamicResource BrushTextMuted}" Margin="0,0,0,16"/>
                            <Button Content="Reset Minecraft Control Hub" Theme="{StaticResource DangerButtonStyle}"
                                    Padding="20,10" HorizontalAlignment="Left" Click="ClearCache_Click"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
