<UserControl x:Class="MinecraftControlHub.UI.Pages.ServersPage"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewmodels="clr-namespace:MinecraftControlHub.UI.ViewModels"
             xmlns:converters="clr-namespace:MinecraftControlHub.UI.Converters">

    <UserControl.Resources>
        <ControlTheme x:Key="ServerCardStyle" TargetType="Border" BasedOn="{StaticResource InstallationCardStyle}">
            <Setter Property="Width" Value="NaN"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </ControlTheme>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalContentAlignment="Stretch">
            <StackPanel Margin="32,24,32,32" HorizontalAlignment="Stretch">
                <Grid Margin="0,0,0,24">
                    <TextBlock Text="Servers"
                               FontFamily="{DynamicResource FontDisplay}"
                               FontSize="24"
                               Foreground="{DynamicResource BrushTextPrimary}"/>
                    <Button Content="+ New Server"
                            Theme="{StaticResource PrimaryButtonStyle}"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Padding="20,8"
                            Click="NewServer_Click"/>
                </Grid>

                <!-- Creation Wizard -->
                <Border Background="{DynamicResource BrushPanelBackground}"
                        BorderBrush="{DynamicResource BrushBorder}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="24"
                        Margin="0,0,0,24"
                        IsVisible="{Binding IsWizardVisible}">
                    <StackPanel>
                        <TextBlock Text="{Binding WizardStepTitle}"
                                   FontFamily="{DynamicResource FontDisplay}"
                                   FontSize="18"
                                   Foreground="{DynamicResource BrushTextPrimary}"
                                   Margin="0,0,0,20"/>

                        <!-- Step 1: Name -->
                        <StackPanel IsVisible="{Binding IsWizardStep1}">
                            <TextBlock Text="Choose a name for your server."
                                       FontFamily="{DynamicResource FontBody}"
                                       FontSize="13"
                                       Foreground="{DynamicResource BrushTextSecondary}"
                                       Margin="0,0,0,12"/>
                            <TextBox Text="{Binding NewServerName, Mode=TwoWay}"
                                     Padding="12"
                                     FontSize="14"
                                     Background="{DynamicResource BrushAppBackground}"
                                     BorderBrush="{DynamicResource BrushBorder}"
                                     BorderThickness="1"
                                     Foreground="{DynamicResource BrushTextPrimary}"/>
                        </StackPanel>

                        <!-- Step 2: Type -->
                        <StackPanel IsVisible="{Binding IsWizardStep2}">
                            <TextBlock Text="Select the server software type."
                                       FontFamily="{DynamicResource FontBody}"
                                       FontSize="13"
                                       Foreground="{DynamicResource BrushTextSecondary}"
                                       Margin="0,0,0,12"/>
                            <ComboBox ItemsSource="{Binding ServerTypes}"
                                      SelectedItem="{Binding NewServerType}"
                                      Padding="12"/>
                        </StackPanel>

                        <!-- Step 3: Version -->
                        <StackPanel IsVisible="{Binding IsWizardStep3}">
                            <TextBlock Text="Select the Minecraft version."
                                       FontFamily="{DynamicResource FontBody}"
                                       FontSize="13"
                                       Foreground="{DynamicResource BrushTextSecondary}"
                                       Margin="0,0,0,12"/>
                            <AutoCompleteBox ItemsSource="{Binding AvailableServerVersions}"
                                             Text="{Binding NewServerVersion, Mode=TwoWay}"
                                             Padding="12"
                                             FontSize="14"
                                             Margin="0,0,0,12"/>

                            <!-- Java version advice -->
                            <Border Background="{DynamicResource BrushPanelElevated}"
                                    BorderBrush="{DynamicResource BrushBorder}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12,10"
                                    IsVisible="{Binding HasJavaAdvice}">
                                <StackPanel>
                                    <TextBlock Text="Java requirement"
                                               FontFamily="{DynamicResource FontBody}"
                                               FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource BrushTextSecondary}"
                                               Margin="0,0,0,3"/>
                                    <TextBlock Text="{Binding JavaAdvice}"
                                               FontFamily="{DynamicResource FontBody}"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource BrushTextPrimary}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Step 4: RAM -->
                        <StackPanel IsVisible="{Binding IsWizardStep4}">
                            <TextBlock Text="How much RAM should the server use? (MB)"
                                       FontFamily="{DynamicResource FontBody}"
                                       FontSize="13"
                                       Foreground="{DynamicResource BrushTextSecondary}"
                                       Margin="0,0,0,12"/>
                            <TextBox Text="{Binding NewServerMaxMemory, Mode=TwoWay}"
                                     Padding="12"
                                     FontSize="14"
                                     Background="{DynamicResource BrushAppBackground}"
                                     BorderBrush="{DynamicResource BrushBorder}"
                                     BorderThickness="1"
                                     Foreground="{DynamicResource BrushTextPrimary}"
                                     Margin="0,0,0,12"/>
                            <TextBlock Text="{Binding RamSuggestionText}"
                                       FontFamily="{DynamicResource FontBody}"
                                       FontSize="12"
                                       Foreground="{DynamicResource BrushTextSecondary}"
                                       TextWrapping="Wrap"
                                       IsVisible="{Binding HasRamSuggestion}"/>
                        </StackPanel>

                        <!-- Step 5: Account mode -->
                        <StackPanel IsVisible="{Binding IsWizardStep5}">
                            <TextBlock Text="Choose how players can connect."
                                       FontFamily="{DynamicResource FontBody}"
                                       FontSize="13"
                                       Foreground="{DynamicResource BrushTextSecondary}"
                                       Margin="0,0,0,12"/>
                            <ComboBox ItemsSource="{Binding ServerAccountModes}"
                                      SelectedItem="{Binding NewServerAccountMode}"
                                      Padding="12"/>
                            <TextBlock Text="The server folder, EULA, settings and start files will be automatically set up afterwards."
                                       FontFamily="{DynamicResource FontBody}"
                                       FontSize="12"
                                       Foreground="{DynamicResource BrushTextMuted}"
                                       Margin="0,12,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- Step 6: Review & Create -->
                        <StackPanel IsVisible="{Binding IsWizardStep6}">
                            <TextBlock Text="Review your settings and create the server."
                                       FontFamily="{DynamicResource FontBody}"
                                       FontSize="13"
                                       Foreground="{DynamicResource BrushTextSecondary}"
                                       Margin="0,0,0,16"/>
                            <Border Background="{DynamicResource BrushAppBackground}"
                                    BorderBrush="{DynamicResource BrushBorder}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="16">
                                <StackPanel>
                                    <TextBlock FontFamily="{DynamicResource FontBody}" FontSize="13" Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,6">
                                        <Run Text="Name: " Foreground="{DynamicResource BrushTextSecondary}"/>
                                        <Run Text="{Binding NewServerName}"/>
                                    </TextBlock>
                                    <TextBlock FontFamily="{DynamicResource FontBody}" FontSize="13" Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,6">
                                        <Run Text="Type: " Foreground="{DynamicResource BrushTextSecondary}"/>
                                        <Run Text="{Binding NewServerType}"/>
                                    </TextBlock>
                                    <TextBlock FontFamily="{DynamicResource FontBody}" FontSize="13" Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,6">
                                        <Run Text="Version: " Foreground="{DynamicResource BrushTextSecondary}"/>
                                        <Run Text="{Binding NewServerVersion}"/>
                                    </TextBlock>
                                    <TextBlock FontFamily="{DynamicResource FontBody}" FontSize="13" Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,6">
                                        <Run Text="RAM: " Foreground="{DynamicResource BrushTextSecondary}"/>
                                        <Run Text="{Binding NewServerMaxMemory}"/>
                                        <Run Text=" MB"/>
                                    </TextBlock>
                                    <TextBlock FontFamily="{DynamicResource FontBody}" FontSize="13" Foreground="{DynamicResource BrushTextPrimary}">
                                        <Run Text="Account mode: " Foreground="{DynamicResource BrushTextSecondary}"/>
                                        <Run Text="{Binding NewServerAccountMode}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- Java version info in review -->
                            <Border Background="{DynamicResource BrushPanelElevated}"
                                    BorderBrush="{DynamicResource BrushBorder}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12,10"
                                    Margin="0,12,0,0"
                                    IsVisible="{Binding HasJavaAdvice}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Java required: "
                                               FontFamily="{DynamicResource FontBody}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource BrushTextSecondary}"/>
                                    <TextBlock Text="{Binding JavaAdvice}"
                                               FontFamily="{DynamicResource FontBody}"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource BrushTextPrimary}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <TextBlock Text="{Binding CreationError}"
                                   FontFamily="{DynamicResource FontBody}"
                                   FontSize="12"
                                   Foreground="{DynamicResource BrushDanger}"
                                   Margin="0,16,0,0"
                                   TextWrapping="Wrap"
                                   IsVisible="{Binding CreationError, Converter={StaticResource NullToVisibilityConverter}}"/>

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Margin="0,24,0,0">
                            <Button Content="Cancel"
                                    Theme="{StaticResource SecondaryButtonStyle}"
                                    Margin="0,0,8,0"
                                    Click="CancelWizard_Click"/>
                            <Button Content="Back"
                                    Theme="{StaticResource SecondaryButtonStyle}"
                                    Margin="0,0,8,0"
                                    IsEnabled="{Binding CanGoBack}"
                                    Click="BackWizard_Click"/>
                            <Button Content="Next"
                                    Theme="{StaticResource PrimaryButtonStyle}"
                                    Margin="0,0,8,0"
                                    IsEnabled="{Binding CanGoNext}"
                                    IsVisible="{Binding IsWizardStep6, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                    Click="NextWizard_Click"/>
                            <Button Content="Create Server"
                                    Theme="{StaticResource PrimaryButtonStyle}"
                                    IsVisible="{Binding IsWizardStep6}"
                                    IsEnabled="{Binding IsCreatingServer, Converter={StaticResource InverseBoolConverter}}"
                                    Click="CreateServer_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Empty State -->
                <Border Background="{DynamicResource BrushPanelBackground}"
                        BorderBrush="{DynamicResource BrushBorder}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="48"
                        Margin="0,0,0,24"
                        IsVisible="{Binding HasServers, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="No servers yet"
                                   FontFamily="{DynamicResource FontDisplay}"
                                   FontSize="18"
                                   Foreground="{DynamicResource BrushTextPrimary}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="Create your first Minecraft server with the wizard."
                                   FontFamily="{DynamicResource FontBody}"
                                   FontSize="13"
                                   Foreground="{DynamicResource BrushTextSecondary}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Servers List -->
                <ItemsControl ItemsSource="{Binding Servers}"
                              IsVisible="{Binding HasServers}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Theme="{StaticResource ServerCardStyle}">
                                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto">

                                    <!-- Header row: name + status badge -->
                                    <Grid Grid.Row="0" Margin="0,0,0,10" ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Name}"
                                                   FontFamily="{DynamicResource FontDisplay}"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource BrushTextPrimary}"
                                                   VerticalAlignment="Center"/>
                                        <!-- Status pill badge -->
                                        <Border Grid.Column="1"
                                                CornerRadius="10"
                                                Padding="10,3"
                                                Background="{DynamicResource BrushPanelElevated}"
                                                VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="7" Height="7"
                                                         Fill="{Binding StatusDotBrush}"
                                                         VerticalAlignment="Center"
                                                         Margin="0,0,6,0"/>
                                                <TextBlock Text="{Binding Status}"
                                                           FontFamily="{DynamicResource FontBody}"
                                                           FontSize="11"
                                                           Foreground="{Binding StatusTextBrush}"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <!-- Meta info row -->
                                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                                        <Border Background="{DynamicResource BrushPanelElevated}"
                                                CornerRadius="6" Padding="8,3" Margin="0,0,8,0">
                                            <TextBlock FontFamily="{DynamicResource FontBody}" FontSize="11"
                                                       Foreground="{DynamicResource BrushTextSecondary}">
                                                <Run Text="{Binding Type}"/>
                                            </TextBlock>
                                        </Border>
                                        <Border Background="{DynamicResource BrushPanelElevated}"
                                                CornerRadius="6" Padding="8,3" Margin="0,0,8,0">
                                            <TextBlock Text="{Binding MinecraftVersion}"
                                                       FontFamily="{DynamicResource FontBody}" FontSize="11"
                                                       Foreground="{DynamicResource BrushTextSecondary}"/>
                                        </Border>
                                        <Border Background="{DynamicResource BrushPanelElevated}"
                                                CornerRadius="6" Padding="8,3">
                                            <TextBlock FontFamily="{DynamicResource FontBody}" FontSize="11"
                                                       Foreground="{DynamicResource BrushTextSecondary}">
                                                <Run Text="👥 "/>
                                                <Run Text="{Binding CurrentPlayers}"/>
                                                <Run Text=" / "/>
                                                <Run Text="{Binding MaxPlayers}"/>
                                            </TextBlock>
                                        </Border>
                                    </StackPanel>

                                    <!-- Provisioning progress (jar download in background) -->
                                    <StackPanel Grid.Row="2"
                                                Margin="0,0,0,10"
                                                IsVisible="{Binding ProvisioningPanelVisible}">
                                        <TextBlock Text="Downloading server files…"
                                                   FontFamily="{DynamicResource FontBody}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource BrushAccent}"
                                                   Margin="0,0,0,5"/>
                                        <ProgressBar IsIndeterminate="True"
                                                     Height="4"
                                                     Background="{DynamicResource BrushPanelElevated}"
                                                     Foreground="{DynamicResource BrushAccent}"
                                                     BorderThickness="0"/>
                                    </StackPanel>

                                    <!-- Progress bar (server load while running) -->
                                    <ProgressBar Grid.Row="3"
                                                 Theme="{StaticResource ServerProgressBarStyle}"
                                                 Value="{Binding LoadPercent}"
                                                 Maximum="100"
                                                 Margin="0,0,0,14"/>

                                    <!-- Action buttons -->
                                    <WrapPanel Grid.Row="4">
                                        <Button Content="{Binding StartButtonContent}"
                                                Theme="{StaticResource PrimaryButtonStyle}"
                                                Padding="16,7" Margin="0,0,8,0"
                                                IsVisible="{Binding StartButtonVisible}"
                                                IsEnabled="{Binding StartButtonEnabled}"
                                                Click="StartServer_Click"/>
                                        <Button Content="{Binding StopButtonContent}"
                                                Theme="{StaticResource SecondaryButtonStyle}"
                                                Padding="16,7" Margin="0,0,8,0"
                                                IsVisible="{Binding StopButtonVisible}"
                                                IsEnabled="{Binding StopButtonEnabled}"
                                                Click="StopServer_Click"/>
                                        <Button Content="↺  Restart"
                                                Theme="{StaticResource SecondaryButtonStyle}"
                                                Padding="16,7" Margin="0,0,8,0"
                                                IsVisible="{Binding RestartButtonVisible}"
                                                IsEnabled="{Binding RestartButtonEnabled}"
                                                Click="RestartServer_Click"/>
                                        <Button Content="Open"
                                                Theme="{StaticResource SecondaryButtonStyle}"
                                                Padding="16,7" Margin="0,0,8,0"
                                                ToolTip.Tip="Open server (console, logs, settings)"
                                                Click="PreviewServer_Click"/>
                                        <Button Content="Delete"
                                                Theme="{StaticResource DangerButtonStyle}"
                                                Padding="16,7"
                                                Click="DeleteServer_Click"/>
                                    </WrapPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
