<UserControl x:Class="MinecraftControlHub.UI.Pages.ServersPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:viewmodels="clr-namespace:MinecraftControlHub.UI.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="500"
             d:DataContext="{d:DesignInstance viewmodels:ServersPageViewModel}">
    <UserControl.Resources>
        <Style x:Key="ServerCardStyle" TargetType="Border" BasedOn="{StaticResource InstallationCardStyle}">
            <Setter Property="Width" Value="Auto"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalContentAlignment="Stretch">
            <StackPanel Margin="32,24,32,32" HorizontalAlignment="Stretch">
                <Grid Margin="0,0,0,24">
                    <TextBlock Text="Servers"
                               FontFamily="{DynamicResource FontDisplay}"
                               FontSize="24"
                               Foreground="{DynamicResource BrushTextPrimary}"/>
                    <Button Content="+ New Server"
                            Style="{StaticResource PrimaryButtonStyle}"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Padding="20,8"
                            Click="NewServer_Click"/>
                </Grid>

                <!-- Creation Wizard -->
                <Border Background="{DynamicResource BrushPanelBackground}"
                        BorderBrush="{DynamicResource BrushBorder}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="24"
                        Margin="0,0,0,24"
                        Visibility="{Binding IsWizardVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="{Binding WizardStepTitle}"
                                   FontFamily="{DynamicResource FontDisplay}"
                                   FontSize="18"
                                   Foreground="{DynamicResource BrushTextPrimary}"
                                   Margin="0,0,0,20"/>

                        <!-- Step 1: Name -->
                        <StackPanel Visibility="{Binding IsWizardStep1, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="Choose a name for your server."
                                       FontFamily="{DynamicResource FontBody}"
                                       FontSize="13"
                                       Foreground="{DynamicResource BrushTextSecondary}"
                                       Margin="0,0,0,12"/>
                            <TextBox Text="{Binding NewServerName, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="12"
                                     FontSize="14"
                                     Background="{DynamicResource BrushAppBackground}"
                                     BorderBrush="{DynamicResource BrushBorder}"
                                     BorderThickness="1"
                                     Foreground="{DynamicResource BrushTextPrimary}"/>
                        </StackPanel>

                        <!-- Step 2: Type -->
                        <StackPanel Visibility="{Binding IsWizardStep2, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="Select the server software type."
                                       FontFamily="{DynamicResource FontBody}"
                                       FontSize="13"
                                       Foreground="{DynamicResource BrushTextSecondary}"
                                       Margin="0,0,0,12"/>
                            <ComboBox ItemsSource="{Binding ServerTypes}"
                                      SelectedItem="{Binding NewServerType}"
                                      Padding="12"
                                      Background="{DynamicResource BrushAppBackground}"
                                      BorderBrush="{DynamicResource BrushBorder}"
                                      BorderThickness="1"
                                      Foreground="{DynamicResource BrushTextPrimary}"/>
                        </StackPanel>

                        <!-- Step 3: Version -->
                        <StackPanel Visibility="{Binding IsWizardStep3, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="Select the Minecraft version."
                                       FontFamily="{DynamicResource FontBody}"
                                       FontSize="13"
                                       Foreground="{DynamicResource BrushTextSecondary}"
                                       Margin="0,0,0,12"/>
                            <ComboBox
                                ItemsSource="{Binding AvailableServerVersions}"
                                SelectedItem="{Binding NewServerVersion, Mode=TwoWay}"
                                Text="{Binding NewServerVersion, UpdateSourceTrigger=PropertyChanged}"
                                IsEditable="True"
                                Padding="12"
                                FontSize="14"
                                Background="{DynamicResource BrushAppBackground}"
                                BorderBrush="{DynamicResource BrushBorder}"
                                BorderThickness="1"
                                Foreground="{DynamicResource BrushTextPrimary}"
                                Margin="0,0,0,12"/>

                            <!-- Java version advice (auto-updates when version changes) -->
                            <Border Background="{DynamicResource BrushPanelElevated}"
                                    BorderBrush="{DynamicResource BrushBorder}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12,10"
                                    Visibility="{Binding HasJavaAdvice, Converter={StaticResource BoolToVisibilityConverter}}">
                                <StackPanel>
                                    <TextBlock Text="Java requirement"
                                               FontFamily="{DynamicResource FontBody}"
                                               FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource BrushTextSecondary}"
                                               Margin="0,0,0,3"/>
                                    <TextBlock Text="{Binding JavaAdvice}"
                                               FontFamily="{DynamicResource FontBody}"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource BrushTextPrimary}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Step 4: RAM -->
                        <StackPanel Visibility="{Binding IsWizardStep4, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="How much RAM should the server use? (MB)"
                                       FontFamily="{DynamicResource FontBody}"
                                       FontSize="13"
                                       Foreground="{DynamicResource BrushTextSecondary}"
                                       Margin="0,0,0,12"/>
                            <TextBox Text="{Binding NewServerMaxMemory, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="12"
                                     FontSize="14"
                                     Background="{DynamicResource BrushAppBackground}"
                                     BorderBrush="{DynamicResource BrushBorder}"
                                     BorderThickness="1"
                                     Foreground="{DynamicResource BrushTextPrimary}"
                                     Margin="0,0,0,12"/>
                            <TextBlock Text="{Binding RamSuggestionText}"
                                       FontFamily="{DynamicResource FontBody}"
                                       FontSize="12"
                                       Foreground="{DynamicResource BrushTextSecondary}"
                                       TextWrapping="Wrap"
                                       Visibility="{Binding HasRamSuggestion, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>

                        <!-- Step 5: Account mode -->
                        <StackPanel Visibility="{Binding IsWizardStep5, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="Choose how players can connect."
                                       FontFamily="{DynamicResource FontBody}"
                                       FontSize="13"
                                       Foreground="{DynamicResource BrushTextSecondary}"
                                       Margin="0,0,0,12"/>
                            <ComboBox ItemsSource="{Binding ServerAccountModes}"
                                      SelectedItem="{Binding NewServerAccountMode}"
                                      Padding="12"
                                      Background="{DynamicResource BrushAppBackground}"
                                      BorderBrush="{DynamicResource BrushBorder}"
                                      BorderThickness="1"
                                      Foreground="{DynamicResource BrushTextPrimary}"/>
                            <TextBlock Text="The server folder, EULA, settings and start files will be automatically set up afterwards."
                                       FontFamily="{DynamicResource FontBody}"
                                       FontSize="12"
                                       Foreground="{DynamicResource BrushTextMuted}"
                                       Margin="0,12,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- Step 6: Review & Create -->
                        <StackPanel Visibility="{Binding IsWizardStep6, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="Review your settings and create the server."
                                       FontFamily="{DynamicResource FontBody}"
                                       FontSize="13"
                                       Foreground="{DynamicResource BrushTextSecondary}"
                                       Margin="0,0,0,16"/>
                            <Border Background="{DynamicResource BrushAppBackground}"
                                    BorderBrush="{DynamicResource BrushBorder}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="16">
                                <StackPanel>
                                    <TextBlock FontFamily="{DynamicResource FontBody}" FontSize="13" Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,6">
                                        <Run Text="Name: " Foreground="{DynamicResource BrushTextSecondary}"/>
                                        <Run Text="{Binding NewServerName}"/>
                                    </TextBlock>
                                    <TextBlock FontFamily="{DynamicResource FontBody}" FontSize="13" Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,6">
                                        <Run Text="Type: " Foreground="{DynamicResource BrushTextSecondary}"/>
                                        <Run Text="{Binding NewServerType}"/>
                                    </TextBlock>
                                    <TextBlock FontFamily="{DynamicResource FontBody}" FontSize="13" Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,6">
                                        <Run Text="Version: " Foreground="{DynamicResource BrushTextSecondary}"/>
                                        <Run Text="{Binding NewServerVersion}"/>
                                    </TextBlock>
                                    <TextBlock FontFamily="{DynamicResource FontBody}" FontSize="13" Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,6">
                                        <Run Text="RAM: " Foreground="{DynamicResource BrushTextSecondary}"/>
                                        <Run Text="{Binding NewServerMaxMemory}"/>
                                        <Run Text=" MB"/>
                                    </TextBlock>
                                    <TextBlock FontFamily="{DynamicResource FontBody}" FontSize="13" Foreground="{DynamicResource BrushTextPrimary}">
                                        <Run Text="Account mode: " Foreground="{DynamicResource BrushTextSecondary}"/>
                                        <Run Text="{Binding NewServerAccountMode}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- Java version info in review -->
                            <Border Background="{DynamicResource BrushPanelElevated}"
                                    BorderBrush="{DynamicResource BrushBorder}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12,10"
                                    Margin="0,12,0,0"
                                    Visibility="{Binding HasJavaAdvice, Converter={StaticResource BoolToVisibilityConverter}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Java required: "
                                               FontFamily="{DynamicResource FontBody}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource BrushTextSecondary}"/>
                                    <TextBlock Text="{Binding JavaAdvice}"
                                               FontFamily="{DynamicResource FontBody}"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource BrushTextPrimary}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <TextBlock Text="{Binding CreationError}"
                                   FontFamily="{DynamicResource FontBody}"
                                   FontSize="12"
                                   Foreground="{DynamicResource BrushDanger}"
                                   Margin="0,16,0,0"
                                   TextWrapping="Wrap"
                                   Visibility="{Binding CreationError, Converter={StaticResource NullToVisibilityConverter}}"/>

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Margin="0,24,0,0">
                            <Button Content="Cancel"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="0,0,8,0"
                                    Click="CancelWizard_Click"/>
                            <Button Content="Back"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="0,0,8,0"
                                    IsEnabled="{Binding CanGoBack}"
                                    Click="BackWizard_Click"/>
                            <Button Content="Next"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Margin="0,0,8,0"
                                    IsEnabled="{Binding CanGoNext}"
                                    Visibility="{Binding IsWizardStep6, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                    Click="NextWizard_Click"/>
                            <Button Content="Create Server"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Visibility="{Binding IsWizardStep6, Converter={StaticResource BoolToVisibilityConverter}}"
                                    IsEnabled="{Binding IsCreatingServer, Converter={StaticResource InverseBoolConverter}}"
                                    Click="CreateServer_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Empty State -->
                <Border Background="{DynamicResource BrushPanelBackground}"
                        BorderBrush="{DynamicResource BrushBorder}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="48"
                        Margin="0,0,0,24"
                        Visibility="{Binding HasServers, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="No servers yet"
                                   FontFamily="{DynamicResource FontDisplay}"
                                   FontSize="18"
                                   Foreground="{DynamicResource BrushTextPrimary}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="Create your first Minecraft server with the wizard."
                                   FontFamily="{DynamicResource FontBody}"
                                   FontSize="13"
                                   Foreground="{DynamicResource BrushTextSecondary}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Servers List -->
                <ItemsControl ItemsSource="{Binding Servers}"
                              Visibility="{Binding HasServers, Converter={StaticResource BoolToVisibilityConverter}}"
                              HorizontalContentAlignment="Stretch">
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="HorizontalAlignment" Value="Stretch"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel HorizontalAlignment="Stretch"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource ServerCardStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Header row: name + status badge -->
                                    <Grid Grid.Row="0" Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Name}"
                                                   FontFamily="{DynamicResource FontDisplay}"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource BrushTextPrimary}"
                                                   VerticalAlignment="Center"/>
                                        <!-- Status pill badge -->
                                        <Border Grid.Column="1"
                                                x:Name="StatusBadge"
                                                CornerRadius="10"
                                                Padding="10,3"
                                                Background="{DynamicResource BrushPanelElevated}"
                                                VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse x:Name="StatusDot"
                                                         Width="7" Height="7"
                                                         Fill="{DynamicResource BrushOffline}"
                                                         VerticalAlignment="Center"
                                                         Margin="0,0,6,0"/>
                                                <TextBlock x:Name="StatusLabel"
                                                           Text="{Binding Status}"
                                                           FontFamily="{DynamicResource FontBody}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource BrushTextMuted}"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <!-- Meta info row -->
                                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                                        <Border Background="{DynamicResource BrushPanelElevated}"
                                                CornerRadius="6" Padding="8,3" Margin="0,0,8,0">
                                            <TextBlock FontFamily="{DynamicResource FontBody}" FontSize="11"
                                                       Foreground="{DynamicResource BrushTextSecondary}">
                                                <Run Text="{Binding Type}"/>
                                            </TextBlock>
                                        </Border>
                                        <Border Background="{DynamicResource BrushPanelElevated}"
                                                CornerRadius="6" Padding="8,3" Margin="0,0,8,0">
                                            <TextBlock Text="{Binding MinecraftVersion}"
                                                       FontFamily="{DynamicResource FontBody}" FontSize="11"
                                                       Foreground="{DynamicResource BrushTextSecondary}"/>
                                        </Border>
                                        <Border Background="{DynamicResource BrushPanelElevated}"
                                                CornerRadius="6" Padding="8,3">
                                            <TextBlock FontFamily="{DynamicResource FontBody}" FontSize="11"
                                                       Foreground="{DynamicResource BrushTextSecondary}">
                                                <Run Text="👥 "/>
                                                <Run Text="{Binding CurrentPlayers}"/>
                                                <Run Text=" / "/>
                                                <Run Text="{Binding MaxPlayers}"/>
                                            </TextBlock>
                                        </Border>
                                    </StackPanel>

                                    <!-- Provisioning progress (jar download in background) -->
                                    <StackPanel Grid.Row="2"
                                                x:Name="ProvisioningPanel"
                                                Margin="0,0,0,10"
                                                Visibility="Collapsed">
                                        <TextBlock x:Name="ProvisioningLabel"
                                                   Text="Downloading server files…"
                                                   FontFamily="{DynamicResource FontBody}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource BrushAccent}"
                                                   Margin="0,0,0,5"/>
                                        <ProgressBar IsIndeterminate="True"
                                                     Height="4"
                                                     Background="{DynamicResource BrushPanelElevated}"
                                                     Foreground="{DynamicResource BrushAccent}"
                                                     BorderThickness="0"/>
                                    </StackPanel>

                                    <!-- Progress bar (server load while running) -->
                                    <ProgressBar Grid.Row="3"
                                                 Style="{StaticResource ServerProgressBarStyle}"
                                                 Value="{Binding LoadPercent}"
                                                 Maximum="100"
                                                 Margin="0,0,0,14"/>

                                    <!-- Action buttons -->
                                    <WrapPanel Grid.Row="4">
                                        <Button x:Name="StartBtn" Content="▶  Start"
                                                Style="{StaticResource PrimaryButtonStyle}"
                                                Padding="16,7" Margin="0,0,8,0"
                                                Click="StartServer_Click"/>
                                        <Button x:Name="StopBtn" Content="■  Stop"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Padding="16,7" Margin="0,0,8,0"
                                                Visibility="Collapsed"
                                                Click="StopServer_Click"/>
                                        <Button x:Name="RestartBtn" Content="↺  Restart"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Padding="16,7" Margin="0,0,8,0"
                                                Visibility="Collapsed"
                                                IsEnabled="False"
                                                Click="RestartServer_Click"/>
                                        <Button Content="Open"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Padding="16,7" Margin="0,0,8,0"
                                                ToolTip="Open server (console, logs, settings)"
                                                Click="PreviewServer_Click"/>
                                        <Button Content="Delete"
                                                Style="{StaticResource DangerButtonStyle}"
                                                Padding="16,7"
                                                Click="DeleteServer_Click"/>
                                    </WrapPanel>
                                </Grid>
                            </Border>
                            <DataTemplate.Triggers>
                                <!-- Running state -->
                                <DataTrigger Binding="{Binding Status}" Value="Running">
                                    <Setter TargetName="StartBtn"   Property="Visibility" Value="Collapsed"/>
                                    <Setter TargetName="StopBtn"    Property="Visibility" Value="Visible"/>
                                    <Setter TargetName="RestartBtn" Property="Visibility" Value="Visible"/>
                                    <Setter TargetName="RestartBtn" Property="IsEnabled"  Value="True"/>
                                    <Setter TargetName="StatusDot"  Property="Fill"       Value="{DynamicResource BrushOnline}"/>
                                    <Setter TargetName="StatusLabel" Property="Foreground" Value="{DynamicResource BrushOnline}"/>
                                </DataTrigger>
                                <!-- Stopped state -->
                                <DataTrigger Binding="{Binding Status}" Value="Stopped">
                                    <Setter TargetName="StartBtn"   Property="Visibility" Value="Visible"/>
                                    <Setter TargetName="StopBtn"    Property="Visibility" Value="Collapsed"/>
                                    <Setter TargetName="RestartBtn" Property="Visibility" Value="Collapsed"/>
                                    <Setter TargetName="StatusDot"  Property="Fill"       Value="{DynamicResource BrushOffline}"/>
                                </DataTrigger>
                                <!-- Starting state -->
                                <DataTrigger Binding="{Binding Status}" Value="Starting">
                                    <Setter TargetName="StartBtn"   Property="IsEnabled"  Value="False"/>
                                    <Setter TargetName="StartBtn"   Property="Content"    Value="Starting…"/>
                                    <Setter TargetName="StatusDot"  Property="Fill"       Value="#F0A020"/>
                                    <Setter TargetName="StatusLabel" Property="Foreground" Value="#F0A020"/>
                                </DataTrigger>
                                <!-- Stopping state -->
                                <DataTrigger Binding="{Binding Status}" Value="Stopping">
                                    <Setter TargetName="StopBtn"    Property="IsEnabled"  Value="False"/>
                                    <Setter TargetName="StopBtn"    Property="Content"    Value="Stopping…"/>
                                    <Setter TargetName="StatusDot"  Property="Fill"       Value="#F0A020"/>
                                    <Setter TargetName="StatusLabel" Property="Foreground" Value="#F0A020"/>
                                </DataTrigger>
                                <!-- Provisioning state (jar download in background) -->
                                <DataTrigger Binding="{Binding Status}" Value="Provisioning">
                                    <Setter TargetName="StartBtn"        Property="IsEnabled"  Value="False"/>
                                    <Setter TargetName="StartBtn"        Property="Content"    Value="Downloading…"/>
                                    <Setter TargetName="StatusDot"       Property="Fill"       Value="{DynamicResource BrushAccent}"/>
                                    <Setter TargetName="StatusLabel"     Property="Foreground" Value="{DynamicResource BrushAccent}"/>
                                    <Setter TargetName="ProvisioningPanel" Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
