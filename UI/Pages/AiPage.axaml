<UserControl x:Class="MinecraftControlHub.UI.Pages.AiPage"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewmodels="clr-namespace:MinecraftControlHub.UI.ViewModels"
             xmlns:models="clr-namespace:MinecraftControlHub.AI.Models"
             xmlns:helpers="clr-namespace:MinecraftControlHub.UI.Helpers"
             xmlns:local="clr-namespace:MinecraftControlHub.UI.Pages"
             d:DesignWidth="900" d:DesignHeight="700"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <UserControl.Resources>

        <!-- ── User message template ── -->
        <DataTemplate x:Key="UserMessageTemplate" DataType="models:TerminalMessage">
            <Grid Margin="0,4,0,4">
                <Border HorizontalAlignment="Right"
                        MaxWidth="600"
                        Background="{DynamicResource BrushAccent}"
                        CornerRadius="12,12,2,12"
                        Padding="14,10">
                    <TextBlock Text="{Binding Text}"
                               FontFamily="{DynamicResource FontBody}"
                               FontSize="13.5"
                               Foreground="White"
                               TextWrapping="Wrap"/>
                </Border>
            </Grid>
        </DataTemplate>

        <!-- ── AI message template ── -->
        <DataTemplate x:Key="AIMessageTemplate" DataType="models:TerminalMessage">
            <Grid Margin="0,4,0,4">
                <Grid HorizontalAlignment="Left" MaxWidth="680">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0"
                            Width="28" Height="28"
                            CornerRadius="14"
                            Background="{DynamicResource BrushPanelElevated}"
                            Margin="0,0,10,0"
                            VerticalAlignment="Top">
                        <Canvas Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Polygon Points="8,0 10,6 16,8 10,10 8,16 6,10 0,8 6,6"
                                     Fill="{DynamicResource BrushAccent}"/>
                        </Canvas>
                    </Border>
                    <Border Grid.Column="1"
                            Background="{DynamicResource BrushPanelBackground}"
                            BorderBrush="{DynamicResource BrushBorder}"
                            BorderThickness="1"
                            CornerRadius="2,12,12,12"
                            Padding="14,10">
                        <TextBlock helpers:TextLinkHelper.TextWithLinks="{Binding Text}"
                                   helpers:TextLinkHelper.LinkBrush="{DynamicResource BrushAccent}"
                                   FontFamily="{DynamicResource FontBody}"
                                   FontSize="13.5"
                                   Foreground="{DynamicResource BrushTextPrimary}"
                                   TextWrapping="Wrap"/>
                    </Border>
                </Grid>
            </Grid>
        </DataTemplate>

        <!-- ── Action plan template ── -->
        <DataTemplate x:Key="ActionPlanTemplate" DataType="models:TerminalMessage">
            <Grid Margin="0,8,0,8">
                <Border Background="{DynamicResource BrushPanelElevated}"
                        BorderBrush="{DynamicResource BrushAccent}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="18,14">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Canvas Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,8,0">
                                <Polygon Points="8,0 10,6 16,8 10,10 8,16 6,10 0,8 6,6"
                                         Fill="{DynamicResource BrushAccent}"/>
                            </Canvas>
                            <TextBlock Text="Proposed Action"
                                       FontFamily="{DynamicResource FontDisplay}"
                                       FontSize="13"
                                       Foreground="{DynamicResource BrushAccent}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Compact summary (shown when HasPlanSummary is true) -->
                        <Border Margin="0,0,0,8"
                                IsVisible="{Binding HasPlanSummary}">
                            <StackPanel>
                                <!-- Summary line with expand/collapse toggle -->
                                <Button Click="ToggleExpand_Click"
                                        Cursor="Hand"
                                        HorizontalAlignment="Left"
                                        HorizontalContentAlignment="Left"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="6,6">
                                    <StackPanel Orientation="Horizontal">
                                        <!-- Chevron icon -->
                                        <TextBlock FontSize="11" Margin="0,0,8,0"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource BrushTextMuted}"
                                                   Text="{Binding ExpandChevron}"/>
                                        <!-- Summary text -->
                                        <TextBlock Text="{Binding PlanSummary}"
                                                   FontFamily="{DynamicResource FontBody}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource BrushTextPrimary}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <!-- Expanded details -->
                                <TextBlock Text="{Binding Text}"
                                           FontFamily="{DynamicResource FontBody}"
                                           FontSize="12.5"
                                           Foreground="{DynamicResource BrushTextMuted}"
                                           TextWrapping="Wrap"
                                           Margin="20,6,0,0"
                                           IsVisible="{Binding IsExpanded}"/>
                            </StackPanel>
                        </Border>

                        <!-- Full detail text (shown when NO summary — few commands) -->
                        <TextBlock Text="{Binding Text}"
                                   FontFamily="{DynamicResource FontBody}"
                                   FontSize="13"
                                   Foreground="{DynamicResource BrushTextPrimary}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,14"
                                   IsVisible="{Binding HasPlanSummary, Converter={StaticResource InverseBoolConverter}}"/>

                        <!-- Confirmation buttons -->
                        <StackPanel Orientation="Horizontal"
                                    IsVisible="{Binding IsAwaitingConfirmation}">
                            <Button x:Name="CancelBtn"
                                    Content="Cancel"
                                    Theme="{StaticResource SecondaryButtonStyle}"
                                    Padding="16,8"
                                    Margin="0,0,10,0"
                                    Tag="{Binding}"
                                    Click="CancelAction_Click"/>
                            <Button x:Name="ExecuteBtn"
                                    Content="Execute"
                                    Theme="{StaticResource PrimaryButtonStyle}"
                                    Padding="16,8"
                                    Tag="{Binding}"
                                    Click="ExecuteAction_Click"/>
                        </StackPanel>

                        <!-- Executing indicator — hidden once IsDone is set -->
                        <StackPanel Orientation="Horizontal"
                                    IsVisible="{Binding IsExecutingActive}">
                            <TextBlock Text="Executing…"
                                       FontFamily="{DynamicResource FontBody}"
                                       FontSize="13"
                                       Foreground="{DynamicResource BrushTextMuted}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>

        <!-- ── Execution result template ── -->
        <DataTemplate x:Key="ExecutionResultTemplate" DataType="models:TerminalMessage">
            <Grid Margin="0,4,0,4">
                <Border Background="{DynamicResource BrushPanelBackground}"
                        CornerRadius="8"
                        BorderThickness="1"
                        BorderBrush="{Binding IsSuccess, Converter={StaticResource SuccessToBrushConverter}}"
                        Padding="14,10">
                    <StackPanel>
                        <TextBlock helpers:TextLinkHelper.TextWithLinks="{Binding Text}"
                                   helpers:TextLinkHelper.LinkBrush="{DynamicResource BrushAccent}"
                                   FontFamily="{DynamicResource FontBody}"
                                   FontSize="13"
                                   Foreground="{Binding IsSuccess, Converter={StaticResource SuccessToBrushConverter}}"
                                   TextWrapping="Wrap"/>
                        <!-- Fix with AI button — only visible on failure -->
                        <Button x:Name="FixWithAiBtn"
                                Click="FixWithAi_Click"
                                Margin="0,10,0,2"
                                Padding="14,8"
                                HorizontalAlignment="Left"
                                FontFamily="{DynamicResource FontBody}"
                                FontSize="12"
                                FontWeight="SemiBold"
                                Cursor="Hand"
                                IsVisible="{Binding IsSuccess, Converter={StaticResource InverseBoolConverter}}"
                                Background="{DynamicResource BrushAccent}"
                                Foreground="White"
                                BorderThickness="0">
                            <Button.Content>
                                <StackPanel Orientation="Horizontal">
                                    <Canvas Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center">
                                        <Path Data="M12,4A6,6,0,1,0,18,10"
                                              Stroke="White"
                                              StrokeThickness="2"
                                              StrokeLineCap="Round"/>
                                        <Path Data="M18,4V10H12"
                                              Stroke="White"
                                              StrokeThickness="2"
                                              StrokeLineCap="Round"/>
                                    </Canvas>
                                    <TextBlock Text="Fix with AI" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button.Content>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <Border Grid.Row="0"
                Background="{DynamicResource BrushSidebarBackground}"
                BorderBrush="{DynamicResource BrushBorder}"
                BorderThickness="0,0,0,1"
                Padding="24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="AI Terminal"
                               FontFamily="{DynamicResource FontDisplay}"
                               FontSize="18"
                               Foreground="{DynamicResource BrushTextPrimary}"/>
                    <TextBlock Text="Control Minecraft Control Hub using natural language"
                               FontFamily="{DynamicResource FontBody}"
                               FontSize="12"
                               Foreground="{DynamicResource BrushTextMuted}"
                               Margin="0,2,0,0"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Clear history"
                        Theme="{StaticResource SecondaryButtonStyle}"
                        Padding="14,7"
                        VerticalAlignment="Center"
                        Click="ClearHistory_Click"/>
            </Grid>
        </Border>

        <!-- ── Not configured notice with Gemini key setup ── -->
        <Border Grid.Row="1"
                IsVisible="{Binding IsConfigured, Converter={StaticResource InverseBoolConverter}}"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Background="{DynamicResource BrushPanelBackground}"
                BorderBrush="{DynamicResource BrushBorder}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="24,20"
                MaxWidth="520">
            <StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,12">
                    <Canvas Width="32" Height="32" VerticalAlignment="Center" Margin="0,0,12,0">
                        <Polygon Points="16,0 19,11 32,16 19,21 16,32 13,21 0,16 13,11"
                                 Fill="{DynamicResource BrushAccent}"/>
                    </Canvas>
                    <TextBlock Text="AI Terminal not configured"
                               FontFamily="{DynamicResource FontDisplay}"
                               FontSize="16"
                               Foreground="{DynamicResource BrushTextPrimary}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <Expander Header="Get a free Gemini API key"
                          Background="{DynamicResource BrushPanelElevated}"
                          BorderBrush="{DynamicResource BrushBorder}"
                          BorderThickness="1"
                          Padding="16,12"
                          Margin="0,0,0,16"
                          Foreground="{DynamicResource BrushTextPrimary}"
                          IsExpanded="True">
                    <StackPanel Margin="0,12,0,0">
                        <TextBlock Text="Follow these steps to get a free Gemini API key:"
                                   FontFamily="{DynamicResource FontDisplay}"
                                   FontSize="13"
                                   Foreground="{DynamicResource BrushTextPrimary}"
                                   Margin="0,0,0,10"/>
                        <StackPanel Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="1. Go to "
                                           FontFamily="{DynamicResource FontBody}"
                                           FontSize="12"
                                           Foreground="{DynamicResource BrushTextSecondary}"
                                           VerticalAlignment="Center"/>
                                <HyperlinkButton Content="Google AI Studio"
                                                 NavigateUri="https://aistudio.google.com/app/apikey"
                                                 Foreground="{DynamicResource BrushAccent}"
                                                 Padding="0"
                                                 VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="2. Sign in with your Google account"
                                       FontFamily="{DynamicResource FontBody}"
                                       FontSize="12"
                                       Foreground="{DynamicResource BrushTextSecondary}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="3. Click 'Create API key' or 'Create API key in new project'"
                                       FontFamily="{DynamicResource FontBody}"
                                       FontSize="12"
                                       Foreground="{DynamicResource BrushTextSecondary}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="4. Copy your API key"
                                       FontFamily="{DynamicResource FontBody}"
                                       FontSize="12"
                                       Foreground="{DynamicResource BrushTextSecondary}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="5. Paste it below and click Save"
                                       FontFamily="{DynamicResource FontBody}"
                                       FontSize="12"
                                       Foreground="{DynamicResource BrushTextSecondary}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        <TextBlock Text="The free tier includes generous limits for testing and personal use."
                                   FontFamily="{DynamicResource FontBody}"
                                   FontSize="11"
                                   Foreground="{DynamicResource BrushTextMuted}"
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,0"
                                   FontStyle="Italic"/>
                    </StackPanel>
                </Expander>

                <TextBlock Text="Paste your Gemini API key:"
                           FontFamily="{DynamicResource FontDisplay}"
                           FontSize="12"
                           Foreground="{DynamicResource BrushTextSecondary}"
                           Margin="0,0,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0"
                            Background="{DynamicResource BrushPanelBackground}"
                            BorderBrush="{DynamicResource BrushBorder}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12,8">
                        <TextBox x:Name="GeminiKeyBox"
                                 FontFamily="{DynamicResource FontBody}"
                                 FontSize="13"
                                 Background="Transparent"
                                 Foreground="{DynamicResource BrushTextPrimary}"
                                 BorderThickness="0"
                                 Padding="0"
                                 VerticalContentAlignment="Center"
                                 CaretBrush="{DynamicResource BrushTextPrimary}"/>
                    </Border>
                    <Button Grid.Column="1"
                            Content="Save"
                            Theme="{StaticResource PrimaryButtonStyle}"
                            Padding="16,8"
                            Margin="8,0,0,0"
                            Click="SaveGeminiKey_Click"/>
                </Grid>
                <TextBlock x:Name="SaveStatusText"
                           FontFamily="{DynamicResource FontBody}"
                           FontSize="11"
                           Foreground="{DynamicResource BrushTextMuted}"
                           Margin="0,8,0,0"
                           TextWrapping="Wrap"
                           IsVisible="False"/>
            </StackPanel>
        </Border>

        <!-- ── Message list ── -->
        <ListBox x:Name="MessageList"
                 Grid.Row="1"
                 ItemsSource="{Binding Messages}"
                 IsVisible="{Binding IsConfigured}"
                 Background="Transparent"
                 BorderThickness="0"
                 Padding="24,16,24,30"
                 SelectionChanged="MessageList_SelectionChanged"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ListBox.Styles>
                <Style Selector="ListBoxItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                </Style>
                <Style Selector="ListBoxItem:pointerover">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                </Style>
                <Style Selector="ListBoxItem:selected">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                </Style>
                <Style Selector="ListBoxItem:focus">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                </Style>
            </ListBox.Styles>
            <ListBox.ItemTemplate>
                <local:TerminalMessageTemplateSelector
                    UserTemplate="{StaticResource UserMessageTemplate}"
                    AITemplate="{StaticResource AIMessageTemplate}"
                    ActionPlanTemplate="{StaticResource ActionPlanTemplate}"
                    ExecutionResultTemplate="{StaticResource ExecutionResultTemplate}"/>
            </ListBox.ItemTemplate>
        </ListBox>
        <!-- ── Input area ── -->
        <Border Grid.Row="2"
                Background="{DynamicResource BrushSidebarBackground}"
                BorderBrush="{DynamicResource BrushBorder}"
                BorderThickness="0,1,0,0"
                Padding="24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Import mod from file button -->
                <Button Grid.Column="0"
                        Content="📎"
                        Theme="{StaticResource SecondaryButtonStyle}"
                        Padding="12,10"
                        Margin="0,0,8,0"
                        ToolTip.Tip="Import a mod .jar from file (for CurseForge mods)"
                        Click="ImportModFromFile_Click"/>

                <Border Grid.Column="1"
                        Background="{DynamicResource BrushPanelBackground}"
                        BorderBrush="{DynamicResource BrushBorder}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Margin="0,0,10,0">
                    <TextBox x:Name="InputBox"
                             Text="{Binding InputText, Mode=TwoWay}"
                             Watermark="Ask anything — 'Create a horror instance', 'Start my server', …"
                             FontFamily="{DynamicResource FontBody}"
                             FontSize="13.5"
                             Background="Transparent"
                             Foreground="{DynamicResource BrushTextPrimary}"
                             BorderThickness="0"
                             Padding="14,10"
                             AcceptsReturn="False"
                             TextWrapping="NoWrap"
                             VerticalContentAlignment="Center"
                             CaretBrush="{DynamicResource BrushTextPrimary}"
                             SelectionBrush="{DynamicResource BrushAccent}"
                             KeyDown="InputBox_KeyDown"
                             TextChanged="InputBox_TextChanged"/>
                </Border>

                <Button Grid.Column="2"
                        Content="Cancel"
                        Theme="{StaticResource SecondaryButtonStyle}"
                        Padding="14,10"
                        Margin="0,0,8,0"
                        IsVisible="{Binding IsBusy}"
                        Click="Cancel_Click"/>

                <Button Grid.Column="3"
                        Content="Send"
                        Theme="{StaticResource PrimaryButtonStyle}"
                        Padding="20,10"
                        IsEnabled="{Binding CanSend}"
                        Click="Send_Click"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>


