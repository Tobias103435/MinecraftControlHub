<UserControl x:Class="MinecraftControlHub.UI.Pages.HomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:viewmodels="clr-namespace:MinecraftControlHub.UI.ViewModels"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             d:DataContext="{d:DesignInstance viewmodels:HomePageViewModel}">

    <Grid>
        <!-- ========== Main installations list ========== -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32,24,32,32">

                <!-- Page header -->
                <Grid Margin="0,0,0,24">
                    <StackPanel>
                        <TextBlock Text="Installations"
                                   FontFamily="{StaticResource FontDisplay}"
                                   FontSize="24"
                                   Foreground="{DynamicResource BrushTextPrimary}"/>
                        <TextBlock Text="Manage your Minecraft instances"
                                   FontFamily="{StaticResource FontBody}"
                                   FontSize="13"
                                   Foreground="{DynamicResource BrushTextMuted}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                    <Button Content="+ New Installation"
                            Style="{StaticResource PrimaryButtonStyle}"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Padding="20,9"
                            Click="NewInstallation_Click"/>
                </Grid>

                <!-- Installations grid -->
                <ItemsControl ItemsSource="{Binding InstallationCards}"
                              Visibility="{Binding HasInstallations, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- Card wrapper — grows vertically when expanded -->
                            <Border Style="{StaticResource InstallationCardStyle}"
                                    MinHeight="0" Width="270">
                                <StackPanel>

                                    <!-- ══ HEADER (always visible, non-clickable) ══ -->
                                    <Grid Margin="0,0,0,16">
                                        <StackPanel>
                                            <!-- version + loader badge row -->
                                            <Grid Margin="0,0,0,4">
                                                <TextBlock Text="{Binding MinecraftVersion, StringFormat='Minecraft {0}'}"
                                                           FontFamily="{StaticResource FontBody}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource BrushTextSecondary}"
                                                           VerticalAlignment="Center"/>
                                                <Border HorizontalAlignment="Right"
                                                        VerticalAlignment="Center"
                                                        Background="{StaticResource BrushAccent}"
                                                        CornerRadius="4"
                                                        Padding="6,2"
                                                        Visibility="{Binding Loader, Converter={StaticResource LoaderNotVanillaToVisibilityConverter}}">
                                                    <TextBlock Text="{Binding Loader}"
                                                               FontFamily="{StaticResource FontBody}"
                                                               FontSize="10"
                                                               FontWeight="SemiBold"
                                                               Foreground="White"/>
                                                </Border>
                                            </Grid>

                                            <!-- name -->
                                            <TextBlock Text="{Binding Name}"
                                                       FontFamily="{StaticResource FontDisplay}"
                                                       FontSize="16"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource BrushTextPrimary}"
                                                       TextWrapping="Wrap"/>

                                            <!-- mod count subtitle -->
                                            <TextBlock Text="{Binding ModCountLabel}"
                                                       FontFamily="{StaticResource FontBody}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource BrushTextMuted}"
                                                       Margin="0,3,0,0"/>

                                            <!-- Health indicators (shown after background check completes) -->
                                            <StackPanel Margin="0,8,0,0"
                                                        Visibility="{Binding HealthChecked, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <!-- Java status -->
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,3"
                                                            Visibility="{Binding JavaHealth, Converter={StaticResource NullToVisibilityConverter}}">
                                                    <Ellipse Width="6" Height="6" Margin="0,0,6,0"
                                                             VerticalAlignment="Center">
                                                        <Ellipse.Style>
                                                            <Style TargetType="Ellipse">
                                                                <Setter Property="Fill" Value="{StaticResource BrushOnline}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding JavaOk}" Value="False">
                                                                        <Setter Property="Fill" Value="{StaticResource BrushDanger}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Ellipse.Style>
                                                    </Ellipse>
                                                    <TextBlock Text="{Binding JavaHealth}"
                                                               FontFamily="{StaticResource FontBody}"
                                                               FontSize="11"
                                                               VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="{StaticResource BrushOnline}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding JavaOk}" Value="False">
                                                                        <Setter Property="Foreground" Value="{StaticResource BrushDanger}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                                <!-- Mods update status -->
                                                <StackPanel Orientation="Horizontal"
                                                            Visibility="{Binding ModsHealth, Converter={StaticResource NullToVisibilityConverter}}">
                                                    <Ellipse Width="6" Height="6" Margin="0,0,6,0"
                                                             VerticalAlignment="Center">
                                                        <Ellipse.Style>
                                                            <Style TargetType="Ellipse">
                                                                <Setter Property="Fill" Value="{StaticResource BrushOnline}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding ModsUpToDate}" Value="False">
                                                                        <Setter Property="Fill" Value="#F0A020"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Ellipse.Style>
                                                    </Ellipse>
                                                    <TextBlock Text="{Binding ModsHealth}"
                                                               FontFamily="{StaticResource FontBody}"
                                                               FontSize="11"
                                                               VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="{StaticResource BrushOnline}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding ModsUpToDate}" Value="False">
                                                                        <Setter Property="Foreground" Value="#F0A020"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>


                                    <!-- ══ ACTION BUTTONS (always visible) ══ -->
                                    <StackPanel>
                                        <!-- Row 1: Play -->
                                        <Button Content="▶  Play"
                                                Style="{StaticResource PrimaryButtonStyle}"
                                                Padding="16,8"
                                                HorizontalAlignment="Stretch"
                                                Margin="0,0,0,6"
                                                Click="Play_Click"/>
                                        <!-- Row 2: Settings / Share / Delete -->
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="Settings"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Padding="12,7"
                                                    Margin="0,0,6,0"
                                                    Click="Settings_Click"/>
                                            <Button Content="Share"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Padding="12,7"
                                                    Margin="0,0,6,0"
                                                    ToolTip="Share this instance"
                                                    Click="ShareInstallation_Click"/>
                                            <Button Content="✕ Delete"
                                                    Padding="10,7"
                                                    FontFamily="{StaticResource FontBody}"
                                                    FontSize="12"
                                                    Foreground="{StaticResource BrushDanger}"
                                                    Background="Transparent"
                                                    BorderBrush="{StaticResource BrushBorder}"
                                                    BorderThickness="1"
                                                    Cursor="Hand"
                                                    Click="DeleteInstallation_Click"
                                                    ToolTip="Delete this installation">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border x:Name="Bg"
                                                                            Background="{TemplateBinding Background}"
                                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                                            CornerRadius="6"
                                                                            Padding="{TemplateBinding Padding}">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource BrushDanger}"/>
                                                                            <Setter Property="Foreground" Value="White"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </StackPanel>
                                    </StackPanel>

                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Empty state -->
                <Border Background="{StaticResource BrushPanelBackground}"
                        BorderBrush="{StaticResource BrushBorder}"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="60,48"
                        Visibility="{Binding HasInstallations, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                    <StackPanel HorizontalAlignment="Center">
                        <!-- Grass block icon (simple flat representation) -->
                        <Grid Width="48" Height="48" HorizontalAlignment="Center" Margin="0,0,0,16">
                            <Rectangle Fill="#5D9E4A" RadiusX="6" RadiusY="6"/>
                            <Rectangle Fill="#8B6340" RadiusX="0" RadiusY="0"
                                       Margin="0,16,0,0"/>
                            <Rectangle Fill="#5D9E4A" Height="14" VerticalAlignment="Top"
                                       RadiusX="6" RadiusY="6"/>
                        </Grid>
                        <TextBlock Text="No installations yet"
                                   FontFamily="{StaticResource FontDisplay}"
                                   FontSize="20"
                                   Foreground="{DynamicResource BrushTextPrimary}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="Create your first Minecraft installation with the button above, or import an existing one."
                                   FontFamily="{StaticResource FontBody}"
                                   FontSize="13"
                                   Foreground="{DynamicResource BrushTextSecondary}"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ========== New installation dialog overlay ========== -->
        <Border Background="#CC000000"
                Visibility="{Binding IsCreateVisible, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Background="{StaticResource BrushPanelBackground}"
                    BorderBrush="{StaticResource BrushBorder}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Width="460"
                    MaxHeight="580"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <!-- Header -->
                        <RowDefinition Height="Auto"/>
                        <!-- Scrollable form body -->
                        <RowDefinition Height="*"/>
                        <!-- Sticky footer buttons -->
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <StackPanel Grid.Row="0" Margin="24,20,24,12">
                        <Grid>
                            <TextBlock Text="New Installation"
                                       FontFamily="{StaticResource FontDisplay}"
                                       FontSize="18"
                                       Foreground="{DynamicResource BrushTextPrimary}"
                                       VerticalAlignment="Center"/>
                            <!-- Import dropdown button -->
                            <Button x:Name="ImportBtn"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    HorizontalAlignment="Right"
                                    Padding="12,6"
                                    FontSize="12"
                                    IsEnabled="{Binding IsCreateDialogBusy, Converter={StaticResource InverseBoolConverter}}"
                                    Click="ImportBtn_Click">
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Import" VerticalAlignment="Center"/>
                                        <TextBlock Text=" ▾" VerticalAlignment="Center" FontSize="10"/>
                                    </StackPanel>
                                </Button.Content>
                                <Button.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Modrinth / .mrpack"
                                                  Click="ImportMrpack_Click"/>
                                        <MenuItem Header="Prism Launcher zip"
                                                  Click="ImportPrismZip_Click"/>
                                        <Separator/>
                                        <MenuItem Header="Import with code…"
                                                  Click="ImportWithCode_Click"/>
                                    </ContextMenu>
                                </Button.ContextMenu>
                            </Button>
                        </Grid>
                        <TextBlock Text="Java is recommended automatically for the chosen Minecraft version."
                                   FontFamily="{StaticResource FontBody}"
                                   FontSize="12"
                                   Foreground="{DynamicResource BrushTextMuted}"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,0"/>
                    </StackPanel>

                    <!-- Divider -->
                    <Border Grid.Row="0" Height="1" Background="{StaticResource BrushBorder}"
                            VerticalAlignment="Bottom"/>

                    <!-- Scrollable form body -->
                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  Padding="24,16,24,0">
                        <StackPanel>

                            <TextBlock Text="Name"
                                       FontFamily="{StaticResource FontBody}"
                                       FontSize="12"
                                       Foreground="{DynamicResource BrushTextSecondary}"
                                       Margin="0,0,0,4"/>
                            <TextBox Text="{Binding NewInstallationName, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="10"
                                     Background="{StaticResource BrushPanelElevated}"
                                     BorderBrush="{StaticResource BrushBorder}"
                                     BorderThickness="1"
                                     Foreground="{DynamicResource BrushTextPrimary}"
                                     FontSize="13"
                                     Margin="0,0,0,16"/>

                            <DockPanel Margin="0,0,0,4">
                                <CheckBox Content="Show snapshots"
                                          IsChecked="{Binding ShowSnapshots}"
                                          DockPanel.Dock="Right"
                                          FontFamily="{StaticResource FontBody}"
                                          FontSize="12"
                                          Foreground="{DynamicResource BrushTextSecondary}"/>
                                <TextBlock Text="Minecraft version"
                                           FontFamily="{StaticResource FontBody}"
                                           FontSize="12"
                                           Foreground="{DynamicResource BrushTextSecondary}"/>
                            </DockPanel>

                            <ComboBox x:Name="MinecraftVersionCombo"
                                      IsEditable="True"
                                      ItemsSource="{Binding FilteredMinecraftVersions}"
                                      Text="{Binding NewMinecraftVersion, UpdateSourceTrigger=PropertyChanged}"
                                      HorizontalAlignment="Stretch"
                                      Margin="0,0,0,16"
                                      TextBoxBase.TextChanged="MinecraftVersionCombo_TextChanged"/>

                            <TextBlock Text="Loader"
                                       FontFamily="{StaticResource FontBody}"
                                       FontSize="12"
                                       Foreground="{DynamicResource BrushTextSecondary}"
                                       Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding Loaders}"
                                      SelectedItem="{Binding NewLoader}"
                                      HorizontalAlignment="Left"
                                      MinWidth="200"
                                      Margin="0,0,0,16"/>

                            <TextBlock Text="Loader version"
                                       FontFamily="{StaticResource FontBody}"
                                       FontSize="12"
                                       Foreground="{DynamicResource BrushTextSecondary}"
                                       Margin="0,0,0,4"
                                       Visibility="{Binding NewLoader, Converter={StaticResource LoaderNotVanillaToVisibilityConverter}}"/>
                            <ComboBox ItemsSource="{Binding AvailableLoaderVersions}"
                                      SelectedItem="{Binding NewLoaderVersion}"
                                      HorizontalAlignment="Left"
                                      MinWidth="200"
                                      Margin="0,0,0,16"
                                      Visibility="{Binding NewLoader, Converter={StaticResource LoaderNotVanillaToVisibilityConverter}}"/>

                            <!-- Java advice -->
                            <Border Background="{StaticResource BrushPanelElevated}"
                                    BorderBrush="{StaticResource BrushBorder}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12,10"
                                    Margin="0,0,0,12"
                                    Visibility="{Binding HasJavaAdvice, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="{Binding JavaAdvice}"
                                           FontFamily="{StaticResource FontBody}"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource BrushTextPrimary}"/>
                            </Border>

                            <!-- Create status -->
                            <TextBlock Text="{Binding CreateStatus}"
                                       FontFamily="{StaticResource FontBody}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource BrushTextSecondary}"
                                       Margin="0,0,0,12"
                                       Visibility="{Binding HasCreateStatus, Converter={StaticResource BoolToVisibilityConverter}}"/>

                            <!-- Bottom padding inside scroll -->
                            <Border Height="8"/>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Sticky footer: Cancel + Create -->
                    <Border Grid.Row="2"
                            Background="{StaticResource BrushSidebarBackground}"
                            BorderBrush="{StaticResource BrushBorder}"
                            BorderThickness="0,1,0,0"
                            CornerRadius="0,0,12,12"
                            Padding="24,14">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Cancel"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="18,8"
                                    Margin="0,0,10,0"
                                    Click="CancelCreate_Click"/>
                            <Button Content="Create"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Padding="22,8"
                                    IsEnabled="{Binding IsCreateDialogBusy, Converter={StaticResource InverseBoolConverter}}"
                                    Click="CreateInstallation_Click"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Border>

        <!-- ========== Sign-in / play overlay ========== -->
        <Border Background="#CC000000"
                Visibility="{Binding IsLoginVisible, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Background="{StaticResource BrushPanelBackground}"
                    BorderBrush="{StaticResource BrushBorder}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="28"
                    Width="420"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Play Minecraft"
                               FontFamily="{StaticResource FontDisplay}"
                               FontSize="18"
                               Foreground="{StaticResource BrushTextPrimary}"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="Sign in with Microsoft to play online, or play offline for singleplayer and LAN."
                               FontFamily="{StaticResource FontBody}"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource BrushTextSecondary}"
                               Margin="0,0,0,20"/>

                    <!-- Microsoft sign-in button -->
                    <Button Click="SignIn_Click"
                            HorizontalAlignment="Stretch"
                            Height="46"
                            Cursor="Hand"
                            IsEnabled="{Binding IsSigningIn, Converter={StaticResource InverseBoolConverter}}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="{DynamicResource BrushAccent}" CornerRadius="8">
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                        <Grid Width="20" Height="20" Margin="0,0,12,0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition/><RowDefinition/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/><ColumnDefinition/>
                                            </Grid.ColumnDefinitions>
                                            <Rectangle Grid.Row="0" Grid.Column="0" Fill="#F25022" Margin="0,0,1,1"/>
                                            <Rectangle Grid.Row="0" Grid.Column="1" Fill="#7FBA00" Margin="1,0,0,1"/>
                                            <Rectangle Grid.Row="1" Grid.Column="0" Fill="#00A4EF" Margin="0,1,1,0"/>
                                            <Rectangle Grid.Row="1" Grid.Column="1" Fill="#FFB900" Margin="1,1,0,0"/>
                                        </Grid>
                                        <TextBlock Text="Sign in with Microsoft"
                                                   Foreground="White"
                                                   FontFamily="{StaticResource FontBody}"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#8B5CF6"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="Bd" Property="Opacity" Value="0.5"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Device code box -->
                    <Border Background="{StaticResource BrushPanelElevated}"
                            BorderBrush="{StaticResource BrushBorder}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="14"
                            Margin="0,14,0,0"
                            Visibility="{Binding HasDeviceCode, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Enter this code on the Microsoft sign-in page:"
                                       FontFamily="{StaticResource FontBody}"
                                       FontSize="12"
                                       Foreground="{StaticResource BrushTextSecondary}"
                                       Margin="0,0,0,6"/>
                            <Grid>
                                <TextBlock Text="{Binding DeviceCode}"
                                           FontFamily="{StaticResource FontDisplay}"
                                           FontSize="24"
                                           Foreground="{StaticResource BrushTextPrimary}"
                                           VerticalAlignment="Center"/>
                                <Button Content="Copy"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Padding="12,5"
                                        FontSize="12"
                                        HorizontalAlignment="Right"
                                        Click="CopyShareCode_Click"/>
                            </Grid>
                            <TextBlock Text="{Binding DeviceVerificationUri}"
                                       FontFamily="{StaticResource FontBody}"
                                       FontSize="12"
                                       Foreground="{StaticResource BrushAccent}"
                                       Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="{Binding LoginStatus}"
                               FontFamily="{StaticResource FontBody}"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource BrushTextSecondary}"
                               Margin="0,12,0,0"
                               Visibility="{Binding HasLoginStatus, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <Border Height="1" Background="{StaticResource BrushBorder}" Margin="0,20,0,16"/>

                    <!-- Offline play section -->
                    <TextBlock Text="Or play offline"
                               FontFamily="{StaticResource FontBody}"
                               FontSize="13"
                               Foreground="{StaticResource BrushTextSecondary}"
                               Margin="0,0,0,10"/>

                    <TextBlock Text="Player name:"
                               FontFamily="{StaticResource FontDisplay}"
                               FontSize="13"
                               Foreground="{StaticResource BrushTextSecondary}"
                               Margin="0,0,0,4"/>
                    <TextBox Text="{Binding OfflinePlayerName, UpdateSourceTrigger=PropertyChanged}"
                             Padding="10"
                             Background="{StaticResource BrushPanelElevated}"
                             BorderBrush="{StaticResource BrushBorder}"
                             BorderThickness="1"
                             Foreground="{StaticResource BrushTextPrimary}"
                             FontSize="13"
                             Margin="0,0,0,12"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancel"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Padding="16,8"
                                Margin="0,0,8,0"
                                Click="CancelLogin_Click"/>
                        <Button Content="Play offline"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Padding="16,8"
                                Click="PlayOffline_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <!-- ========== Launch progress overlay ========== -->
        <Border Background="#CC000000"
                Visibility="{Binding IsLaunchVisible, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Background="{StaticResource BrushPanelBackground}"
                    BorderBrush="{StaticResource BrushBorder}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="28"
                    Width="440"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Launching Minecraft"
                               FontFamily="{StaticResource FontDisplay}"
                               FontSize="18"
                               Foreground="{StaticResource BrushTextPrimary}"
                               Margin="0,0,0,16"/>

                    <TextBlock Text="{Binding LaunchStage}"
                               FontFamily="{StaticResource FontBody}"
                               FontSize="13"
                               Foreground="{StaticResource BrushTextPrimary}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,12"/>

                    <ProgressBar Height="10"
                                 Style="{StaticResource ServerProgressBarStyle}"
                                 Minimum="0" Maximum="100"
                                 Value="{Binding LaunchPercent}"
                                 IsIndeterminate="{Binding LaunchIndeterminate}"
                                 Margin="0,0,0,14"/>

                    <Border Background="{StaticResource BrushPanelElevated}"
                            BorderBrush="{StaticResource BrushBorder}"
                            BorderThickness="1"
                            CornerRadius="6"
                            MaxHeight="200"
                            Margin="0,0,0,8"
                            Visibility="{Binding HasLaunchMessage, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
                            <TextBox Text="{Binding LaunchMessage, Mode=OneWay}"
                                     FontFamily="{StaticResource FontBody}"
                                     FontSize="12"
                                     Foreground="{StaticResource BrushTextSecondary}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     TextWrapping="Wrap"
                                     IsReadOnly="True"
                                     IsReadOnlyCaretVisible="True"/>
                        </ScrollViewer>
                    </Border>

                    <Button Content="Copy log"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Padding="14,6"
                            HorizontalAlignment="Right"
                            Margin="0,0,0,16"
                            Visibility="{Binding HasLaunchMessage, Converter={StaticResource BoolToVisibilityConverter}}"
                            Click="CopyLaunchLog_Click"/>

                    <Button Content="Done"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Padding="24,8"
                            HorizontalAlignment="Right"
                            IsEnabled="{Binding LaunchFinished}"
                            Click="FinishLaunch_Click"/>
                </StackPanel>
            </Border>
        </Border>


        <!-- ========== Share overlay ========== -->
        <Border Visibility="{Binding IsShareVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                Background="#99000000" Panel.ZIndex="50">
            <Border Background="{StaticResource BrushPanelBackground}"
                    BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                    CornerRadius="14" Padding="28,24" MaxWidth="500" MaxHeight="580"
                    VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel>
                    <Grid Margin="0,0,0,16">
                        <TextBlock Text="Share Instance" FontFamily="{StaticResource FontDisplay}"
                                   FontSize="18" Foreground="{StaticResource BrushTextPrimary}"/>
                        <Button Content="x" Style="{StaticResource SecondaryButtonStyle}"
                                Padding="8,4" HorizontalAlignment="Right" Click="CloseShare_Click"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Button Content="Share with Friends" Padding="14,7" Margin="0,0,8,0" Click="ShareTabFriends_Click">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsFriendsTab}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource BrushAccent}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Share Code" Padding="14,7" Click="ShareTabCode_Click">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCodeTab}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource BrushAccent}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                    <!-- Friends tab -->
                    <StackPanel Visibility="{Binding IsFriendsTab, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="Select friends to share with:"
                                   FontFamily="{StaticResource FontBody}" FontSize="13"
                                   Foreground="{StaticResource BrushTextSecondary}" Margin="0,0,0,10"/>
                        <ScrollViewer MaxHeight="180" VerticalScrollBarVisibility="Auto" Margin="0,0,0,14">
                            <ItemsControl ItemsSource="{Binding ShareableFriends}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Content="{Binding DisplayName}"
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                  FontFamily="{StaticResource FontBody}" FontSize="13"
                                                  Foreground="{StaticResource BrushTextPrimary}" Margin="0,4"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                        <Button Content="Send" Style="{StaticResource PrimaryButtonStyle}"
                                Padding="20,9" HorizontalAlignment="Left"
                                IsEnabled="{Binding IsShareBusy, Converter={StaticResource InverseBoolConverter}}"
                                Click="ShareWithFriends_Click"/>
                    </StackPanel>
                    <!-- Code tab -->
                    <StackPanel Visibility="{Binding IsCodeTab, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="Generate a share code anyone can use to import this instance:"
                                   FontFamily="{StaticResource FontBody}" FontSize="13"
                                   Foreground="{StaticResource BrushTextSecondary}" TextWrapping="Wrap" Margin="0,0,0,10"/>
                        <Button Content="Generate code" Style="{StaticResource SecondaryButtonStyle}"
                                Padding="16,8" HorizontalAlignment="Left"
                                IsEnabled="{Binding IsShareBusy, Converter={StaticResource InverseBoolConverter}}"
                                Click="GenerateCode_Click"/>
                        <Border Background="{StaticResource BrushPanelElevated}"
                                BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                                CornerRadius="8" Padding="14,10" Margin="0,12,0,0"
                                Visibility="{Binding HasShareCode, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid>
                                <TextBlock Text="{Binding ShareCode}" FontFamily="Consolas" FontSize="18"
                                           Foreground="{StaticResource BrushAccent}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                <Button Content="Copy" Style="{StaticResource SecondaryButtonStyle}"
                                        Padding="10,5" HorizontalAlignment="Right" Click="CopyShareCode_Click"/>
                            </Grid>
                        </Border>
                        <TextBlock Text="Or import an instance using a code:"
                                   FontFamily="{StaticResource FontBody}" FontSize="13"
                                   Foreground="{StaticResource BrushTextSecondary}" Margin="0,20,0,8"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBox Text="{Binding ImportCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Width="200" Padding="10,8" FontFamily="{StaticResource FontBody}" FontSize="13"
                                     Background="{StaticResource BrushPanelElevated}"
                                     Foreground="{StaticResource BrushTextPrimary}"
                                     BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"/>
                            <Button Content="Import" Style="{StaticResource PrimaryButtonStyle}"
                                    Padding="16,8" Margin="8,0,0,0"
                                    IsEnabled="{Binding IsShareBusy, Converter={StaticResource InverseBoolConverter}}"
                                    Click="ImportFromCode_Click"/>
                        </StackPanel>
                    </StackPanel>
                    <TextBlock Text="{Binding ShareStatus}" FontFamily="{StaticResource FontBody}" FontSize="12"
                               Foreground="{StaticResource BrushAccent}" TextWrapping="Wrap" Margin="0,14,0,0"
                               Visibility="{Binding HasShareStatus, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </StackPanel>
            </Border>
        </Border>


    </Grid>
</UserControl>
