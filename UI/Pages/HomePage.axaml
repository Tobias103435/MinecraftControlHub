<UserControl x:Class="MinecraftControlHub.UI.Pages.HomePage"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:viewmodels="clr-namespace:MinecraftControlHub.UI.ViewModels"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600">

    <Grid>
        <!-- ========== Main installations list ========== -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32,24,32,32">

                <!-- Page header -->
                <Grid Margin="0,0,0,24">
                    <StackPanel>
                        <TextBlock Text="Installations"
                                   FontFamily="{StaticResource FontDisplay}"
                                   FontSize="24"
                                   Foreground="{DynamicResource BrushTextPrimary}"/>
                        <TextBlock Text="Manage your Minecraft instances"
                                   FontFamily="{StaticResource FontBody}"
                                   FontSize="13"
                                   Foreground="{DynamicResource BrushTextMuted}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                    <Button Content="+ New Installation"
                            Theme="{StaticResource PrimaryButtonStyle}"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Padding="20,9"
                            Click="NewInstallation_Click"/>
                </Grid>

                <!-- Installations grid -->
                <ItemsControl ItemsSource="{Binding InstallationCards}"
                              IsVisible="{Binding HasInstallations}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- Card wrapper — grows vertically when expanded -->
                            <Border Theme="{StaticResource InstallationCardStyle}"
                                    MinHeight="0" Width="270">
                                <StackPanel>

                                    <!-- ══ HEADER (always visible, non-clickable) ══ -->
                                    <Grid Margin="0,0,0,16">
                                        <StackPanel>
                                            <!-- version + loader badge row -->
                                            <Grid Margin="0,0,0,4">
                                                <TextBlock Text="{Binding MinecraftVersion, StringFormat='Minecraft {0}'}"
                                                           FontFamily="{StaticResource FontBody}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource BrushTextSecondary}"
                                                           VerticalAlignment="Center"/>
                                                <Border HorizontalAlignment="Right"
                                                        VerticalAlignment="Center"
                                                        Background="{StaticResource BrushAccent}"
                                                        CornerRadius="4"
                                                        Padding="6,2"
                                                        IsVisible="{Binding Loader, Converter={StaticResource LoaderNotVanillaToVisibilityConverter}}">
                                                    <TextBlock Text="{Binding Loader}"
                                                               FontFamily="{StaticResource FontBody}"
                                                               FontSize="10"
                                                               FontWeight="SemiBold"
                                                               Foreground="White"/>
                                                </Border>
                                            </Grid>

                                            <!-- name -->
                                            <TextBlock Text="{Binding Name}"
                                                       FontFamily="{StaticResource FontDisplay}"
                                                       FontSize="16"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource BrushTextPrimary}"
                                                       TextWrapping="Wrap"/>

                                            <!-- mod count subtitle -->
                                            <TextBlock Text="{Binding ModCountLabel}"
                                                       FontFamily="{StaticResource FontBody}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource BrushTextMuted}"
                                                       Margin="0,3,0,0"/>

                                            <!-- Health indicators (shown after background check completes) -->
                                            <StackPanel Margin="0,8,0,0"
                                                        IsVisible="{Binding HealthChecked}">
                                                <!-- Java status -->
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,3"
                                                            IsVisible="{Binding JavaHealth, Converter={StaticResource NullToVisibilityConverter}}">
                                                    <Ellipse Width="6" Height="6" Margin="0,0,6,0"
                                                             VerticalAlignment="Center"
                                                             Classes.ok="{Binding JavaOk}">
                                                        <Ellipse.Styles>
                                                            <Style Selector="Ellipse">
                                                                <Setter Property="Fill" Value="{StaticResource BrushDanger}"/>
                                                            </Style>
                                                            <Style Selector="Ellipse.ok">
                                                                <Setter Property="Fill" Value="{StaticResource BrushOnline}"/>
                                                            </Style>
                                                        </Ellipse.Styles>
                                                    </Ellipse>
                                                    <TextBlock Text="{Binding JavaHealth}"
                                                               FontFamily="{StaticResource FontBody}"
                                                               FontSize="11"
                                                               VerticalAlignment="Center"
                                                               Classes.ok="{Binding JavaOk}">
                                                        <TextBlock.Styles>
                                                            <Style Selector="TextBlock">
                                                                <Setter Property="Foreground" Value="{StaticResource BrushDanger}"/>
                                                            </Style>
                                                            <Style Selector="TextBlock.ok">
                                                                <Setter Property="Foreground" Value="{StaticResource BrushOnline}"/>
                                                            </Style>
                                                        </TextBlock.Styles>
                                                    </TextBlock>
                                                </StackPanel>
                                                <!-- Mods update status -->
                                                <StackPanel Orientation="Horizontal"
                                                            IsVisible="{Binding ModsHealth, Converter={StaticResource NullToVisibilityConverter}}">
                                                    <Ellipse Width="6" Height="6" Margin="0,0,6,0"
                                                             VerticalAlignment="Center"
                                                             Classes.upToDate="{Binding ModsUpToDate}">
                                                        <Ellipse.Styles>
                                                            <Style Selector="Ellipse">
                                                                <Setter Property="Fill" Value="#F0A020"/>
                                                            </Style>
                                                            <Style Selector="Ellipse.upToDate">
                                                                <Setter Property="Fill" Value="{StaticResource BrushOnline}"/>
                                                            </Style>
                                                        </Ellipse.Styles>
                                                    </Ellipse>
                                                    <TextBlock Text="{Binding ModsHealth}"
                                                               FontFamily="{StaticResource FontBody}"
                                                               FontSize="11"
                                                               VerticalAlignment="Center"
                                                               Classes.upToDate="{Binding ModsUpToDate}">
                                                        <TextBlock.Styles>
                                                            <Style Selector="TextBlock">
                                                                <Setter Property="Foreground" Value="#F0A020"/>
                                                            </Style>
                                                            <Style Selector="TextBlock.upToDate">
                                                                <Setter Property="Foreground" Value="{StaticResource BrushOnline}"/>
                                                            </Style>
                                                        </TextBlock.Styles>
                                                    </TextBlock>
                                                </StackPanel>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>


                                    <!-- ══ ACTION BUTTONS (always visible) ══ -->
                                    <StackPanel>
                                        <!-- Row 1: Play -->
                                        <Button Theme="{StaticResource PrimaryButtonStyle}"
                                                Padding="16,8"
                                                HorizontalAlignment="Stretch"
                                                Margin="0,0,0,6"
                                                Click="Play_Click">
                                            <Button.Content>
                                                <StackPanel Orientation="Horizontal">
                                                    <Canvas Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center">
                                                        <Polygon Points="3,2 12,7 3,12" Fill="White"/>
                                                    </Canvas>
                                                    <TextBlock Text="Play" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button.Content>
                                        </Button>
                                        <!-- Row 2: Settings / Share / Delete -->
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="Settings"
                                                    Theme="{StaticResource SecondaryButtonStyle}"
                                                    Padding="12,7"
                                                    Margin="0,0,6,0"
                                                    Click="Settings_Click"/>
                                            <Button Content="Share"
                                                    Theme="{StaticResource SecondaryButtonStyle}"
                                                    Padding="12,7"
                                                    Margin="0,0,6,0"
                                                    ToolTip.Tip="Share this instance"
                                                    Click="ShareInstallation_Click"/>
                                            <Button Padding="10,7"
                                                    FontFamily="{StaticResource FontBody}"
                                                    FontSize="12"
                                                    Foreground="{StaticResource BrushDanger}"
                                                    Background="Transparent"
                                                    BorderBrush="{StaticResource BrushBorder}"
                                                    BorderThickness="1"
                                                    Cursor="Hand"
                                                    Click="DeleteInstallation_Click"
                                                    ToolTip.Tip="Delete this installation">
                                                <Button.Content>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Canvas Width="12" Height="12" Margin="0,0,6,0" VerticalAlignment="Center">
                                                            <Line StartPoint="2,2" EndPoint="10,10" Stroke="{Binding $parent[Button].Foreground}" StrokeThickness="2"/>
                                                            <Line StartPoint="10,2" EndPoint="2,10" Stroke="{Binding $parent[Button].Foreground}" StrokeThickness="2"/>
                                                        </Canvas>
                                                        <TextBlock Text="Delete" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button.Content>
                                                <Button.Styles>
                                                    <Style Selector="Button:pointerover /template/ Border#Bg">
                                                        <Setter Property="Background" Value="{StaticResource BrushDanger}"/>
                                                    </Style>
                                                    <Style Selector="Button:pointerover">
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </Style>
                                                </Button.Styles>
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="Bg"
                                                                Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="6"
                                                                Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter Content="{TemplateBinding Content}"
                                                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </StackPanel>
                                    </StackPanel>

                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Empty state -->
                <Border Background="{StaticResource BrushPanelBackground}"
                        BorderBrush="{StaticResource BrushBorder}"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="60,48"
                        IsVisible="{Binding !HasInstallations}">
                    <StackPanel HorizontalAlignment="Center">
                        <!-- Grass block icon (simple flat representation) -->
                        <Grid Width="48" Height="48" HorizontalAlignment="Center" Margin="0,0,0,16">
                            <Rectangle Fill="#5D9E4A" RadiusX="6" RadiusY="6"/>
                            <Rectangle Fill="#8B6340" RadiusX="0" RadiusY="0"
                                       Margin="0,16,0,0"/>
                            <Rectangle Fill="#5D9E4A" Height="14" VerticalAlignment="Top"
                                       RadiusX="6" RadiusY="6"/>
                        </Grid>
                        <TextBlock Text="No installations yet"
                                   FontFamily="{StaticResource FontDisplay}"
                                   FontSize="20"
                                   Foreground="{DynamicResource BrushTextPrimary}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="Create your first Minecraft installation with the button above, or import an existing one."
                                   FontFamily="{StaticResource FontBody}"
                                   FontSize="13"
                                   Foreground="{DynamicResource BrushTextSecondary}"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ========== New installation dialog overlay ========== -->
        <Border Background="#CC000000"
                IsVisible="{Binding IsCreateVisible}">
            <Border Background="{StaticResource BrushPanelBackground}"
                    BorderBrush="{StaticResource BrushBorder}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Width="460"
                    MaxHeight="580"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                <Grid RowDefinitions="Auto,*,Auto">

                    <!-- Header -->
                    <StackPanel Grid.Row="0" Margin="24,20,24,12">
                        <Grid>
                            <TextBlock Text="New Installation"
                                       FontFamily="{StaticResource FontDisplay}"
                                       FontSize="18"
                                       Foreground="{DynamicResource BrushTextPrimary}"
                                       VerticalAlignment="Center"/>
                            <!-- Import dropdown button -->
                            <Button x:Name="ImportBtn"
                                    Theme="{StaticResource SecondaryButtonStyle}"
                                    HorizontalAlignment="Right"
                                    Padding="12,6"
                                    FontSize="12"
                                    IsEnabled="{Binding IsCreateDialogBusy, Converter={StaticResource InverseBoolConverter}}">
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Import" VerticalAlignment="Center"/>
                                        <TextBlock Text=" ▾" VerticalAlignment="Center" FontSize="10"/>
                                    </StackPanel>
                                </Button.Content>
                                <Button.Flyout>
                                    <MenuFlyout>
                                        <MenuItem Header="Modrinth / .mrpack"
                                                  Click="ImportMrpack_Click"/>
                                        <MenuItem Header="Prism Launcher zip"
                                                  Click="ImportPrismZip_Click"/>
                                        <Separator/>
                                        <MenuItem Header="Import with code…"
                                                  Click="ImportWithCode_Click"/>
                                    </MenuFlyout>
                                </Button.Flyout>
                            </Button>
                        </Grid>
                        <TextBlock Text="Java is recommended automatically for the chosen Minecraft version."
                                   FontFamily="{StaticResource FontBody}"
                                   FontSize="12"
                                   Foreground="{DynamicResource BrushTextMuted}"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,0"/>
                    </StackPanel>

                    <!-- Divider -->
                    <Border Grid.Row="0" Height="1" Background="{StaticResource BrushBorder}"
                            VerticalAlignment="Bottom"/>

                    <!-- Scrollable form body -->
                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  Padding="24,16,24,0">
                        <StackPanel>

                            <TextBlock Text="Name"
                                       FontFamily="{StaticResource FontBody}"
                                       FontSize="12"
                                       Foreground="{DynamicResource BrushTextSecondary}"
                                       Margin="0,0,0,4"/>
                            <TextBox Text="{Binding NewInstallationName}"
                                     Padding="10"
                                     Background="{StaticResource BrushPanelElevated}"
                                     BorderBrush="{StaticResource BrushBorder}"
                                     BorderThickness="1"
                                     Foreground="{DynamicResource BrushTextPrimary}"
                                     FontSize="13"
                                     Margin="0,0,0,16"/>

                            <DockPanel Margin="0,0,0,4">
                                <CheckBox Content="Show snapshots"
                                          IsChecked="{Binding ShowSnapshots}"
                                          DockPanel.Dock="Right"
                                          FontFamily="{StaticResource FontBody}"
                                          FontSize="12"
                                          Foreground="{DynamicResource BrushTextSecondary}"/>
                                <TextBlock Text="Minecraft version"
                                           FontFamily="{StaticResource FontBody}"
                                           FontSize="12"
                                           Foreground="{DynamicResource BrushTextSecondary}"/>
                            </DockPanel>

                            <!-- Avalonia's ComboBox has no IsEditable/Text (unlike WPF's editable ComboBox),
                                 so AutoCompleteBox is used instead — same free-text-entry-with-dropdown
                                 behavior. FilterMode="None" because the item list is already filtered by
                                 the ViewModel (FilteredMinecraftVersions), so no extra client-side filtering
                                 should be applied on top of it. -->
                            <AutoCompleteBox x:Name="MinecraftVersionCombo"
                                             FilterMode="None"
                                             ItemsSource="{Binding FilteredMinecraftVersions}"
                                             Text="{Binding NewMinecraftVersion}"
                                             HorizontalAlignment="Stretch"
                                             Margin="0,0,0,16"
                                             TextChanged="MinecraftVersionCombo_TextChanged"/>

                            <TextBlock Text="Loader"
                                       FontFamily="{StaticResource FontBody}"
                                       FontSize="12"
                                       Foreground="{DynamicResource BrushTextSecondary}"
                                       Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding Loaders}"
                                      SelectedItem="{Binding NewLoader}"
                                      HorizontalAlignment="Left"
                                      MinWidth="200"
                                      Margin="0,0,0,16"/>

                            <TextBlock Text="Loader version"
                                       FontFamily="{StaticResource FontBody}"
                                       FontSize="12"
                                       Foreground="{DynamicResource BrushTextSecondary}"
                                       Margin="0,0,0,4"
                                       IsVisible="{Binding NewLoader, Converter={StaticResource LoaderNotVanillaToVisibilityConverter}}"/>
                            <ComboBox ItemsSource="{Binding AvailableLoaderVersions}"
                                      SelectedItem="{Binding NewLoaderVersion}"
                                      HorizontalAlignment="Left"
                                      MinWidth="200"
                                      Margin="0,0,0,16"
                                      IsVisible="{Binding NewLoader, Converter={StaticResource LoaderNotVanillaToVisibilityConverter}}"/>

                            <!-- Java advice -->
                            <Border Background="{StaticResource BrushPanelElevated}"
                                    BorderBrush="{StaticResource BrushBorder}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12,10"
                                    Margin="0,0,0,12"
                                    IsVisible="{Binding HasJavaAdvice}">
                                <TextBlock Text="{Binding JavaAdvice}"
                                           FontFamily="{StaticResource FontBody}"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource BrushTextPrimary}"/>
                            </Border>

                            <!-- Create status -->
                            <TextBlock Text="{Binding CreateStatus}"
                                       FontFamily="{StaticResource FontBody}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource BrushTextSecondary}"
                                       Margin="0,0,0,12"
                                       IsVisible="{Binding HasCreateStatus}"/>

                            <!-- Bottom padding inside scroll -->
                            <Border Height="8"/>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Sticky footer: Cancel + Create -->
                    <Border Grid.Row="2"
                            Background="{StaticResource BrushSidebarBackground}"
                            BorderBrush="{StaticResource BrushBorder}"
                            BorderThickness="0,1,0,0"
                            CornerRadius="0,0,12,12"
                            Padding="24,14">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Cancel"
                                    Theme="{StaticResource SecondaryButtonStyle}"
                                    Padding="18,8"
                                    Margin="0,0,10,0"
                                    Click="CancelCreate_Click"/>
                            <Button Content="Create"
                                    Theme="{StaticResource PrimaryButtonStyle}"
                                    Padding="22,8"
                                    IsEnabled="{Binding IsCreateDialogBusy, Converter={StaticResource InverseBoolConverter}}"
                                    Click="CreateInstallation_Click"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Border>

        <!-- ========== Sign-in / play overlay ========== -->
        <Border Background="#CC000000"
                IsVisible="{Binding IsLoginVisible}">
            <Border Background="{StaticResource BrushPanelBackground}"
                    BorderBrush="{StaticResource BrushBorder}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="28"
                    Width="420"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Play Minecraft"
                               FontFamily="{StaticResource FontDisplay}"
                               FontSize="18"
                               Foreground="{StaticResource BrushTextPrimary}"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="Sign in with Microsoft to play online, or play offline for singleplayer and LAN."
                               FontFamily="{StaticResource FontBody}"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource BrushTextSecondary}"
                               Margin="0,0,0,20"/>

                    <!-- Microsoft sign-in button -->
                    <Button Click="SignIn_Click"
                            HorizontalAlignment="Stretch"
                            Height="46"
                            Cursor="Hand"
                            IsEnabled="{Binding IsSigningIn, Converter={StaticResource InverseBoolConverter}}">
                        <Button.Styles>
                            <Style Selector="Button:pointerover /template/ Border#Bd">
                                <Setter Property="Background" Value="#8B5CF6"/>
                            </Style>
                            <Style Selector="Button:disabled /template/ Border#Bd">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Style>
                        </Button.Styles>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="{DynamicResource BrushAccent}" CornerRadius="8">
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                        <Grid Width="20" Height="20" Margin="0,0,12,0"
                                              ColumnDefinitions="*,*" RowDefinitions="*,*">
                                            <Rectangle Grid.Row="0" Grid.Column="0" Fill="#F25022" Margin="0,0,1,1"/>
                                            <Rectangle Grid.Row="0" Grid.Column="1" Fill="#7FBA00" Margin="1,0,0,1"/>
                                            <Rectangle Grid.Row="1" Grid.Column="0" Fill="#00A4EF" Margin="0,1,1,0"/>
                                            <Rectangle Grid.Row="1" Grid.Column="1" Fill="#FFB900" Margin="1,1,0,0"/>
                                        </Grid>
                                        <TextBlock Text="Sign in with Microsoft"
                                                   Foreground="White"
                                                   FontFamily="{StaticResource FontBody}"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Device code box -->
                    <Border Background="{StaticResource BrushPanelElevated}"
                            BorderBrush="{StaticResource BrushBorder}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="14"
                            Margin="0,14,0,0"
                            IsVisible="{Binding HasDeviceCode}">
                        <StackPanel>
                            <TextBlock Text="Enter this code on the Microsoft sign-in page:"
                                       FontFamily="{StaticResource FontBody}"
                                       FontSize="12"
                                       Foreground="{StaticResource BrushTextSecondary}"
                                       Margin="0,0,0,6"/>
                            <Grid>
                                <TextBlock Text="{Binding DeviceCode}"
                                           FontFamily="{StaticResource FontDisplay}"
                                           FontSize="24"
                                           Foreground="{StaticResource BrushTextPrimary}"
                                           VerticalAlignment="Center"/>
                                <Button Content="Copy"
                                        Theme="{StaticResource SecondaryButtonStyle}"
                                        Padding="12,5"
                                        FontSize="12"
                                        HorizontalAlignment="Right"
                                        Click="CopyShareCode_Click"/>
                            </Grid>
                            <TextBlock Text="{Binding DeviceVerificationUri}"
                                       FontFamily="{StaticResource FontBody}"
                                       FontSize="12"
                                       Foreground="{StaticResource BrushAccent}"
                                       Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="{Binding LoginStatus}"
                               FontFamily="{StaticResource FontBody}"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource BrushTextSecondary}"
                               Margin="0,12,0,0"
                               IsVisible="{Binding HasLoginStatus}"/>

                    <Border Height="1" Background="{StaticResource BrushBorder}" Margin="0,20,0,16"/>

                    <!-- Offline play section -->
                    <TextBlock Text="Or play offline"
                               FontFamily="{StaticResource FontBody}"
                               FontSize="13"
                               Foreground="{StaticResource BrushTextSecondary}"
                               Margin="0,0,0,10"/>

                    <TextBlock Text="Player name:"
                               FontFamily="{StaticResource FontDisplay}"
                               FontSize="13"
                               Foreground="{StaticResource BrushTextSecondary}"
                               Margin="0,0,0,4"/>
                    <TextBox Text="{Binding OfflinePlayerName}"
                             Padding="10"
                             Background="{StaticResource BrushPanelElevated}"
                             BorderBrush="{StaticResource BrushBorder}"
                             BorderThickness="1"
                             Foreground="{StaticResource BrushTextPrimary}"
                             FontSize="13"
                             Margin="0,0,0,12"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancel"
                                Theme="{StaticResource SecondaryButtonStyle}"
                                Padding="16,8"
                                Margin="0,0,8,0"
                                Click="CancelLogin_Click"/>
                        <Button Content="Play offline"
                                Theme="{StaticResource SecondaryButtonStyle}"
                                Padding="16,8"
                                Click="PlayOffline_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <!-- ========== Launch progress overlay ========== -->
        <Border Background="#CC000000"
                IsVisible="{Binding IsLaunchVisible}">
            <Border Background="{StaticResource BrushPanelBackground}"
                    BorderBrush="{StaticResource BrushBorder}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="28"
                    Width="440"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Launching Minecraft"
                               FontFamily="{StaticResource FontDisplay}"
                               FontSize="18"
                               Foreground="{StaticResource BrushTextPrimary}"
                               Margin="0,0,0,16"/>

                    <TextBlock Text="{Binding LaunchStage}"
                               FontFamily="{StaticResource FontBody}"
                               FontSize="13"
                               Foreground="{StaticResource BrushTextPrimary}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,12"/>

                    <ProgressBar Height="10"
                                 Theme="{StaticResource ServerProgressBarStyle}"
                                 Minimum="0" Maximum="100"
                                 Value="{Binding LaunchPercent}"
                                 IsIndeterminate="{Binding LaunchIndeterminate}"
                                 Margin="0,0,0,14"/>

                    <Border Background="{StaticResource BrushPanelElevated}"
                            BorderBrush="{StaticResource BrushBorder}"
                            BorderThickness="1"
                            CornerRadius="6"
                            MaxHeight="200"
                            Margin="0,0,0,8"
                            IsVisible="{Binding HasLaunchMessage}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
                            <TextBox Text="{Binding LaunchMessage, Mode=OneWay}"
                                     FontFamily="{StaticResource FontBody}"
                                     FontSize="12"
                                     Foreground="{StaticResource BrushTextSecondary}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     TextWrapping="Wrap"
                                     IsReadOnly="True"/>
                        </ScrollViewer>
                    </Border>

                    <Button Content="Copy log"
                            Theme="{StaticResource SecondaryButtonStyle}"
                            Padding="14,6"
                            HorizontalAlignment="Right"
                            Margin="0,0,0,16"
                            IsVisible="{Binding HasLaunchMessage}"
                            Click="CopyLaunchLog_Click"/>

                    <Button Content="Done"
                            Theme="{StaticResource PrimaryButtonStyle}"
                            Padding="24,8"
                            HorizontalAlignment="Right"
                            IsEnabled="{Binding LaunchFinished}"
                            Click="FinishLaunch_Click"/>
                </StackPanel>
            </Border>
        </Border>


        <!-- ========== Share overlay ========== -->
        <Border IsVisible="{Binding IsShareVisible}"
                Background="#99000000" ZIndex="50">
            <Border Background="{StaticResource BrushPanelBackground}"
                    BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                    CornerRadius="14" Padding="28,24" MaxWidth="500" MaxHeight="580"
                    VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel>
                    <Grid Margin="0,0,0,16">
                        <TextBlock Text="Share Instance" FontFamily="{StaticResource FontDisplay}"
                                   FontSize="18" Foreground="{StaticResource BrushTextPrimary}"/>
                        <Button Content="x" Theme="{StaticResource SecondaryButtonStyle}"
                                Padding="8,4" HorizontalAlignment="Right" Click="CloseShare_Click"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Button Content="Share with Friends" Padding="14,7" Margin="0,0,8,0" Click="ShareTabFriends_Click"
                                Theme="{StaticResource SecondaryButtonStyle}"
                                Classes.active="{Binding IsFriendsTab}">
                            <Button.Styles>
                                <Style Selector="Button.active">
                                    <Setter Property="Background" Value="{StaticResource BrushAccent}"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Style>
                            </Button.Styles>
                        </Button>
                        <Button Content="Share Code" Padding="14,7" Click="ShareTabCode_Click"
                                Theme="{StaticResource SecondaryButtonStyle}"
                                Classes.active="{Binding IsCodeTab}">
                            <Button.Styles>
                                <Style Selector="Button.active">
                                    <Setter Property="Background" Value="{StaticResource BrushAccent}"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Style>
                            </Button.Styles>
                        </Button>
                    </StackPanel>
                    <!-- Friends tab -->
                    <StackPanel IsVisible="{Binding IsFriendsTab}">
                        <TextBlock Text="Select friends to share with:"
                                   FontFamily="{StaticResource FontBody}" FontSize="13"
                                   Foreground="{StaticResource BrushTextSecondary}" Margin="0,0,0,10"/>
                        <ScrollViewer MaxHeight="180" VerticalScrollBarVisibility="Auto" Margin="0,0,0,14">
                            <ItemsControl ItemsSource="{Binding ShareableFriends}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Content="{Binding DisplayName}"
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                  FontFamily="{StaticResource FontBody}" FontSize="13"
                                                  Foreground="{StaticResource BrushTextPrimary}" Margin="0,4"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                        <Button Content="Send" Theme="{StaticResource PrimaryButtonStyle}"
                                Padding="20,9" HorizontalAlignment="Left"
                                IsEnabled="{Binding IsShareBusy, Converter={StaticResource InverseBoolConverter}}"
                                Click="ShareWithFriends_Click"/>
                    </StackPanel>
                    <!-- Code tab -->
                    <StackPanel IsVisible="{Binding IsCodeTab}">
                        <TextBlock Text="Generate a share code anyone can use to import this instance:"
                                   FontFamily="{StaticResource FontBody}" FontSize="13"
                                   Foreground="{StaticResource BrushTextSecondary}" TextWrapping="Wrap" Margin="0,0,0,10"/>
                        <Button Content="Generate code" Theme="{StaticResource SecondaryButtonStyle}"
                                Padding="16,8" HorizontalAlignment="Left"
                                IsEnabled="{Binding IsShareBusy, Converter={StaticResource InverseBoolConverter}}"
                                Click="GenerateCode_Click"/>
                        <Border Background="{StaticResource BrushPanelElevated}"
                                BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                                CornerRadius="8" Padding="14,10" Margin="0,12,0,0"
                                IsVisible="{Binding HasShareCode}">
                            <Grid>
                                <TextBlock Text="{Binding ShareCode}" FontFamily="Consolas" FontSize="18"
                                           Foreground="{StaticResource BrushAccent}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                <Button Content="Copy" Theme="{StaticResource SecondaryButtonStyle}"
                                        Padding="10,5" HorizontalAlignment="Right" Click="CopyShareCode_Click"/>
                            </Grid>
                        </Border>
                        <TextBlock Text="Or import an instance using a code:"
                                   FontFamily="{StaticResource FontBody}" FontSize="13"
                                   Foreground="{StaticResource BrushTextSecondary}" Margin="0,20,0,8"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBox Text="{Binding ImportCode, Mode=TwoWay}"
                                     Width="200" Padding="10,8" FontFamily="{StaticResource FontBody}" FontSize="13"
                                     Background="{StaticResource BrushPanelElevated}"
                                     Foreground="{StaticResource BrushTextPrimary}"
                                     BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"/>
                            <Button Content="Import" Theme="{StaticResource PrimaryButtonStyle}"
                                    Padding="16,8" Margin="8,0,0,0"
                                    IsEnabled="{Binding IsShareBusy, Converter={StaticResource InverseBoolConverter}}"
                                    Click="ImportFromCode_Click"/>
                        </StackPanel>
                    </StackPanel>
                    <TextBlock Text="{Binding ShareStatus}" FontFamily="{StaticResource FontBody}" FontSize="12"
                               Foreground="{StaticResource BrushAccent}" TextWrapping="Wrap" Margin="0,14,0,0"
                               IsVisible="{Binding HasShareStatus}"/>
                </StackPanel>
            </Border>
        </Border>


    </Grid>
</UserControl>
